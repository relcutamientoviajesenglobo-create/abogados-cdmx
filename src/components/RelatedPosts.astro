---
/**
 * RelatedPosts — 3 cards enriquecidas con imagen, categoría, extracto
 * Se inyecta automáticamente en cada blog post después del CTA
 * Matching semántico por keywords compartidos + misma categoría
 */
import { getCollection } from 'astro:content';
import { getRelatedImage } from '../data/blog-images';

interface Props {
  currentSlug: string;
  currentKeywords: string;
}

const { currentSlug, currentKeywords } = Astro.props;

// Parse keywords
const keywords = currentKeywords
  ? currentKeywords.split(',').map(k => k.trim().toLowerCase())
  : [];

// Category mapping
const categoryMap: Record<string, { label: string; color: string; image: string }> = {
  'familiar': {
    label: 'Derecho Familiar',
    color: '#c17f3e',
    image: 'https://images.unsplash.com/photo-1491013516836-7db643ee125a?w=400&h=240&fit=crop&fm=webp&q=75'
  },
  'penal': {
    label: 'Derecho Penal',
    color: '#8b1a1a',
    image: 'https://images.unsplash.com/photo-1589578527966-fdac0f44566c?w=400&h=240&fit=crop&fm=webp&q=75'
  },
  'civil': {
    label: 'Derecho Civil',
    color: '#2d5f8a',
    image: 'https://images.unsplash.com/photo-1450101499163-c8848c66ca85?w=400&h=240&fit=crop&fm=webp&q=75'
  },
  'corporativo': {
    label: 'Derecho Corporativo',
    color: '#1a5c3a',
    image: 'https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?w=400&h=240&fit=crop&fm=webp&q=75'
  },
  'inmobiliario': {
    label: 'Derecho Inmobiliario',
    color: '#6b4c9a',
    image: 'https://images.unsplash.com/photo-1560518883-ce09059eeffa?w=400&h=240&fit=crop&fm=webp&q=75'
  },
  'migratorio': {
    label: 'Derecho Migratorio',
    color: '#2e7d6f',
    image: 'https://images.unsplash.com/photo-1569974507005-6dc61f97fb5c?w=400&h=240&fit=crop&fm=webp&q=75'
  },
  'laboral': {
    label: 'Derecho Laboral',
    color: '#c4731b',
    image: 'https://images.unsplash.com/photo-1521791136064-7986c2920216?w=400&h=240&fit=crop&fm=webp&q=75'
  },
  'general': {
    label: 'Derecho',
    color: '#001d3d',
    image: 'https://images.unsplash.com/photo-1589829545856-d10d557cf95f?w=400&h=240&fit=crop&fm=webp&q=75'
  }
};

// Detect category from keywords
function detectCategory(kws: string[]): string {
  const catKeywords: Record<string, string[]> = {
    'familiar': ['divorcio', 'custodia', 'pension alimenticia', 'matrimonio', 'adopcion', 'familia', 'familiar', 'conyugal', 'guarda', 'patria potestad', 'violencia domestica'],
    'penal': ['penal', 'delito', 'amparo', 'defensa penal', 'detenido', 'narcomenudeo', 'robo', 'fraude', 'penalista', 'antecedentes penales', 'violencia genero'],
    'civil': ['civil', 'contrato', 'sucesion', 'herencia', 'usucapion', 'demanda civil', 'responsabilidad civil', 'profeco', 'consumidor', 'embargo', 'mediacion civil', 'prescripcion', 'interdiccion', 'tutela', 'cobro', 'deuda'],
    'corporativo': ['empresa', 'corporativo', 'sociedad', 'mercantil', 'startup', 'compliance', 'franquicia', 'propiedad intelectual', 'marca', 'sa de cv', 'srl', 'sas', 'constituir', 'disolucion'],
    'inmobiliario': ['inmobiliario', 'inmueble', 'propiedad', 'arrendamiento', 'inquilino', 'escritura', 'compraventa', 'hipoteca', 'infonavit', 'fideicomiso', 'avaluo', 'condomin'],
    'migratorio': ['migratorio', 'migracion', 'visa', 'residencia', 'inm', 'extranjero', 'naturalizacion', 'deportacion', 'asilo', 'refugio', 'nacionalidad', 'trabajo extranjero'],
    'laboral': ['laboral', 'trabajo', 'despido', 'liquidacion', 'sindicato', 'outsourcing', 'subcontratacion', 'jornada', 'horas extra', 'home office', 'teletrabajo', 'mobbing', 'acoso laboral', 'contrato trabajo', 'accidente trabajo']
  };

  for (const [cat, catKws] of Object.entries(catKeywords)) {
    if (kws.some(kw => catKws.some(ck => kw.includes(ck) || ck.includes(kw)))) {
      return cat;
    }
  }
  return 'general';
}

const currentCategory = detectCategory(keywords);

// Get all posts
const allPosts = await getCollection('blog');
const otherPosts = allPosts.filter(p => p.slug !== currentSlug);

// Score each post by semantic relevance
function scorePost(post: any): number {
  const postKeywords = post.data.keywords
    ? post.data.keywords.split(',').map((k: string) => k.trim().toLowerCase())
    : [];
  const postCategory = detectCategory(postKeywords);

  let score = 0;

  // Keyword overlap (highest weight)
  for (const kw of keywords) {
    for (const pkw of postKeywords) {
      if (kw === pkw) score += 10;
      else if (kw.includes(pkw) || pkw.includes(kw)) score += 5;
      else {
        // Check word overlap
        const kwWords = kw.split(' ');
        const pkwWords = pkw.split(' ');
        for (const w of kwWords) {
          if (w.length > 3 && pkwWords.includes(w)) score += 3;
        }
      }
    }
  }

  // Same category bonus
  if (postCategory === currentCategory) score += 8;

  // Different category slight bonus for diversity (only if already has some relevance)
  if (postCategory !== currentCategory && score > 0) score += 2;

  return score;
}

// Score and sort
const scored = otherPosts.map(p => ({ post: p, score: scorePost(p) }));
scored.sort((a, b) => b.score - a.score);

// Pick top 3, ensure at least 2 from same category
const topSameCategory = scored.filter(s => detectCategory(
  s.post.data.keywords?.split(',').map((k: string) => k.trim().toLowerCase()) || []
) === currentCategory);
const topOtherCategory = scored.filter(s => detectCategory(
  s.post.data.keywords?.split(',').map((k: string) => k.trim().toLowerCase()) || []
) !== currentCategory);

let related: typeof scored = [];
if (topSameCategory.length >= 2) {
  related = [topSameCategory[0], topSameCategory[1]];
  // Add best from another category for diversity
  if (topOtherCategory.length > 0 && topOtherCategory[0].score > 0) {
    related.push(topOtherCategory[0]);
  } else if (topSameCategory.length > 2) {
    related.push(topSameCategory[2]);
  }
} else {
  related = scored.slice(0, 3);
}

// Ensure we have exactly 3
while (related.length < 3 && scored.length > related.length) {
  const next = scored.find(s => !related.includes(s));
  if (next) related.push(next);
}

// Build card data
const cards = related.slice(0, 3).map(({ post }) => {
  const postKws = post.data.keywords
    ? post.data.keywords.split(',').map((k: string) => k.trim().toLowerCase())
    : [];
  const cat = detectCategory(postKws);
  const catInfo = categoryMap[cat] || categoryMap['general'];

  return {
    slug: post.slug,
    title: post.data.title,
    description: post.data.description,
    author: post.data.author,
    category: catInfo.label,
    categoryColor: catInfo.color,
    image: getRelatedImage(post.slug),
    date: post.data.date,
  };
});

const months = ['enero','febrero','marzo','abril','mayo','junio','julio','agosto','septiembre','octubre','noviembre','diciembre'];
---

{cards.length > 0 && (
  <section class="related-posts reveal">
    <div class="related-posts__header">
      <span class="related-posts__line"></span>
      <h2 class="related-posts__title">Le podría interesar</h2>
      <span class="related-posts__line"></span>
    </div>

    <div class="related-posts__grid">
      {cards.map((card) => (
        <a href={`/blog/${card.slug}`} class="rp-card" data-category={card.category}>
          <div class="rp-card__image-wrap">
            <img
              src={card.image}
              alt={card.title}
              width="400"
              height="240"
              loading="lazy"
              class="rp-card__image"
            />
            <span class="rp-card__badge" style={`background:${card.categoryColor}`}>
              {card.category}
            </span>
          </div>
          <div class="rp-card__body">
            <h3 class="rp-card__title">{card.title}</h3>
            <p class="rp-card__excerpt">{card.description}</p>
            <div class="rp-card__footer">
              <span class="rp-card__author">{card.author}</span>
              <span class="rp-card__read">Leer artículo →</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>
)}

<style>
  .related-posts {
    margin-top: 56px;
    padding-top: 48px;
    border-top: 1px solid var(--color-border, #e0e0e0);
  }

  .related-posts__header {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 36px;
  }

  .related-posts__line {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-secondary, #c17f3e), transparent);
  }

  .related-posts__title {
    font-size: 22px;
    font-weight: 700;
    color: var(--color-primary, #001d3d);
    white-space: nowrap;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    font-size: 14px;
  }

  .related-posts__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  /* Card */
  .rp-card {
    display: flex;
    flex-direction: column;
    background: var(--color-white, #fff);
    border: 1px solid var(--color-border, #e8e8e8);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .rp-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0, 29, 61, 0.12);
  }

  .rp-card:hover .rp-card__image {
    transform: scale(1.05);
  }

  .rp-card:hover .rp-card__read {
    color: var(--color-secondary, #c17f3e);
  }

  /* Image */
  .rp-card__image-wrap {
    position: relative;
    overflow: hidden;
    aspect-ratio: 5 / 3;
  }

  .rp-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .rp-card__badge {
    position: absolute;
    top: 12px;
    left: 12px;
    padding: 4px 12px;
    font-size: 11px;
    font-weight: 700;
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 0.8px;
    backdrop-filter: blur(4px);
  }

  /* Body */
  .rp-card__body {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: 20px;
  }

  .rp-card__title {
    font-size: 17px;
    font-weight: 700;
    line-height: 1.35;
    color: var(--color-primary, #001d3d);
    margin-bottom: 10px;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .rp-card__excerpt {
    font-size: 14px;
    line-height: 1.55;
    color: var(--color-paragraph, #555);
    margin-bottom: 16px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
  }

  .rp-card__footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 14px;
    border-top: 1px solid var(--color-border, #e8e8e8);
    font-size: 13px;
  }

  .rp-card__author {
    color: var(--color-primary, #001d3d);
    font-weight: 600;
  }

  .rp-card__read {
    color: var(--color-paragraph, #888);
    font-weight: 500;
    transition: color 0.2s;
  }

  /* Responsive */
  @media (max-width: 991px) {
    .related-posts__grid {
      grid-template-columns: 1fr;
      gap: 20px;
    }

    .rp-card {
      flex-direction: row;
    }

    .rp-card__image-wrap {
      width: 180px;
      min-height: 100%;
      aspect-ratio: auto;
      flex-shrink: 0;
    }

    .rp-card__body {
      padding: 16px;
    }

    .rp-card__title {
      font-size: 16px;
      -webkit-line-clamp: 2;
    }

    .rp-card__excerpt {
      -webkit-line-clamp: 2;
    }
  }

  @media (max-width: 479px) {
    .rp-card {
      flex-direction: column;
    }

    .rp-card__image-wrap {
      width: 100%;
      aspect-ratio: 16 / 9;
    }

    .related-posts__header {
      margin-bottom: 24px;
    }

    .rp-card__body {
      padding: 14px;
    }
  }
</style>
