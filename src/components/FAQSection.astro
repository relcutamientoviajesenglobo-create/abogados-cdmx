---
/**
 * FAQSection.astro
 * Componente de FAQ con acordeón CSS puro (sin JavaScript)
 * Renderiza <details><summary> accesibles con schema JSON-LD opcional
 */

import SchemaOrg from './SchemaOrg.astro';

interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  faqs: FAQItem[];
  includeSchema?: boolean;
}

const { faqs, includeSchema = true } = Astro.props;

// Validación
if (!faqs || !Array.isArray(faqs) || faqs.length === 0) {
  console.warn('FAQSection: faqs debe ser un array no vacío');
}

// Preparar datos para schema FAQPage
const faqItems = faqs.map((item) => ({
  '@type': 'Question',
  name: item.question,
  acceptedAnswer: {
    '@type': 'Answer',
    text: item.answer
  }
}));

const faqPageSchema = {
  '@type': 'FAQPage',
  mainEntity: faqItems
};
---

{includeSchema && <SchemaOrg type="FAQPage" data={faqPageSchema} />}

<section class="faq-section" aria-labelledby="faq-title">
  <h2 id="faq-title" class="faq-title">Preguntas Frecuentes</h2>
  <div class="faq-container">
    {
      faqs.map((item, index) => (
        <details class="faq-item" key={index}>
          <summary class="faq-question">{item.question}</summary>
          <div class="faq-answer">
            <p set:html={item.answer} />
          </div>
        </details>
      ))
    }
  </div>
</section>

<style>
  .faq-section {
    width: 100%;
    max-width: 800px;
    margin: 2rem auto;
    padding: 0 1rem;
  }

  .faq-title {
    font-size: 1.75rem;
    margin-bottom: 1.5rem;
    color: #1a1a1a;
  }

  .faq-container {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .faq-item {
    border: 1px solid #e0e0e0;
    border-radius: 0.5rem;
    overflow: hidden;
    transition: all 0.3s ease;
  }

  .faq-item:hover {
    border-color: #003366;
    box-shadow: 0 2px 8px rgba(0, 51, 102, 0.1);
  }

  .faq-question {
    padding: 1.25rem;
    background-color: #f5f5f5;
    cursor: pointer;
    font-weight: 600;
    display: flex;
    justify-content: space-between;
    align-items: center;
    user-select: none;
    color: #003366;
    transition: background-color 0.3s ease;
  }

  .faq-question:hover {
    background-color: #efefef;
  }

  .faq-question::after {
    content: '›';
    font-size: 1.5rem;
    transition: transform 0.3s ease;
    margin-left: 0.5rem;
  }

  details[open] .faq-question {
    background-color: #e8f0f7;
  }

  details[open] .faq-question::after {
    transform: rotate(90deg);
  }

  .faq-answer {
    padding: 1.25rem;
    background-color: #fafafa;
    border-top: 1px solid #e0e0e0;
    line-height: 1.6;
    color: #333;
  }

  .faq-answer p {
    margin: 0;
  }

  .faq-answer p + p {
    margin-top: 1rem;
  }

  /* Accesibilidad */
  details:focus-within .faq-question {
    outline: 2px solid #003366;
    outline-offset: 2px;
  }

  @media (max-width: 640px) {
    .faq-section {
      padding: 0 0.75rem;
    }

    .faq-question {
      padding: 1rem;
    }

    .faq-answer {
      padding: 1rem;
    }

    .faq-title {
      font-size: 1.5rem;
    }
  }
</style>
