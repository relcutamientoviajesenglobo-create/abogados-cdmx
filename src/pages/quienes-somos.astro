---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import MarqueeTrust from '../components/MarqueeTrust.astro';
import Footer from '../components/Footer.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

const title = 'Quiénes Somos — Despacho Jurídico en CDMX | Abogados en CDMX';
const description = 'Abogados en CDMX es un despacho jurídico multidisciplinario en Colonia Roma Norte, Ciudad de México. Más de 300 casos resueltos en 7 áreas del derecho con un equipo de 20+ abogados.';
const canonical = 'https://abogadosencdmx.com/quienes-somos';

const values = [
  { icon: '🎯', title: 'Enfoque en resultados', desc: 'Cada estrategia legal que diseñamos tiene un objetivo medible. No prolongamos casos innecesariamente ni generamos honorarios sin justificación.' },
  { icon: '🤝', title: 'Transparencia total', desc: 'Desde la primera consulta conocerá los costos, los tiempos estimados y las probabilidades reales de éxito. Sin sorpresas ni letra pequeña.' },
  { icon: '📚', title: 'Especialización real', desc: 'Cada abogado de nuestro equipo se dedica a una rama específica del derecho. No somos generalistas que intentan cubrir todo sin profundidad.' },
  { icon: '⏱️', title: 'Comunicación constante', desc: 'Usted sabrá el estado de su caso en todo momento. Respondemos llamadas, correos y mensajes con la prontitud que su situación merece.' },
];

const schema = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "name": "Quiénes Somos — Abogados en CDMX",
  "description": description,
  "url": canonical,
  "mainEntity": {
    "@type": "LegalService",
    "name": "Abogados en CDMX",
    "url": "https://abogadosencdmx.com",
    "telephone": "+525564655501",
    "foundingDate": "2016",
    "numberOfEmployees": { "@type": "QuantitativeValue", "minValue": 20 },
    "address": { "@type": "PostalAddress", "streetAddress": "Guanajuato 224", "addressLocality": "Ciudad de México", "postalCode": "06700", "addressCountry": "MX" },
    "areaServed": { "@type": "City", "name": "Ciudad de México" },
    "sameAs": [
      "https://facebook.com/abogadosencdmx",
      "https://instagram.com/abogadosencdmx",
      "https://linkedin.com/company/abogadosencdmx"
    ]
  }
};
---

<Base title={title} description={description} canonical={canonical} schema={schema}>
  <Header slot="header" />

  <section class="hero-pillar" style="background-color: var(--color-primary);">
    <div class="container">
      <Breadcrumb items={[{label: 'Quiénes Somos'}]} />
      <div class="hero-pillar__content reveal">
        <p class="section-tag" style="color:var(--color-secondary);">Nuestro despacho</p>
        <h1 class="text-white">Quiénes somos</h1>
        <p class="text-white-soft" style="font-size:19px; line-height:1.7; max-width:746px;">Abogados en CDMX es un despacho jurídico multidisciplinario establecido en la Colonia Roma Norte de la Ciudad de México. Nuestro equipo de más de 20 abogados se especializa en siete áreas del derecho, lo que nos permite ofrecer soluciones legales integrales respaldadas por conocimiento técnico profundo y experiencia comprobada en tribunales.</p>
      </div>
    </div>
  </section>
  <MarqueeTrust />

  <!-- BRACKET: Conceptual — Historia y misión -->
  <section class="section-padding" style="background-color: var(--color-light);">
    <div class="container">
      <div class="two-col reveal">
        <div>
          <p class="section-tag">Nuestra historia</p>
          <h2>Un despacho construido sobre resultados</h2>
          <p>Abogados en CDMX nació con una premisa clara: ofrecer representación legal que combine especialización técnica con trato humano. Desde nuestras oficinas en Guanajuato 224, Colonia Roma Norte, hemos construido un equipo que atiende casos en las siete ramas del derecho más demandadas en la Ciudad de México.</p>
          <p>A lo largo de nuestra trayectoria hemos resuelto más de 300 casos en materias que van desde divorcios y custodia hasta litigios corporativos y defensa penal. Esta experiencia acumulada nos permite anticipar escenarios, diseñar estrategias sólidas y ofrecer a nuestros clientes la tranquilidad de saber que su caso está en manos de especialistas.</p>
          <p>Nuestra misión es hacer accesible la asesoría legal de calidad. Creemos que toda persona y empresa en la Ciudad de México merece contar con un abogado que realmente entienda su situación, le explique sus opciones con claridad y trabaje con determinación para proteger sus derechos e intereses.</p>
        </div>
        <div>
          <img src="https://images.unsplash.com/photo-1497366216548-37526070297c?w=800&h=600&fit=crop&fm=webp&q=75" alt="Oficinas de Abogados en CDMX en Colonia Roma Norte, Ciudad de México" loading="lazy" style="width:100%; aspect-ratio:4/3; object-fit:cover; background:#ddd;" />
        </div>
      </div>
    </div>
  </section>

  <!-- BRACKET: Operational — Valores -->
  <section class="section-padding">
    <div class="container">
      <div class="text-center mb-50 reveal">
        <p class="section-tag">Lo que nos define</p>
        <h2>Nuestros valores como despacho</h2>
      </div>
      <div class="values-grid">
        {values.map((v, i) => (
          <div class="value-card reveal" style={`--delay:${i * 0.08}s`}>
            <span class="value-card__icon" aria-hidden="true">{v.icon}</span>
            <h3>{v.title}</h3>
            <p>{v.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- BRACKET: Intent — Especialización y alcance -->
  <section class="section-padding">
    <div class="container">
      <div class="reveal" style="max-width:850px;">
        <p class="section-tag">Nuestra Especialización</p>
        <h2>Un despacho multidisciplinario con raíz en la Ciudad de México</h2>
        <p style="font-size:18px;line-height:1.7;margin-bottom:20px;">Abogados en CDMX es un despacho jurídico que opera exclusivamente en la Ciudad de México. Esta decisión estratégica nos permite conocer los juzgados, tribunales, fiscalías, centros de conciliación y autoridades administrativas de la capital como ningún otro despacho. No pretendemos abarcar todo el país — nos concentramos en dominar el sistema jurídico de la Ciudad de México para que nuestros clientes obtengan los mejores resultados posibles.</p>
        <p style="font-size:16px;line-height:1.8;margin-bottom:16px;">Nuestra práctica se estructura en siete <a href="/especialidades">áreas de especialidad</a>: <a href="/especialidades/derecho-familiar-cdmx">derecho familiar</a>, <a href="/especialidades/derecho-penal-cdmx">derecho penal</a>, <a href="/especialidades/derecho-civil-cdmx">derecho civil</a>, <a href="/especialidades/derecho-corporativo-cdmx">derecho corporativo</a>, <a href="/especialidades/derecho-inmobiliario-cdmx">derecho inmobiliario</a>, <a href="/especialidades/derecho-laboral-cdmx">derecho laboral</a> y <a href="/especialidades/derecho-migratorio-cdmx">derecho migratorio</a>. Cada área cuenta con abogados dedicados que conocen la legislación aplicable, los procedimientos vigentes y los criterios actuales de los juzgados y tribunales de la Ciudad de México.</p>
        <p style="font-size:16px;line-height:1.8;">Nuestras oficinas se ubican en Guanajuato 224, Colonia Roma Norte, Alcaldía Cuauhtémoc, C.P. 06700 — en el corazón de una de las zonas con mayor concentración de despachos jurídicos, notarías y oficinas gubernamentales de la ciudad. Esta ubicación nos permite atender audiencias, presentar escritos y realizar gestiones con agilidad. Para conocer a los abogados que integran nuestro equipo, visite nuestra sección de <a href="/equipo-legal-cdmx">equipo legal</a> o agende una <a href="/asesoria-inicial">asesoría inicial</a> llamando al 55 6465 5501.</p>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="section-padding" style="background-color: var(--color-light);">
    <div class="container">
      <div class="stats-row reveal">
        <div class="stat-item"><span class="stat-item__num">20+</span><span class="stat-item__label">Abogados especializados</span></div>
        <div class="stat-item"><span class="stat-item__num">7</span><span class="stat-item__label">Áreas del derecho</span></div>
        <div class="stat-item"><span class="stat-item__num">300+</span><span class="stat-item__label">Casos resueltos</span></div>
        <div class="stat-item"><span class="stat-item__num">100+</span><span class="stat-item__label">Clientes satisfechos</span></div>
      </div>
    </div>
  </section>

  <!-- BRACKET: CTA — Equipo -->
  <section class="section-padding">
    <div class="container text-center">
      <div class="reveal">
        <p class="section-tag">Nuestro equipo</p>
        <h2>Conozca a los abogados detrás del despacho</h2>
        <p class="max-w-694 mb-40">Cada miembro de nuestro equipo se especializa en un área concreta del derecho. Conozca a los abogados que integran Abogados en CDMX.</p>
        <a href="/equipo-legal-cdmx" class="btn-primary-wrap"><span class="btn-primary">Conocer al equipo legal <span aria-hidden="true">→</span></span></a>
        <div class="about-social">
          <p class="about-social__label">Síganos en redes sociales</p>
          <div class="about-social__icons">
            <a href="https://facebook.com/abogadosencdmx" target="_blank" rel="noopener noreferrer" aria-label="Facebook de Abogados en CDMX" class="about-social__link">
              <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            </a>
            <a href="https://instagram.com/abogadosencdmx" target="_blank" rel="noopener noreferrer" aria-label="Instagram de Abogados en CDMX" class="about-social__link">
              <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
            </a>
            <a href="https://linkedin.com/company/abogadosencdmx" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn de Abogados en CDMX" class="about-social__link">
              <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- BRACKET: CTA -->
  <section class="cta-section section-padding" style="background-color: var(--color-primary);">
    <div class="container text-center">
      <div class="reveal">
        <h2 class="text-white">¿Necesita un despacho de confianza?</h2>
        <p class="text-white-soft max-w-694 mb-40">Platiquemos sobre su caso. Nuestra primera consulta está diseñada para que usted entienda su situación legal y las opciones que tiene disponibles.</p>
        <div class="btn-group btn-group--center">
          <a href="/asesoria-inicial" class="btn-primary-wrap"><span class="btn-primary">Agendar asesoría inicial <span aria-hidden="true">→</span></span></a>
          <a href="/contacto" class="btn-secondary-wrap"><span class="btn-secondary">Contactar al despacho</span></a>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Base>

<style>
  
  

  .two-col { display: grid; grid-template-columns: 1.2fr 1fr; gap: 60px; align-items: center; }
  .two-col p { margin-bottom: 14px; }

  .values-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 32px; }
  .value-card {
    background: var(--color-white); border: 1px solid var(--color-border);
    padding: 40px 32px; transition-delay: var(--delay, 0s);
  }
  .value-card__icon { font-size: 32px; display: block; margin-bottom: 16px; }
  .value-card h3 { font-size: 24px; margin-bottom: 12px; }
  .value-card p { font-size: 16px; line-height: 1.7; margin: 0; }

  .stats-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 32px; text-align: center; }
  .stat-item__num { display: block; font-family: var(--font-heading); font-size: 56px; color: var(--color-secondary); line-height: 1.1; margin-bottom: 8px; }
  .stat-item__label { font-size: 16px; font-weight: 500; }

  .about-social { margin-top: 32px; }
  .about-social__label {
    font-size: 14px; font-weight: 600; text-transform: uppercase;
    letter-spacing: 1px; color: var(--color-paragraph); margin-bottom: 12px;
  }
  .about-social__icons { display: flex; gap: 12px; justify-content: center; }
  .about-social__link {
    display: flex; align-items: center; justify-content: center;
    width: 42px; height: 42px;
    border: 1px solid var(--color-border);
    color: var(--color-secondary);
    transition: all var(--transition);
  }
  .about-social__link:hover {
    background: var(--color-secondary);
    color: var(--color-white);
    border-color: var(--color-secondary);
  }
  .about-social__link svg { width: 20px; height: 20px; }

  .cta-section h2 { margin-bottom: 16px; }

  @media (max-width: 991px) {
    .two-col { grid-template-columns: 1fr; gap: 40px; }
    .stats-row { grid-template-columns: repeat(2, 1fr); }
    .values-grid { grid-template-columns: 1fr; }
  }
  
  @media (max-width: 767px) {
    h1 { font-size: 36px; }
    .lead { font-size: 18px; }
  }
  @media (max-width: 479px) {
    .stats-row { grid-template-columns: 1fr; }
    .stat-item__num { font-size: 42px; }
  }
</style>
