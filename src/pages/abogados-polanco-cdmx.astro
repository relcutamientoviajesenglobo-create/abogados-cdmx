---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = 'Abogados en Polanco, CDMX — Despacho Jurídico Cerca de Polanco | Abogados en CDMX';
const description = 'Abogados cerca de Polanco, CDMX. Despacho jurídico a 15 minutos de Polanco especializado en derecho corporativo, familiar, penal, civil, inmobiliario, migratorio y laboral.';
const canonical = 'https://abogadosencdmx.com/abogados-polanco-cdmx';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LegalService",
      "name": "Abogados Cerca de Polanco, CDMX",
      "description": "Despacho jurídico que atiende a clientes de Polanco, Alcaldía Miguel Hidalgo, CDMX. Oficina en Roma Norte a 15 minutos de Polanco.",
      "url": "https://abogadosencdmx.com/abogados-polanco-cdmx",
      "telephone": "+525564655501",
      "email": "contacto@abogadosencdmx.com",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Guanajuato 224",
        "addressLocality": "Ciudad de México",
        "addressRegion": "CDMX",
        "postalCode": "06700",
        "addressCountry": "MX",
        "name": "Colonia Roma Norte, Alcaldía Cuauhtémoc"
      },
      "geo": { "@type": "GeoCoordinates", "latitude": 19.4329, "longitude": -99.1926 },
      "areaServed": {
        "@type": "Place",
        "name": "Polanco, Alcaldía Miguel Hidalgo, Ciudad de México",
        "geo": { "@type": "GeoCoordinates", "latitude": 19.4329, "longitude": -99.1926 }
      },
      "openingHoursSpecification": { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"], "opens": "09:00", "closes": "18:00" },
      "priceRange": "$$"
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://abogadosencdmx.com/" },
        { "@type": "ListItem", "position": 2, "name": "Abogados en Polanco", "item": "https://abogadosencdmx.com/abogados-polanco-cdmx" }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "¿Hay un despacho de abogados en Polanco?",
          "acceptedAnswer": { "@type": "Answer", "text": "Nuestro despacho se encuentra en la Colonia Roma Norte, a solo 15 minutos de Polanco por Avenida Paseo de la Reforma. Atendemos a clientes de Polanco, Lomas de Chapultepec y toda la Alcaldía Miguel Hidalgo." }
        },
        {
          "@type": "Question",
          "name": "¿Qué tipo de casos atienden para clientes de Polanco?",
          "acceptedAnswer": { "@type": "Answer", "text": "Atendemos casos de derecho corporativo, inmobiliario, familiar, penal, civil, migratorio y laboral. Muchos de nuestros clientes de Polanco requieren asesoría corporativa, contratos inmobiliarios de alto valor y trámites migratorios." }
        },
        {
          "@type": "Question",
          "name": "¿Cómo llego desde Polanco al despacho?",
          "acceptedAnswer": { "@type": "Answer", "text": "Desde Polanco puede tomar Paseo de la Reforma hacia el oriente hasta la Glorieta de los Insurgentes, luego dirigirse al sur sobre Insurgentes hasta la calle Guanajuato. En Metro, tome la Línea 7 de Polanco a Tacubaya y transborde a la Línea 1 hasta Insurgentes." }
        },
        {
          "@type": "Question",
          "name": "¿Ofrecen consultas en oficinas de Polanco?",
          "acceptedAnswer": { "@type": "Answer", "text": "Nuestras consultas presenciales se realizan en nuestra oficina de Roma Norte. También ofrecemos consultas por videollamada para mayor comodidad. La primera consulta es gratuita y sin compromiso." }
        }
      ]
    }
  ]
};

const especialidades = [
  { nombre: 'Derecho Familiar', href: '/especialidades/derecho-familiar-cdmx', icono: '&#9825;', desc: 'Divorcios, custodia, pensión alimenticia y adopciones.' },
  { nombre: 'Derecho Penal', href: '/especialidades/derecho-penal-cdmx', icono: '&#9878;', desc: 'Defensa penal, amparos y delitos patrimoniales.' },
  { nombre: 'Derecho Civil', href: '/especialidades/derecho-civil-cdmx', icono: '&#9998;', desc: 'Contratos, responsabilidad civil y sucesiones.' },
  { nombre: 'Derecho Corporativo', href: '/especialidades/derecho-corporativo-cdmx', icono: '&#9881;', desc: 'Constitución de empresas, compliance y gobierno corporativo.' },
  { nombre: 'Derecho Inmobiliario', href: '/especialidades/derecho-inmobiliario-cdmx', icono: '&#8962;', desc: 'Compraventa, escrituración y arrendamiento.' },
  { nombre: 'Derecho Migratorio', href: '/especialidades/derecho-migratorio-cdmx', icono: '&#9992;', desc: 'Visas, residencia temporal y permanente, naturalización.' },
  { nombre: 'Derecho Laboral', href: '/especialidades/derecho-laboral-cdmx', icono: '&#9874;', desc: 'Despidos injustificados, liquidaciones y demandas laborales.' },
];
---

<Base title={title} description={description} canonical={canonical} schema={schema}>
  <Header slot="header" />

  <section class="loc-hero">
    <div class="loc-container">
      <nav class="loc-breadcrumb" aria-label="Breadcrumb">
        <a href="/">Inicio</a> &rsaquo; <span>Abogados en Polanco</span>
      </nav>
      <span class="loc-badge">Despacho jur&iacute;dico a 15 minutos de Polanco</span>
      <h1>Abogados en Polanco, Ciudad de M&eacute;xico</h1>
      <p class="loc-hero-desc">Atendemos a clientes de Polanco, Lomas de Chapultepec y la Alcald&iacute;a Miguel Hidalgo desde nuestro despacho en la Colonia Roma Norte. Especialistas en derecho corporativo, inmobiliario, familiar y las 7 &aacute;reas de pr&aacute;ctica jur&iacute;dica m&aacute;s demandadas en la zona.</p>
    </div>
  </section>

  <section class="loc-section">
    <div class="loc-container">
      <h2>Servicios legales para Polanco y Alcald&iacute;a Miguel Hidalgo</h2>
      <p>Polanco es el epicentro corporativo y residencial de alta gama en la Ciudad de M&eacute;xico. Desde nuestra oficina en Roma Norte atendemos a empresas con sede en Polanco, Campos El&iacute;seos y Masaryk en asuntos de derecho corporativo, compliance y contratos comerciales. Tambi&eacute;n asesoramos a familias de la zona en divorcios, sucesiones, compraventa de inmuebles de alto valor y tr&aacute;mites migratorios para ejecutivos extranjeros.</p>
      <p>La Alcald&iacute;a Miguel Hidalgo alberga embajadas, corporativos internacionales y desarrollos inmobiliarios premium, lo que genera necesidades jur&iacute;dicas especializadas en comercio internacional, visas de trabajo y contratos de arrendamiento comercial. Nuestro equipo tiene amplia experiencia atendiendo estas necesidades.</p>
    </div>
  </section>

  <section class="loc-section loc-section--alt">
    <div class="loc-container">
      <h2>C&oacute;mo llegar desde Polanco a nuestro despacho</h2>
      <p>Nuestra oficina est&aacute; en <strong>Guanajuato 224, Colonia Roma Norte</strong>, a aproximadamente 15 minutos de Polanco por Paseo de la Reforma.</p>
      <div class="loc-directions">
        <div class="loc-dir-card">
          <h3>En Metro</h3>
          <p>Tome la <strong>L&iacute;nea 7</strong> en la estaci&oacute;n <strong>Polanco</strong> hasta <strong>Tacubaya</strong>, transborde a la <strong>L&iacute;nea 1</strong> hasta <strong>Insurgentes</strong>. Desde ah&iacute;, camine 8 minutos al sur hasta Guanajuato 224. Tiempo total: aproximadamente 30 minutos.</p>
        </div>
        <div class="loc-dir-card">
          <h3>En auto</h3>
          <p>Tome <strong>Paseo de la Reforma</strong> hacia el oriente hasta la <strong>Glorieta de los Insurgentes</strong>. Gire al sur sobre Insurgentes y luego a la izquierda en Guanajuato. Trayecto de 15 a 25 minutos seg&uacute;n el tr&aacute;fico.</p>
        </div>
        <div class="loc-dir-card">
          <h3>En Metrob&uacute;s</h3>
          <p>Desde <strong>Auditorio</strong> (cerca de Polanco), tome la <strong>L&iacute;nea 7</strong> del Metrob&uacute;s sobre Reforma hasta <strong>Hamburgo</strong>, luego camine 10 minutos al sur hasta nuestra oficina.</p>
        </div>
      </div>
      <p class="loc-landmarks"><strong>Referencias:</strong> Nuestro despacho est&aacute; a 15 minutos del Museo Soumaya, a 20 minutos de Presidente Masaryk y a 10 minutos de la Glorieta de los Insurgentes.</p>
    </div>
  </section>

  <section class="loc-section">
    <div class="loc-container">
      <h2>&Aacute;reas del derecho para clientes de Polanco</h2>
      <div class="loc-specs-grid">
        {especialidades.map(e => (
          <a href={e.href} class="loc-spec-card">
            <span class="loc-spec-icon" set:html={e.icono} />
            <h3>{e.nombre}</h3>
            <p>{e.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="loc-section loc-section--alt">
    <div class="loc-container">
      <div class="loc-testimonial">
        <blockquote>
          <p>&ldquo;Dirijo una empresa en Polanco y necesit&aacute;bamos asesor&iacute;a corporativa urgente. A pesar de estar en Roma Norte, la cercan&iacute;a por Reforma hizo todo muy pr&aacute;ctico. El equipo reestructur&oacute; nuestros contratos mercantiles y nos ayud&oacute; con el compliance fiscal. Muy recomendable.&rdquo;</p>
          <cite>&mdash; Roberto Linares, Polanco, Alcald&iacute;a Miguel Hidalgo</cite>
        </blockquote>
      </div>
    </div>
  </section>

  <section class="loc-section">
    <div class="loc-container">
      <h2>Preguntas frecuentes — Abogados cerca de Polanco</h2>
      <div class="loc-faq">
        <details>
          <summary>&iquest;Hay un despacho de abogados en Polanco?</summary>
          <p>Nuestro despacho se encuentra en la Colonia Roma Norte, a solo 15 minutos de Polanco por Paseo de la Reforma. Atendemos a clientes de Polanco, Lomas de Chapultepec y toda la Alcald&iacute;a Miguel Hidalgo.</p>
        </details>
        <details>
          <summary>&iquest;Qu&eacute; tipo de casos atienden para clientes de Polanco?</summary>
          <p>Atendemos casos de derecho corporativo, inmobiliario, familiar, penal, civil, migratorio y laboral. Muchos clientes de Polanco nos buscan para asesor&iacute;a corporativa, contratos inmobiliarios de alto valor y tr&aacute;mites migratorios para ejecutivos.</p>
        </details>
        <details>
          <summary>&iquest;C&oacute;mo llego desde Polanco al despacho?</summary>
          <p>Desde Polanco tome Paseo de la Reforma hacia el oriente hasta Insurgentes, luego al sur hasta la calle Guanajuato. En Metro: L&iacute;nea 7 de Polanco a Tacubaya, transbordo a L&iacute;nea 1 hasta Insurgentes.</p>
        </details>
        <details>
          <summary>&iquest;Ofrecen consultas por videollamada para clientes de Polanco?</summary>
          <p>S&iacute;, ofrecemos consultas presenciales en nuestra oficina y tambi&eacute;n por videollamada. La primera consulta es gratuita en cualquier modalidad.</p>
        </details>
      </div>
    </div>
  </section>

  <section class="loc-cta">
    <div class="loc-container">
      <h2>Agende su consulta gratuita desde Polanco</h2>
      <p>Ll&aacute;menos, escr&iacute;banos por WhatsApp o solicite su asesor&iacute;a inicial en l&iacute;nea.</p>
      <div class="loc-cta-buttons">
        <a href="tel:+525564655501" class="loc-btn loc-btn--primary">Llamar: 55 6465 5501</a>
        <a href="https://wa.me/525564655501?text=Hola%2C%20soy%20de%20Polanco%20y%20quiero%20agendar%20una%20consulta%20legal" class="loc-btn loc-btn--whatsapp">WhatsApp</a>
        <a href="/asesoria-inicial" class="loc-btn loc-btn--outline">Asesor&iacute;a inicial gratuita</a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Base>

<style>
  .loc-hero{background:#1a1f3d;color:#fff;padding:80px 0 60px;text-align:center}
  .loc-hero h1{font-size:clamp(1.8rem,4vw,2.8rem);margin:16px 0;line-height:1.2}
  .loc-hero-desc{max-width:700px;margin:0 auto;font-size:1.1rem;opacity:.9;line-height:1.7}
  .loc-container{max-width:1100px;margin:0 auto;padding:0 20px}
  .loc-breadcrumb{font-size:.9rem;margin-bottom:16px;opacity:.7}
  .loc-breadcrumb a{color:#c9a84c;text-decoration:none}
  .loc-badge{display:inline-block;background:#c9a84c;color:#1a1f3d;padding:6px 18px;border-radius:50px;font-size:.85rem;font-weight:600;margin-bottom:10px}
  .loc-section{padding:60px 0}
  .loc-section--alt{background:#f8f7f4}
  .loc-section h2{font-size:clamp(1.4rem,3vw,2rem);color:#1a1f3d;margin-bottom:20px}
  .loc-section p{line-height:1.8;color:#333;max-width:800px;margin-bottom:16px}
  .loc-directions{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:24px;margin-top:30px}
  .loc-dir-card{background:#fff;border:1px solid #e8e6e1;border-radius:12px;padding:28px;box-shadow:0 2px 8px rgba(0,0,0,.04)}
  .loc-dir-card h3{color:#1a1f3d;margin-bottom:10px;font-size:1.1rem}
  .loc-dir-card p{font-size:.95rem;margin:0}
  .loc-landmarks{margin-top:24px;padding:16px 20px;background:#fff;border-left:4px solid #c9a84c;border-radius:0 8px 8px 0;font-size:.95rem}
  .loc-specs-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(250px,1fr));gap:20px;margin-top:30px}
  .loc-spec-card{display:block;background:#fff;border:1px solid #e8e6e1;border-radius:12px;padding:24px;text-decoration:none;transition:box-shadow .2s,border-color .2s}
  .loc-spec-card:hover{box-shadow:0 4px 16px rgba(0,0,0,.08);border-color:#c9a84c}
  .loc-spec-icon{font-size:1.6rem;display:block;margin-bottom:8px}
  .loc-spec-card h3{color:#1a1f3d;font-size:1rem;margin-bottom:6px}
  .loc-spec-card p{color:#555;font-size:.9rem;margin:0;line-height:1.5}
  .loc-testimonial{max-width:700px;margin:0 auto;text-align:center}
  .loc-testimonial blockquote{border:none;margin:0;padding:0}
  .loc-testimonial p{font-size:1.15rem;font-style:italic;color:#1a1f3d;line-height:1.8}
  .loc-testimonial cite{display:block;margin-top:16px;font-size:.95rem;color:#666;font-style:normal}
  .loc-faq{max-width:800px;margin-top:24px}
  .loc-faq details{border:1px solid #e8e6e1;border-radius:10px;margin-bottom:12px;overflow:hidden}
  .loc-faq summary{padding:18px 24px;cursor:pointer;font-weight:600;color:#1a1f3d;background:#fff;font-size:1rem;list-style:none}
  .loc-faq summary::-webkit-details-marker{display:none}
  .loc-faq summary::before{content:'+ ';color:#c9a84c;font-weight:700}
  .loc-faq details[open] summary::before{content:'- '}
  .loc-faq details p{padding:0 24px 18px;margin:0;color:#444;line-height:1.7;font-size:.95rem}
  .loc-cta{background:#1a1f3d;color:#fff;padding:60px 0;text-align:center}
  .loc-cta h2{color:#fff;margin-bottom:12px;font-size:clamp(1.4rem,3vw,2rem)}
  .loc-cta p{color:rgba(255,255,255,.85);max-width:600px;margin:0 auto 28px}
  .loc-cta-buttons{display:flex;flex-wrap:wrap;gap:14px;justify-content:center}
  .loc-btn{display:inline-block;padding:14px 28px;border-radius:8px;font-weight:600;text-decoration:none;font-size:1rem;transition:opacity .2s}
  .loc-btn:hover{opacity:.9}
  .loc-btn--primary{background:#c9a84c;color:#1a1f3d}
  .loc-btn--whatsapp{background:#25d366;color:#fff}
  .loc-btn--outline{border:2px solid #fff;color:#fff;background:transparent}
  @media(max-width:600px){.loc-hero{padding:60px 0 40px}.loc-section{padding:40px 0}.loc-cta{padding:40px 0}.loc-cta-buttons{flex-direction:column;align-items:center}}
</style>
