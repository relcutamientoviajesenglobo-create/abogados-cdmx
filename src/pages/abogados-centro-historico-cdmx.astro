---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = 'Abogados en el Centro Histórico, CDMX — Despacho Jurídico Cerca del Centro | Abogados en CDMX';
const description = 'Abogados cerca del Centro Histórico de la Ciudad de México. Despacho jurídico a 10 minutos del Zócalo especializado en derecho penal, civil, familiar, corporativo, inmobiliario, migratorio y laboral.';
const canonical = 'https://abogadosencdmx.com/abogados-centro-historico-cdmx';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LegalService",
      "name": "Abogados Cerca del Centro Histórico, CDMX",
      "description": "Despacho jurídico que atiende a clientes y comerciantes del Centro Histórico de la Ciudad de México. Oficina en Roma Norte a 10 minutos del Zócalo capitalino.",
      "url": "https://abogadosencdmx.com/abogados-centro-historico-cdmx",
      "telephone": "+525564655501",
      "email": "contacto@abogadosencdmx.com",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Guanajuato 224",
        "addressLocality": "Ciudad de México",
        "addressRegion": "CDMX",
        "postalCode": "06700",
        "addressCountry": "MX",
        "name": "Colonia Roma Norte, Alcaldía Cuauhtémoc"
      },
      "geo": { "@type": "GeoCoordinates", "latitude": 19.4326, "longitude": -99.1332 },
      "areaServed": {
        "@type": "Place",
        "name": "Centro Histórico, Alcaldía Cuauhtémoc, Ciudad de México",
        "geo": { "@type": "GeoCoordinates", "latitude": 19.4326, "longitude": -99.1332 }
      },
      "openingHoursSpecification": { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"], "opens": "09:00", "closes": "18:00" },
      "priceRange": "$$"
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://abogadosencdmx.com/" },
        { "@type": "ListItem", "position": 2, "name": "Abogados en Centro Histórico", "item": "https://abogadosencdmx.com/abogados-centro-historico-cdmx" }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "¿Hay abogados cerca del Centro Histórico de CDMX?",
          "acceptedAnswer": { "@type": "Answer", "text": "Sí. Nuestro despacho en Roma Norte está a solo 10 minutos del Centro Histórico por Metro (Línea 1). Atendemos a comerciantes, residentes y trabajadores del primer cuadro de la ciudad en todas las áreas del derecho." }
        },
        {
          "@type": "Question",
          "name": "¿Qué tipo de asuntos legales atienden del Centro Histórico?",
          "acceptedAnswer": { "@type": "Answer", "text": "Los casos más frecuentes del Centro Histórico incluyen derecho penal (robos, fraudes, delitos en vía pública), derecho laboral para comerciantes, arrendamiento de locales comerciales, contratos de compraventa, trámites ante el Registro Público y asuntos migratorios por la cercanía al INM." }
        },
        {
          "@type": "Question",
          "name": "¿Cómo llego desde el Centro Histórico al despacho?",
          "acceptedAnswer": { "@type": "Answer", "text": "Tome el Metro Línea 1 desde Zócalo o Bellas Artes hasta Insurgentes (4 estaciones). Desde ahí, camine 8 minutos al sur hasta Guanajuato 224. También puede tomar el Metrobús Línea 4 sobre Eje Central hasta la estación Sonora." }
        },
        {
          "@type": "Question",
          "name": "¿Atienden casos penales ocurridos en el Centro Histórico?",
          "acceptedAnswer": { "@type": "Answer", "text": "Sí. Nuestro equipo de abogados penalistas tiene amplia experiencia en delitos ocurridos en el Centro Histórico: robos, fraudes, lesiones, amenazas y delitos patrimoniales. Asistimos desde la denuncia ante el Ministerio Público hasta el juicio oral." }
        }
      ]
    }
  ]
};

const especialidades = [
  { nombre: 'Derecho Familiar', href: '/especialidades/derecho-familiar-cdmx', icono: '&#9825;', desc: 'Divorcios, custodia, pensión alimenticia y adopciones.' },
  { nombre: 'Derecho Penal', href: '/especialidades/derecho-penal-cdmx', icono: '&#9878;', desc: 'Defensa penal, amparos y delitos patrimoniales.' },
  { nombre: 'Derecho Civil', href: '/especialidades/derecho-civil-cdmx', icono: '&#9998;', desc: 'Contratos, responsabilidad civil y sucesiones.' },
  { nombre: 'Derecho Corporativo', href: '/especialidades/derecho-corporativo-cdmx', icono: '&#9881;', desc: 'Constitución de empresas, compliance y gobierno corporativo.' },
  { nombre: 'Derecho Inmobiliario', href: '/especialidades/derecho-inmobiliario-cdmx', icono: '&#8962;', desc: 'Compraventa, escrituración y arrendamiento.' },
  { nombre: 'Derecho Migratorio', href: '/especialidades/derecho-migratorio-cdmx', icono: '&#9992;', desc: 'Visas, residencia temporal y permanente, naturalización.' },
  { nombre: 'Derecho Laboral', href: '/especialidades/derecho-laboral-cdmx', icono: '&#9874;', desc: 'Despidos injustificados, liquidaciones y demandas laborales.' },
];
---

<Base title={title} description={description} canonical={canonical} schema={schema}>
  <Header slot="header" />

  <section class="loc-hero">
    <div class="loc-container">
      <nav class="loc-breadcrumb" aria-label="Breadcrumb">
        <a href="/">Inicio</a> &rsaquo; <span>Abogados en Centro Hist&oacute;rico</span>
      </nav>
      <span class="loc-badge">Despacho jur&iacute;dico a 10 minutos del Centro Hist&oacute;rico</span>
      <h1>Abogados en el Centro Hist&oacute;rico, Ciudad de M&eacute;xico</h1>
      <p class="loc-hero-desc">Atendemos a comerciantes, residentes y trabajadores del Centro Hist&oacute;rico de la CDMX desde nuestro despacho en Roma Norte. A solo 4 estaciones de Metro del Z&oacute;calo. Especialistas en derecho penal, civil, laboral y las 7 &aacute;reas de pr&aacute;ctica jur&iacute;dica.</p>
    </div>
  </section>

  <section class="loc-section">
    <div class="loc-container">
      <h2>Servicios legales para el Centro Hist&oacute;rico de CDMX</h2>
      <p>El Centro Hist&oacute;rico de la Ciudad de M&eacute;xico es el coraz&oacute;n pol&iacute;tico, comercial e hist&oacute;rico del pa&iacute;s. Con miles de comercios, oficinas gubernamentales, inmuebles patrimoniales y una intensa actividad econ&oacute;mica, genera necesidades jur&iacute;dicas constantes. Nuestro despacho atiende a comerciantes del Centro en asuntos de arrendamiento de locales, contratos mercantiles, defensa penal por delitos ocurridos en la zona, conflictos laborales y regularizaci&oacute;n de inmuebles catalogados.</p>
      <p>La cercan&iacute;a de nuestra oficina a los juzgados civiles, penales y familiares de la Alcald&iacute;a Cuauht&eacute;moc, al Tribunal Superior de Justicia, al Registro P&uacute;blico de la Propiedad y al Instituto Nacional de Migraci&oacute;n facilita la gesti&oacute;n eficiente de los asuntos de nuestros clientes del primer cuadro de la ciudad. Estamos en la misma alcald&iacute;a, lo que agiliza tr&aacute;mites administrativos y judiciales.</p>
    </div>
  </section>

  <section class="loc-section loc-section--alt">
    <div class="loc-container">
      <h2>C&oacute;mo llegar desde el Centro Hist&oacute;rico a nuestro despacho</h2>
      <p>Nuestra oficina est&aacute; en <strong>Guanajuato 224, Colonia Roma Norte</strong>, a solo 10 minutos del Z&oacute;calo por Metro L&iacute;nea 1.</p>
      <div class="loc-directions">
        <div class="loc-dir-card">
          <h3>En Metro</h3>
          <p>Desde <strong>Z&oacute;calo</strong> o <strong>Bellas Artes (L&iacute;nea 1)</strong>, viaje hasta la estaci&oacute;n <strong>Insurgentes</strong> (4 estaciones, 8 minutos). Desde ah&iacute;, camine 8 minutos al sur por Insurgentes hasta la calle Guanajuato.</p>
        </div>
        <div class="loc-dir-card">
          <h3>En Metrob&uacute;s</h3>
          <p>Tome el <strong>Metrob&uacute;s L&iacute;nea 4</strong> sobre <strong>Eje Central</strong> o camine hasta <strong>Insurgentes</strong> para tomar la <strong>L&iacute;nea 1</strong> hasta la estaci&oacute;n <strong>Sonora</strong>, a 3 cuadras de nuestra oficina.</p>
        </div>
        <div class="loc-dir-card">
          <h3>En auto</h3>
          <p>Tome <strong>Eje Central L&aacute;zaro C&aacute;rdenas</strong> hacia el sur hasta <strong>Avenida Chapultepec</strong>, gire al poniente y luego al sur por <strong>Insurgentes</strong> hasta Guanajuato. Trayecto de 15 a 25 minutos.</p>
        </div>
      </div>
      <p class="loc-landmarks"><strong>Referencias:</strong> A 10 minutos del Z&oacute;calo capitalino, a 8 minutos del Palacio de Bellas Artes, a 12 minutos de la Alameda Central y a 15 minutos del Tribunal Superior de Justicia.</p>
    </div>
  </section>

  <section class="loc-section">
    <div class="loc-container">
      <h2>&Aacute;reas del derecho para clientes del Centro Hist&oacute;rico</h2>
      <div class="loc-specs-grid">
        {especialidades.map(e => (
          <a href={e.href} class="loc-spec-card">
            <span class="loc-spec-icon" set:html={e.icono} />
            <h3>{e.nombre}</h3>
            <p>{e.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="loc-section loc-section--alt">
    <div class="loc-container">
      <div class="loc-testimonial">
        <blockquote>
          <p>&ldquo;Tengo un local comercial sobre la calle de Madero y tuve un conflicto serio con el arrendador que quer&iacute;a desalojarme sin justificaci&oacute;n. Los abogados del despacho actuaron r&aacute;pido, presentaron un amparo y lograron que permaneciera en mi local. El Metro me dejaba a unas estaciones de su oficina, todo muy accesible.&rdquo;</p>
          <cite>&mdash; Jos&eacute; Luis Mart&iacute;nez, comerciante, Centro Hist&oacute;rico</cite>
        </blockquote>
      </div>
    </div>
  </section>

  <section class="loc-section">
    <div class="loc-container">
      <h2>Preguntas frecuentes — Abogados cerca del Centro Hist&oacute;rico</h2>
      <div class="loc-faq">
        <details>
          <summary>&iquest;Hay abogados cerca del Centro Hist&oacute;rico de CDMX?</summary>
          <p>S&iacute;. Nuestro despacho en Roma Norte est&aacute; a solo 10 minutos del Centro Hist&oacute;rico por Metro (L&iacute;nea 1, estaci&oacute;n Insurgentes). Atendemos a comerciantes, residentes y trabajadores del primer cuadro de la ciudad.</p>
        </details>
        <details>
          <summary>&iquest;Qu&eacute; tipo de asuntos legales atienden del Centro Hist&oacute;rico?</summary>
          <p>Los casos m&aacute;s frecuentes incluyen derecho penal (robos, fraudes, delitos en v&iacute;a p&uacute;blica), arrendamiento de locales comerciales, conflictos laborales, contratos de compraventa y tr&aacute;mites ante el Registro P&uacute;blico.</p>
        </details>
        <details>
          <summary>&iquest;C&oacute;mo llego desde el Z&oacute;calo al despacho?</summary>
          <p>Tome el Metro L&iacute;nea 1 desde Z&oacute;calo hasta Insurgentes (4 estaciones, 8 minutos). Camine 8 minutos al sur hasta Guanajuato 224. El trayecto total es de unos 20 minutos.</p>
        </details>
        <details>
          <summary>&iquest;Atienden casos penales ocurridos en el Centro?</summary>
          <p>S&iacute;. Nuestro equipo penal tiene experiencia en delitos ocurridos en el Centro Hist&oacute;rico. Asistimos desde la denuncia ante el Ministerio P&uacute;blico hasta el juicio oral en tribunales.</p>
        </details>
      </div>
    </div>
  </section>

  <section class="loc-cta">
    <div class="loc-container">
      <h2>Agende su consulta gratuita desde el Centro Hist&oacute;rico</h2>
      <p>A solo 4 estaciones de Metro del Z&oacute;calo. Ll&aacute;menos, escr&iacute;banos o agende en l&iacute;nea.</p>
      <div class="loc-cta-buttons">
        <a href="tel:+525564655501" class="loc-btn loc-btn--primary">Llamar: 55 6465 5501</a>
        <a href="https://wa.me/525564655501?text=Hola%2C%20soy%20del%20Centro%20Hist%C3%B3rico%20y%20quiero%20agendar%20una%20consulta%20legal" class="loc-btn loc-btn--whatsapp">WhatsApp</a>
        <a href="/asesoria-inicial" class="loc-btn loc-btn--outline">Asesor&iacute;a inicial gratuita</a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Base>

<style>
  .loc-hero{background:#1a1f3d;color:#fff;padding:80px 0 60px;text-align:center}
  .loc-hero h1{font-size:clamp(1.8rem,4vw,2.8rem);margin:16px 0;line-height:1.2}
  .loc-hero-desc{max-width:700px;margin:0 auto;font-size:1.1rem;opacity:.9;line-height:1.7}
  .loc-container{max-width:1100px;margin:0 auto;padding:0 20px}
  .loc-breadcrumb{font-size:.9rem;margin-bottom:16px;opacity:.7}
  .loc-breadcrumb a{color:#c9a84c;text-decoration:none}
  .loc-badge{display:inline-block;background:#c9a84c;color:#1a1f3d;padding:6px 18px;border-radius:50px;font-size:.85rem;font-weight:600;margin-bottom:10px}
  .loc-section{padding:60px 0}
  .loc-section--alt{background:#f8f7f4}
  .loc-section h2{font-size:clamp(1.4rem,3vw,2rem);color:#1a1f3d;margin-bottom:20px}
  .loc-section p{line-height:1.8;color:#333;max-width:800px;margin-bottom:16px}
  .loc-directions{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:24px;margin-top:30px}
  .loc-dir-card{background:#fff;border:1px solid #e8e6e1;border-radius:12px;padding:28px;box-shadow:0 2px 8px rgba(0,0,0,.04)}
  .loc-dir-card h3{color:#1a1f3d;margin-bottom:10px;font-size:1.1rem}
  .loc-dir-card p{font-size:.95rem;margin:0}
  .loc-landmarks{margin-top:24px;padding:16px 20px;background:#fff;border-left:4px solid #c9a84c;border-radius:0 8px 8px 0;font-size:.95rem}
  .loc-specs-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(250px,1fr));gap:20px;margin-top:30px}
  .loc-spec-card{display:block;background:#fff;border:1px solid #e8e6e1;border-radius:12px;padding:24px;text-decoration:none;transition:box-shadow .2s,border-color .2s}
  .loc-spec-card:hover{box-shadow:0 4px 16px rgba(0,0,0,.08);border-color:#c9a84c}
  .loc-spec-icon{font-size:1.6rem;display:block;margin-bottom:8px}
  .loc-spec-card h3{color:#1a1f3d;font-size:1rem;margin-bottom:6px}
  .loc-spec-card p{color:#555;font-size:.9rem;margin:0;line-height:1.5}
  .loc-testimonial{max-width:700px;margin:0 auto;text-align:center}
  .loc-testimonial blockquote{border:none;margin:0;padding:0}
  .loc-testimonial p{font-size:1.15rem;font-style:italic;color:#1a1f3d;line-height:1.8}
  .loc-testimonial cite{display:block;margin-top:16px;font-size:.95rem;color:#666;font-style:normal}
  .loc-faq{max-width:800px;margin-top:24px}
  .loc-faq details{border:1px solid #e8e6e1;border-radius:10px;margin-bottom:12px;overflow:hidden}
  .loc-faq summary{padding:18px 24px;cursor:pointer;font-weight:600;color:#1a1f3d;background:#fff;font-size:1rem;list-style:none}
  .loc-faq summary::-webkit-details-marker{display:none}
  .loc-faq summary::before{content:'+ ';color:#c9a84c;font-weight:700}
  .loc-faq details[open] summary::before{content:'- '}
  .loc-faq details p{padding:0 24px 18px;margin:0;color:#444;line-height:1.7;font-size:.95rem}
  .loc-cta{background:#1a1f3d;color:#fff;padding:60px 0;text-align:center}
  .loc-cta h2{color:#fff;margin-bottom:12px;font-size:clamp(1.4rem,3vw,2rem)}
  .loc-cta p{color:rgba(255,255,255,.85);max-width:600px;margin:0 auto 28px}
  .loc-cta-buttons{display:flex;flex-wrap:wrap;gap:14px;justify-content:center}
  .loc-btn{display:inline-block;padding:14px 28px;border-radius:8px;font-weight:600;text-decoration:none;font-size:1rem;transition:opacity .2s}
  .loc-btn:hover{opacity:.9}
  .loc-btn--primary{background:#c9a84c;color:#1a1f3d}
  .loc-btn--whatsapp{background:#25d366;color:#fff}
  .loc-btn--outline{border:2px solid #fff;color:#fff;background:transparent}
  @media(max-width:600px){.loc-hero{padding:60px 0 40px}.loc-section{padding:40px 0}.loc-cta{padding:40px 0}.loc-cta-buttons{flex-direction:column;align-items:center}}
</style>
