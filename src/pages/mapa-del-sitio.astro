  { titulo: 'Derecho Migratorio en CDMX', url: '/especialidades/derecho-migratorio-cdmx' },
];

const equipoLegal = [
  { titulo: 'Lic. Tania Mendoza — Derecho Inmobiliario', url: '/despacho-juridico/tania-mendoza' },
  { titulo: 'Lic. Luciana Valle — Derecho Laboral', url: '/despacho-juridico/luciana-valle' },
  { titulo: 'Lic. Ian Montiel — Derecho Corporativo', url: '/despacho-juridico/ian-montiel' },
  { titulo: 'Lic. Andrea Solís — Derecho Familiar', url: '/despacho-juridico/andrea-solis' },
  { titulo: 'Lic. Roberto Fuentes — Derecho Penal', url: '/despacho-juridico/roberto-fuentes' },
  { titulo: 'Lic. Mariana Ortega — Derecho Civil', url: '/despacho-juridico/mariana-ortega' },
  { titulo: 'Lic. Diego Navarro — Derecho Migratorio', url: '/despacho-juridico/diego-navarro' },
];

const herramientas = [
  { titulo: 'Calculadora de Pensión Alimenticia', url: '/calcular-pension-alimenticia' },
];

const legal = [
  { titulo: 'Aviso de Privacidad', url: '/aviso-de-privacidad' },
  { titulo: 'Mapa del Sitio', url: '/mapa-del-sitio' },
];

const blogPorEspecialidad: Record<string, { titulo: string; url: string }[]> = {
  'Derecho Familiar': [
    { titulo: '¿Cuánto cuesta un divorcio en CDMX? Guía completa 2026', url: '/blog/cuanto-cuesta-divorcio-cdmx' },
    { titulo: 'Guarda y custodia en CDMX — Todo lo que necesitas saber en 2026', url: '/blog/custodia-hijos-cdmx' },
    { titulo: 'Divorcio express en CDMX — Requisitos, costo y tiempo en 2026', url: '/blog/divorcio-express-cdmx' },
    { titulo: 'Pensión alimenticia en México: cómo se calcula y cuánto corresponde en 2026', url: '/blog/pension-alimenticia-cdmx' },
    { titulo: 'Nuevo Código Nacional de Procedimientos Civiles y Familiares 2026', url: '/blog/nuevo-codigo-procedimientos-civiles-familiares-2026' },
    { titulo: 'Guía completa para tramitar un divorcio en CDMX en 2026', url: '/blog/guia-divorcio-cdmx-2026' },
    { titulo: 'Patria potestad en CDMX: diferencias con custodia y cómo se pierde', url: '/blog/patria-potestad-cdmx' },
    { titulo: 'Derechos del concubinato en CDMX: pensión, herencia y custodia', url: '/blog/concubinato-derechos-cdmx' },
