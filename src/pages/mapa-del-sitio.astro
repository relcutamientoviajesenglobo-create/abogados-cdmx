    { titulo: 'Mediación y justicia restaurativa en CDMX: alternativas al juicio penal', url: '/blog/mediacion-penal-cdmx' },
  ],
  'Derecho Civil': [
    { titulo: 'Contratos civiles en CDMX: tipos, requisitos y validez legal', url: '/blog/contratos-civiles-cdmx' },
    { titulo: 'Responsabilidad civil en CDMX: daños, perjuicios e indemnización', url: '/blog/responsabilidad-civil-cdmx' },
    { titulo: 'Usucapión en CDMX: cómo obtener la propiedad por prescripción adquisitiva', url: '/blog/usucapion-cdmx' },
    { titulo: 'Sucesiones y herencias en CDMX 2026: guía completa del juicio sucesorio', url: '/blog/sucesiones-herencias-cdmx-2026' },
    { titulo: 'Cómo hacer un testamento en CDMX: tipos, costos y requisitos 2026', url: '/blog/testamento-cdmx' },
    { titulo: 'Juicio ejecutivo mercantil en CDMX: cobro de pagarés y deudas', url: '/blog/juicio-ejecutivo-mercantil-cdmx' },
    { titulo: 'Cómo presentar una demanda civil en CDMX: paso a paso 2026', url: '/blog/demanda-civil-cdmx' },
    { titulo: 'Embargo de bienes en CDMX: proceso, tipos y cómo defenderse', url: '/blog/embargo-bienes-cdmx' },
    { titulo: 'Mediación y conciliación civil en CDMX: alternativa al juicio', url: '/blog/mediacion-civil-cdmx' },
    { titulo: 'Prescripción civil en CDMX: plazos para demandar y reclamar derechos', url: '/blog/prescripcion-civil-cdmx' },
  ],
  'Derecho Corporativo': [
    { titulo: 'Cómo constituir una empresa en México 2026: tipos de sociedad, costos y trámites', url: '/blog/constituir-empresa-mexico-2026' },
    { titulo: 'Compliance empresarial en México: obligaciones legales 2026', url: '/blog/compliance-empresarial-mexico' },
    { titulo: 'S.A. de C.V. vs S. de R.L. de C.V.: cuál conviene para tu negocio', url: '/blog/sa-de-cv-vs-srl-cdmx' },
    { titulo: 'Contratos mercantiles en México: tipos y cláusulas esenciales', url: '/blog/contratos-mercantiles-cdmx' },
    { titulo: 'Fusiones y adquisiciones de empresas en México: guía legal 2026', url: '/blog/fusiones-adquisiciones-mexico' },
    { titulo: 'Gobierno corporativo en México: obligaciones y mejores prácticas', url: '/blog/gobierno-corporativo-mexico' },
    { titulo: 'Protección de marca y propiedad intelectual para empresas en CDMX', url: '/blog/propiedad-intelectual-empresas-cdmx' },
    { titulo: 'Disolución y liquidación de empresas en México: proceso legal completo', url: '/blog/disolucion-liquidacion-empresa-mexico' },
    { titulo: 'Franquicias en México: marco legal, contratos y obligaciones 2026', url: '/blog/franquicias-mexico' },
    { titulo: 'Protección de datos personales para empresas en México: LFPDPPP', url: '/blog/proteccion-datos-personales-empresas' },
  ],
  'Derecho Inmobiliario': [
    { titulo: 'Compraventa de inmuebles en CDMX: guía legal completa 2026', url: '/blog/compraventa-inmueble-cdmx' },
    { titulo: 'Escrituración en CDMX: proceso, costos y requisitos notariales 2026', url: '/blog/escrituracion-cdmx' },
    { titulo: 'Contrato de arrendamiento en CDMX: cláusulas esenciales 2026', url: '/blog/contrato-arrendamiento-cdmx' },
    { titulo: 'Derechos del inquilino en CDMX: lo que todo arrendatario debe conocer', url: '/blog/derechos-inquilino-cdmx-2026' },
    { titulo: 'Conflictos de arrendamiento en CDMX: desalojos y rentas impagadas', url: '/blog/arrendamiento-conflictos-cdmx' },
    { titulo: 'Regularización de propiedad en CDMX: cómo obtener escrituras sin título', url: '/blog/regularizacion-propiedad-cdmx' },
    { titulo: 'Due diligence inmobiliario en CDMX: qué revisar antes de comprar', url: '/blog/due-diligence-inmobiliario-cdmx' },
    { titulo: 'Derechos y obligaciones de condóminos en CDMX: guía legal 2026', url: '/blog/condominos-administracion-cdmx' },
    { titulo: 'Fideicomiso inmobiliario en México: guía para compradores y extranjeros', url: '/blog/fideicomiso-inmobiliario-cdmx' },
    { titulo: 'Avalúo inmobiliario en CDMX: tipos, costos y cuándo es obligatorio', url: '/blog/avaluo-inmobiliario-cdmx' },
  ],
  'Derecho Laboral': [
    { titulo: 'Despido injustificado en CDMX — Tus derechos y cómo demandar en 2026', url: '/blog/despido-injustificado-cdmx' },
    { titulo: 'Despido injustificado en CDMX 2026: qué le corresponde y cómo demandar', url: '/blog/despido-injustificado-cdmx-2026' },
    { titulo: 'Acoso laboral (mobbing) en CDMX: cómo denunciar y qué pruebas necesitas', url: '/blog/acoso-laboral-cdmx' },
    { titulo: 'Contrato de trabajo en México: tipos, derechos y obligaciones', url: '/blog/contrato-trabajo-mexico' },
    { titulo: 'Liquidación laboral en CDMX: cómo calcular lo que te corresponde', url: '/blog/liquidacion-laboral-cdmx' },
    { titulo: 'Subcontratación y outsourcing en México: nueva ley y obligaciones 2026', url: '/blog/outsourcing-subcontratacion-mexico' },
    { titulo: 'Cómo presentar una demanda laboral en CDMX: proceso ante el Tribunal Laboral 2026', url: '/blog/demanda-laboral-cdmx' },
    { titulo: 'Accidente de trabajo en CDMX: derechos, incapacidad e indemnización IMSS', url: '/blog/accidente-trabajo-cdmx' },
    { titulo: 'Horas extras y jornada laboral en México: derechos y límites legales', url: '/blog/horas-extras-jornada-laboral-mexico' },
    { titulo: 'Sindicatos y negociación colectiva en México: reforma laboral 2026', url: '/blog/sindicatos-negociacion-colectiva-mexico' },
