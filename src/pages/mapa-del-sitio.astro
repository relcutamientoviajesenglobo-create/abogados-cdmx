    { titulo: 'Naturalización mexicana: requisitos, examen y costos 2026', url: '/blog/naturalizacion-mexico' },
    { titulo: 'Visa de trabajo en México: tipos, requisitos y proceso 2026', url: '/blog/visa-trabajo-mexico' },
    { titulo: 'Visa de inversionista en México: requisitos, montos y proceso 2026', url: '/blog/visa-inversionista-mexico' },
    { titulo: 'Reunificación familiar en México: visa por matrimonio y vínculo familiar', url: '/blog/reunificacion-familiar-mexico' },
    { titulo: 'Regularización migratoria en México: opciones para migrantes en situación irregular', url: '/blog/regularizacion-migratoria-mexico' },
    { titulo: 'Asilo y refugio en México: derechos, proceso ante COMAR y protección 2026', url: '/blog/asilo-refugio-mexico' },
    { titulo: 'Doble nacionalidad en México: derechos, obligaciones y trámites', url: '/blog/doble-nacionalidad-mexico' },
    { titulo: 'Permiso de trabajo para extranjeros en México: opciones legales 2026', url: '/blog/permiso-trabajo-extranjeros-mexico' },
  ],
};

/* Count total pages */
const totalBlog = Object.values(blogPorEspecialidad).reduce((acc, arr) => acc + arr.length, 0);
const totalPaginas = paginasPrincipales.length + especialidades.length + equipoLegal.length + herramientas.length + legal.length + totalBlog;

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://abogadosencdmx.com/" },
        { "@type": "ListItem", "position": 2, "name": "Mapa del Sitio", "item": "https://abogadosencdmx.com/mapa-del-sitio" }
      ]
    },
    {
      "@type": "SiteNavigationElement",
      "name": "Mapa del Sitio — Abogados en CDMX",
      "url": "https://abogadosencdmx.com/mapa-del-sitio"
    }
  ]
};
---

<Base title={title} description={description} canonical={canonical} schema={schema}>
  <Header slot="header" />

  <!-- Hero -->
  <section class="hero-pillar" style="background-color: var(--color-primary);">
    <div class="container">
      <Breadcrumb items={[{label: 'Mapa del Sitio'}]} />
      <div class="hero-pillar__content reveal">
        <p class="section-tag" style="color:var(--color-secondary);">Navegación</p>
        <h1 class="text-white">Mapa del Sitio</h1>
        <p class="text-white-soft" style="font-size:19px; line-height:1.7; max-width:746px;">{totalPaginas} páginas en este sitio. Encuentre rápidamente cualquier sección, artículo o perfil de nuestro despacho jurídico.</p>
      </div>
    </div>
  </section>

  <!-- Sitemap Content -->
  <section class="section-padding" style="background-color: var(--color-light);">
    <div class="container">
      <div class="sitemap-layout">

        <!-- Páginas principales -->
        <div class="sitemap-section reveal">
          <div class="sitemap-section__header">
            <span class="sitemap-section__icon" aria-hidden="true">&#127968;</span>
            <h2 class="sitemap-section__title">Páginas Principales</h2>
          </div>
          <ul class="sitemap-list">
            {paginasPrincipales.map(p => (
              <li><a href={p.url}>{p.titulo}</a></li>
            ))}
          </ul>
        </div>

        <!-- Especialidades -->
        <div class="sitemap-section reveal">
          <div class="sitemap-section__header">
            <span class="sitemap-section__icon" aria-hidden="true">&#9878;&#65039;</span>
            <h2 class="sitemap-section__title">Especialidades</h2>
          </div>
          <ul class="sitemap-list">
            {especialidades.map(e => (
              <li><a href={e.url}>{e.titulo}</a></li>
            ))}
          </ul>
        </div>

        <!-- Equipo Legal -->
        <div class="sitemap-section reveal">
          <div class="sitemap-section__header">
            <span class="sitemap-section__icon" aria-hidden="true">&#128104;&#8205;&#9878;&#65039;</span>
            <h2 class="sitemap-section__title">Equipo Legal</h2>
          </div>
          <ul class="sitemap-list">
            {equipoLegal.map(l => (
              <li><a href={l.url}>{l.titulo}</a></li>
            ))}
          </ul>
        </div>

        <!-- Herramientas -->
        <div class="sitemap-section reveal">
          <div class="sitemap-section__header">
            <span class="sitemap-section__icon" aria-hidden="true">&#129518;</span>
            <h2 class="sitemap-section__title">Herramientas</h2>
          </div>
          <ul class="sitemap-list">
            {herramientas.map(h => (
              <li><a href={h.url}>{h.titulo}</a></li>
            ))}
          </ul>
        </div>

        <!-- Legal -->
        <div class="sitemap-section reveal">
          <div class="sitemap-section__header">
            <span class="sitemap-section__icon" aria-hidden="true">&#128196;</span>
            <h2 class="sitemap-section__title">Legal</h2>
          </div>
          <ul class="sitemap-list">
            {legal.map(l => (
              <li><a href={l.url}>{l.titulo}</a></li>
            ))}
          </ul>
        </div>

        <!-- Blog por Especialidad -->
        <div class="sitemap-section sitemap-section--full reveal">
          <div class="sitemap-section__header">
            <span class="sitemap-section__icon" aria-hidden="true">&#128221;</span>
            <h2 class="sitemap-section__title">Blog Jurídico por Especialidad</h2>
            <span class="sitemap-section__count">{totalBlog} artículos</span>
          </div>

          <div class="sitemap-blog-grid">
            {Object.entries(blogPorEspecialidad).map(([categoria, posts]) => (
              <div class="sitemap-blog-category">
                <h3>{categoria} <span class="sitemap-blog-count">({posts.length})</span></h3>
                <ul class="sitemap-list sitemap-list--compact">
                  {posts.map(post => (
                    <li><a href={post.url}>{post.titulo}</a></li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </div>

      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Base>

<style>
  .sitemap-layout {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 32px;
  }

  .sitemap-section {
    background: #fff;
    border: 1px solid var(--color-border, #e5e5e5);
    padding: 28px 32px;
  }
  .sitemap-section--full {
    grid-column: 1 / -1;
  }

  .sitemap-section__header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 20px;
    padding-bottom: 14px;
    border-bottom: 2px solid var(--color-primary);
  }
  .sitemap-section__icon {
    font-size: 24px;
    line-height: 1;
  }
  .sitemap-section__title {
    font-family: 'Prata', serif;
    font-size: 20px;
    color: var(--color-primary);
    margin: 0;
    flex: 1;
  }
  .sitemap-section__count {
    font-size: 13px;
    color: #999;
    font-weight: 500;
  }

  .sitemap-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .sitemap-list li {
    padding: 6px 0;
    border-bottom: 1px solid #f0f0f0;
  }
  .sitemap-list li:last-child {
    border-bottom: none;
  }
  .sitemap-list a {
    color: #333;
    text-decoration: none;
    font-size: 15px;
    line-height: 1.5;
    transition: color 0.2s ease;
    display: inline-block;
  }
  .sitemap-list a:hover {
    color: var(--color-secondary);
  }

  .sitemap-list--compact li {
    padding: 4px 0;
  }
  .sitemap-list--compact a {
    font-size: 14px;
  }

  /* Blog grid */
  .sitemap-blog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }
  .sitemap-blog-category h3 {
    font-size: 16px;
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: 12px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--color-secondary);
  }
  .sitemap-blog-count {
    font-weight: 400;
    color: #999;
    font-size: 14px;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .sitemap-blog-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 768px) {
    .sitemap-layout {
      grid-template-columns: 1fr;
    }
    .sitemap-blog-grid {
      grid-template-columns: 1fr;
    }
    .sitemap-section {
      padding: 24px 20px;
    }
  }
</style>
