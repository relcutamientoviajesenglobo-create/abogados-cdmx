  { titulo: 'Derecho Civil en CDMX', url: '/especialidades/derecho-civil-cdmx' },
  { titulo: 'Derecho Corporativo en CDMX', url: '/especialidades/derecho-corporativo-cdmx' },
  { titulo: 'Derecho Inmobiliario en CDMX', url: '/especialidades/derecho-inmobiliario-cdmx' },
