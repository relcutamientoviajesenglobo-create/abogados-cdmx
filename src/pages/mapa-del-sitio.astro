    { titulo: 'Régimen matrimonial en CDMX: bienes separados vs sociedad conyugal', url: '/blog/matrimonio-bienes-separados-vs-sociedad-conyugal-cdmx' },
    { titulo: 'Guarda y custodia compartida en CDMX: requisitos y proceso 2026', url: '/blog/guarda-custodia-compartida-cdmx' },
  ],
  'Derecho Penal': [
    { titulo: 'Amparo penal en CDMX: cuándo procede y cómo tramitarlo', url: '/blog/amparo-penal-cdmx' },
    { titulo: 'Defensa penal en CDMX: cómo elegir abogado penalista', url: '/blog/defensa-penal-cdmx' },
    { titulo: 'Fraude, robo y abuso de confianza en CDMX: guía legal completa', url: '/blog/delitos-patrimoniales-cdmx' },
    { titulo: '¿Qué hacer si lo detienen en la Ciudad de México? Guía de derechos del detenido', url: '/blog/derechos-detenido-cdmx' },
    { titulo: 'Violencia familiar como delito en CDMX: denuncia y proceso penal', url: '/blog/violencia-familiar-cdmx-penal' },
    { titulo: 'Libertad bajo caución en CDMX: requisitos y costos 2026', url: '/blog/libertad-bajo-caucion-cdmx' },
    { titulo: 'El juicio oral penal en CDMX: etapas y derechos del acusado', url: '/blog/juicio-oral-penal-cdmx' },
