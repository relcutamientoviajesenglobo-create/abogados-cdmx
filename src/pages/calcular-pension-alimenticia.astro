---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = 'Calculadora de Pensión Alimenticia CDMX 2026 | Abogados en CDMX';
const description = 'Calcule el monto estimado de pensión alimenticia en la Ciudad de México. Porcentajes actualizados 2026 según criterios del Tribunal Superior de Justicia de CDMX.';
const canonical = 'https://abogadosencdmx.com/calcular-pension-alimenticia';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      "name": "Calculadora de Pensión Alimenticia CDMX",
      "url": canonical,
      "applicationCategory": "FinanceApplication",
      "operatingSystem": "Web",
      "description": description,
      "provider": { "@type": "LegalService", "name": "Abogados en CDMX", "url": "https://abogadosencdmx.com" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://abogadosencdmx.com/" },
        { "@type": "ListItem", "position": 2, "name": "Calculadora de Pensión Alimenticia", "item": canonical }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        { "@type": "Question", "name": "¿Cómo se calcula la pensión alimenticia en CDMX?", "acceptedAnswer": { "@type": "Answer", "text": "La pensión alimenticia en CDMX se calcula como un porcentaje del ingreso neto del obligado, considerando el número de hijos, gastos especiales y la capacidad económica. Los tribunales del TSJCDMX utilizan rangos del 15% al 40% según las circunstancias de cada caso." } },
        { "@type": "Question", "name": "¿Cuál es el porcentaje de pensión alimenticia por hijo en CDMX?", "acceptedAnswer": { "@type": "Answer", "text": "Los juzgados familiares de CDMX aplican aproximadamente: 15-20% para 1 hijo, 25-30% para 2 hijos, 30-35% para 3 hijos y 35-40% para 4 o más hijos." } }
      ]
    }
  ]
};
---

<Base title={title} description={description} canonical={canonical} schema={schema}>
  <Header slot="header" />

  <section class="calc-page">
    <!-- HERO -->
    <div class="calc-hero">
      <div class="container">
        <nav class="calc-crumb"><a href="/">Inicio</a><span>/</span><span>Calculadora</span></nav>
        <div class="calc-hero__badge">Actualizada marzo 2026 · Basada en criterios TSJCDMX</div>
        <h1>Calculadora de Pensión<br>Alimenticia <span>CDMX</span></h1>
        <p>Mueva los controles para obtener un estimado instantáneo basado en los porcentajes que aplican los juzgados familiares de la Ciudad de México.</p>
      </div>
    </div>

    <!-- CALCULATOR CARD -->
    <div class="container">
      <div class="calc-card">
        <!-- LEFT: Controls -->
        <div class="calc-controls">

          <!-- Ingreso Slider -->
          <div class="ctrl-group">
            <div class="ctrl-label">
              <span class="ctrl-icon">💰</span>
              <span class="ctrl-label__text">Ingreso mensual neto</span>
              <span class="ctrl-label__value" id="incomeDisplay">$25,000</span>
            </div>
            <div class="slider-wrap">
              <div class="slider-tooltip" id="sliderTooltip">$25,000</div>
              <input type="range" id="incomeSlider" class="slider" min="5000" max="150000" step="1000" value="25000">
            </div>
            <div class="slider-range">
              <span>$5,000</span><span>$150,000</span>
            </div>
          </div>

          <!-- Hijos Selector -->
          <div class="ctrl-group">
            <div class="ctrl-label">
              <span class="ctrl-icon">👶</span>
              <span class="ctrl-label__text">Número de hijos</span>
            </div>
            <div class="children-grid" id="childrenChips">
              <button class="child-card" data-val="1">
                <span class="child-card__emoji">👶</span>
                <span class="child-card__label">1 hijo</span>
                <span class="child-card__pct">15-20%</span>
              </button>
              <button class="child-card active" data-val="2">
                <span class="child-card__emoji">👶👶</span>
                <span class="child-card__label">2 hijos</span>
                <span class="child-card__pct">25-30%</span>
              </button>
              <button class="child-card" data-val="3">
                <span class="child-card__emoji">👶👶👶</span>
                <span class="child-card__label">3 hijos</span>
                <span class="child-card__pct">30-35%</span>
              </button>
              <button class="child-card" data-val="4">
                <span class="child-card__emoji">👨‍👩‍👧‍👦</span>
                <span class="child-card__label">4 o más</span>
                <span class="child-card__pct">35-40%</span>
              </button>
            </div>
          </div>

          <!-- Custodia Toggle -->
          <div class="ctrl-group">
            <div class="ctrl-label">
              <span class="ctrl-icon">⚖️</span>
              <span class="ctrl-label__text">Tipo de custodia</span>
            </div>
            <div class="custody-cards" id="custodyToggle">
              <button class="custody-card active" data-val="exclusive">
                <span class="custody-card__icon">👤</span>
                <div class="custody-card__text">
                  <strong>Exclusiva</strong>
                  <span>Un padre tiene la custodia</span>
                </div>
                <span class="custody-card__check">✓</span>
              </button>
              <button class="custody-card" data-val="shared">
                <span class="custody-card__icon">👥</span>
                <div class="custody-card__text">
                  <strong>Compartida</strong>
                  <span>Tiempo equitativo</span>
                </div>
                <span class="custody-card__check">✓</span>
              </button>
            </div>
          </div>

          <!-- Gastos Especiales -->
          <div class="ctrl-group">
            <div class="ctrl-label">
              <span class="ctrl-icon">📋</span>
              <span class="ctrl-label__text">Gastos especiales</span>
              <span class="ctrl-label__optional">Opcional</span>
            </div>
            <div class="extras-grid" id="extrasChips">
              <button class="extra-card" data-val="school" data-pct="3">
                <span class="extra-card__emoji">🎓</span>
                <span class="extra-card__label">Escuela privada</span>
                <span class="extra-card__pct">+3%</span>
              </button>
              <button class="extra-card" data-val="medical" data-pct="4">
                <span class="extra-card__emoji">🏥</span>
                <span class="extra-card__label">Gastos médicos</span>
                <span class="extra-card__pct">+4%</span>
              </button>
              <button class="extra-card" data-val="activities" data-pct="2">
                <span class="extra-card__emoji">⚽</span>
                <span class="extra-card__label">Extracurriculares</span>
                <span class="extra-card__pct">+2%</span>
              </button>
            </div>
          </div>
        </div>

        <!-- RIGHT: Live Results -->
        <div class="calc-result">
          <div class="result-top">
            <span class="result-tag">Pensión mensual estimada</span>
            <div class="result-amount-wrap">
              <div class="result-col">
                <span class="result-label">Mínimo</span>
                <span class="result-amount" id="resMin">$3,750</span>
              </div>
              <span class="result-arrow">→</span>
              <div class="result-col">
                <span class="result-label">Máximo</span>
                <span class="result-amount result-amount--max" id="resMax">$5,000</span>
              </div>
            </div>
          </div>

          <!-- Annual -->
          <div class="result-annual">
            <div class="result-annual__inner">
              <span class="result-annual__label">Estimado anual</span>
              <span class="result-annual__amount" id="resAnnual">$45,000 – $60,000</span>
            </div>
          </div>

          <!-- Percentage bar -->
          <div class="result-bar-section">
            <div class="result-bar-header">
              <span>Porcentaje del ingreso</span>
              <strong id="resPct">15% – 20%</strong>
            </div>
            <div class="result-bar">
              <div class="result-bar__track">
                <div class="result-bar__fill" id="barFill" style="width:35%"></div>
              </div>
              <div class="result-bar__labels">
                <span>0%</span><span>25%</span><span>50%</span>
              </div>
            </div>
          </div>

          <!-- Breakdown -->
          <div class="result-breakdown">
            <div class="result-row"><span>Ingreso neto</span><strong id="brkIncome">$25,000</strong></div>
            <div class="result-row"><span>Hijos</span><strong id="brkChildren">2</strong></div>
            <div class="result-row"><span>Custodia</span><strong id="brkCustody">Exclusiva</strong></div>
            <div class="result-row" id="brkExtrasRow" style="display:none"><span>Ajuste especial</span><strong id="brkExtras">+0%</strong></div>
          </div>

          <!-- CTA -->
          <a href="/asesoria-inicial" class="result-cta">
            <span>Consultar con abogado familiarista</span>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>

          <!-- Disclaimer -->
          <p class="result-disclaimer">Cálculo orientativo basado en arts. 301-323 CCCDMX y criterios del TSJCDMX. El monto definitivo lo determina el juez familiar.</p>
        </div>
      </div>
    </div>

    <!-- REFERENCE TABLE -->
    <div class="container">
      <div class="calc-ref">
        <h2>Tabla de porcentajes CDMX 2026</h2>
        <p>Rangos orientativos de los juzgados familiares de la Ciudad de México.</p>
        <div class="calc-ref__table-wrap">
          <table>
            <thead>
              <tr><th>Hijos</th><th>Custodia exclusiva</th><th>Custodia compartida</th><th>Con gastos especiales</th></tr>
            </thead>
            <tbody>
              <tr><td><strong>1 hijo</strong></td><td>15% – 20%</td><td>10% – 15%</td><td>20% – 25%</td></tr>
              <tr><td><strong>2 hijos</strong></td><td>25% – 30%</td><td>18% – 22%</td><td>30% – 35%</td></tr>
              <tr><td><strong>3 hijos</strong></td><td>30% – 35%</td><td>22% – 28%</td><td>35% – 40%</td></tr>
              <tr><td><strong>4+ hijos</strong></td><td>35% – 40%</td><td>28% – 33%</td><td>40% – 45%</td></tr>
            </tbody>
          </table>
        </div>
        <p class="calc-ref__note">Fuente: Criterios orientadores del TSJCDMX. Arts. 308-311 Código Civil CDMX.</p>
      </div>

      <!-- CTA Block -->
      <div class="calc-final-cta">
        <h2>¿Necesita fijar o modificar una pensión alimenticia?</h2>
        <p>Nuestros abogados familiaristas en CDMX pueden representarle. La consulta inicial es gratuita.</p>
        <div class="calc-final-cta__btns">
          <a href="/asesoria-inicial" class="btn-primary-wrap">Agendar consulta gratuita →</a>
          <a href="tel:+525564655501" class="btn-secondary-wrap">Llamar al 55 6465 5501</a>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Base>

<script>
  // === STATE ===
  let income = 25000;
  let children = 2;
  let custody: 'exclusive' | 'shared' = 'exclusive';
  let extras: Set<string> = new Set();

  // === PERCENTAGE TABLE ===
  const pct: Record<string, Record<number, [number, number]>> = {
    exclusive: { 1: [15,20], 2: [25,30], 3: [30,35], 4: [35,40] },
    shared:    { 1: [10,15], 2: [18,22], 3: [22,28], 4: [28,33] }
  };
  const extraPcts: Record<string, number> = { school: 3, medical: 4, activities: 2 };

  // === ELEMENTS ===
  const $ = (s: string) => document.querySelector(s)!;
  const incomeSlider = $('#incomeSlider') as HTMLInputElement;

  // === FORMAT ===
  const fmt = (n: number) => '$' + n.toLocaleString('es-MX');

  // === CALCULATE (runs on every change) ===
  function calculate() {
    const c = Math.min(children, 4);
    const [lo, hi] = pct[custody][c];
    let extraPct = 0;
    extras.forEach(e => { extraPct += (extraPcts[e] || 0); });
    const fLo = lo + extraPct;
    const fHi = hi + extraPct;
    const minAmt = Math.round(income * fLo / 100);
    const maxAmt = Math.round(income * fHi / 100);

    // Animate numbers
    animateValue('resMin', fmt(minAmt));
    animateValue('resMax', fmt(maxAmt));
    animateValue('resAnnual', `${fmt(minAmt * 12)} – ${fmt(maxAmt * 12)}`);
    $('#resPct')!.textContent = `${fLo}% – ${fHi}%`;
    $('#incomeDisplay')!.textContent = fmt(income);

    // Bar
    const avg = (fLo + fHi) / 2;
    (document.getElementById('barFill') as HTMLElement).style.width = `${Math.min(avg * 2, 100)}%`;

    // Breakdown
    $('#brkIncome')!.textContent = fmt(income);
    $('#brkChildren')!.textContent = c >= 4 ? '4 o más' : String(c);
    $('#brkCustody')!.textContent = custody === 'exclusive' ? 'Exclusiva' : 'Compartida';
    const extrasRow = document.getElementById('brkExtrasRow')!;
    if (extraPct > 0) {
      extrasRow.style.display = 'flex';
      $('#brkExtras')!.textContent = `+${extraPct}%`;
    } else {
      extrasRow.style.display = 'none';
    }

    // Update slider track fill
    updateSliderTrack();
  }

  function animateValue(id: string, newVal: string) {
    const el = document.getElementById(id)!;
    if (el.textContent === newVal) return;
    el.style.transform = 'translateY(-4px)';
    el.style.opacity = '0.4';
    requestAnimationFrame(() => {
      setTimeout(() => {
        el.textContent = newVal;
        el.style.transform = 'translateY(0)';
        el.style.opacity = '1';
      }, 80);
    });
  }

  function updateSliderTrack() {
    const s = incomeSlider;
    const pctVal = ((parseInt(s.value) - parseInt(s.min)) / (parseInt(s.max) - parseInt(s.min))) * 100;
    s.style.setProperty('--pct', `${pctVal}%`);
  }

  // === INCOME SLIDER + TOOLTIP ===
  const tooltip = document.getElementById('sliderTooltip')!;
  function updateTooltip() {
    const s = incomeSlider;
    const pctVal = ((parseInt(s.value) - parseInt(s.min)) / (parseInt(s.max) - parseInt(s.min)));
    tooltip.style.left = `calc(${pctVal * 100}% + ${(0.5 - pctVal) * 28}px)`;
    tooltip.textContent = fmt(income);
  }
  incomeSlider.addEventListener('input', () => {
    income = parseInt(incomeSlider.value);
    updateTooltip();
    calculate();
  });

  // === CHILDREN CARDS ===
  document.querySelectorAll('#childrenChips .child-card').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('#childrenChips .child-card').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      children = parseInt(btn.getAttribute('data-val') || '1');
      calculate();
    });
  });

  // === CUSTODY CARDS ===
  document.querySelectorAll('#custodyToggle .custody-card').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('#custodyToggle .custody-card').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      custody = btn.getAttribute('data-val') as 'exclusive' | 'shared';
      calculate();
    });
  });

  // === EXTRAS CARDS ===
  document.querySelectorAll('#extrasChips .extra-card').forEach(btn => {
    btn.addEventListener('click', () => {
      btn.classList.toggle('active');
      const val = btn.getAttribute('data-val')!;
      if (extras.has(val)) extras.delete(val); else extras.add(val);
      calculate();
    });
  });

  // === INIT ===
  updateTooltip();
  calculate();
</script>

<style>
  .calc-page { background: #f8f7f5; }

  /* ═══ HERO ═══ */
  .calc-hero {
    background: var(--color-primary); color: #fff;
    padding: 160px 0 80px;
  }
  .calc-crumb { display: flex; gap: 8px; font-size: 13px; color: rgba(255,255,255,0.4); margin-bottom: 24px; }
  .calc-crumb a { color: rgba(255,255,255,0.5); }
  .calc-crumb a:hover { color: var(--color-secondary); }
  .calc-hero__badge {
    display: inline-block; background: rgba(193,127,62,0.12); border: 1px solid rgba(193,127,62,0.25);
    color: var(--color-secondary); padding: 6px 16px; font-size: 11px; font-weight: 700;
    text-transform: uppercase; letter-spacing: 1px; margin-bottom: 20px;
  }
  .calc-hero h1 {
    font-size: clamp(30px, 5vw, 50px); font-weight: 800; line-height: 1.1; margin-bottom: 16px;
  }
  .calc-hero h1 span { color: var(--color-secondary); }
  .calc-hero p { font-size: 17px; color: rgba(255,255,255,0.55); max-width: 580px; line-height: 1.6; }

  /* ═══ CARD ═══ */
  .calc-card {
    display: grid; grid-template-columns: 1fr 400px; gap: 0;
    background: #fff; box-shadow: 0 20px 60px rgba(0,0,0,0.08);
    margin-top: -40px; position: relative; z-index: 2;
    border: 1px solid rgba(0,0,0,0.06);
  }

  /* ═══ CONTROLS ═══ */
  .calc-controls { padding: 40px; }
  .ctrl-group { margin-bottom: 36px; }
  .ctrl-group:last-child { margin-bottom: 0; }
  .ctrl-label {
    display: flex; align-items: center; gap: 10px; margin-bottom: 16px;
  }
  .ctrl-icon { font-size: 20px; }
  .ctrl-label__text { font-size: 13px; font-weight: 700; color: var(--color-primary); text-transform: uppercase; letter-spacing: 0.8px; flex: 1; }
  .ctrl-label__value {
    font-size: 24px; font-weight: 800; color: var(--color-primary); font-family: var(--font-heading);
    transition: all 0.25s cubic-bezier(0.4,0,0.2,1);
  }
  .ctrl-label__optional {
    font-size: 11px; font-weight: 600; color: var(--color-secondary);
    background: rgba(193,127,62,0.1); padding: 3px 10px;
    text-transform: uppercase; letter-spacing: 0.5px;
  }

  /* Slider */
  .slider-wrap { position: relative; padding: 16px 0 0; }
  .slider-tooltip {
    position: absolute; top: -6px;
    background: var(--color-primary); color: #fff;
    padding: 4px 12px; font-size: 12px; font-weight: 700;
    white-space: nowrap; pointer-events: none;
    transform: translateX(-50%); left: 50%;
    opacity: 0; transition: opacity 0.2s;
    font-family: var(--font-heading);
  }
  .slider-tooltip::after {
    content: ''; position: absolute; bottom: -5px; left: 50%; transform: translateX(-50%);
    border-left: 5px solid transparent; border-right: 5px solid transparent;
    border-top: 5px solid var(--color-primary);
  }
  .slider-wrap:hover .slider-tooltip,
  .slider-wrap:active .slider-tooltip { opacity: 1; }

  .slider {
    -webkit-appearance: none; appearance: none;
    width: 100%; height: 8px; border-radius: 4px;
    background: linear-gradient(to right, var(--color-secondary) var(--pct, 50%), #e8e8e8 var(--pct, 50%));
    outline: none; cursor: pointer;
  }
  .slider::-webkit-slider-thumb {
    -webkit-appearance: none; appearance: none;
    width: 28px; height: 28px; border-radius: 50%;
    background: #fff; border: 4px solid var(--color-secondary);
    cursor: grab; transition: transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 2px 10px rgba(193,127,62,0.25);
  }
  .slider::-webkit-slider-thumb:hover {
    transform: scale(1.15);
    box-shadow: 0 4px 16px rgba(193,127,62,0.4);
  }
  .slider::-webkit-slider-thumb:active {
    cursor: grabbing; transform: scale(1.25);
    box-shadow: 0 4px 20px rgba(193,127,62,0.5);
  }
  .slider::-moz-range-thumb {
    width: 28px; height: 28px; border-radius: 50%;
    background: #fff; border: 4px solid var(--color-secondary);
    cursor: grab;
  }
  .slider-range { display: flex; justify-content: space-between; font-size: 11px; color: #aaa; margin-top: 8px; }

  /* Children Cards */
  .children-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; }
  .child-card {
    display: flex; flex-direction: column; align-items: center; gap: 6px;
    padding: 18px 8px 14px; border: 2px solid #e8e8e8; background: #fff;
    cursor: pointer; transition: all 0.25s cubic-bezier(0.4,0,0.2,1);
    font-family: var(--font-body); position: relative; overflow: hidden;
  }
  .child-card::before {
    content: ''; position: absolute; inset: 0;
    background: radial-gradient(circle at center, rgba(193,127,62,0.08), transparent 70%);
    opacity: 0; transition: opacity 0.3s;
  }
  .child-card:hover { border-color: var(--color-secondary); transform: translateY(-2px); }
  .child-card:hover::before { opacity: 1; }
  .child-card:active { transform: scale(0.96); }
  .child-card.active {
    border-color: var(--color-secondary); background: rgba(193,127,62,0.04);
    box-shadow: 0 4px 20px rgba(193,127,62,0.15);
    transform: translateY(-2px);
  }
  .child-card.active .child-card__emoji { animation: bounceIn 0.4s cubic-bezier(0.175,0.885,0.32,1.275); }
  .child-card__emoji { font-size: 28px; transition: transform 0.2s; position: relative; z-index: 1; line-height: 1; }
  .child-card:hover .child-card__emoji { transform: scale(1.15); }
  .child-card__label { font-size: 13px; font-weight: 700; color: var(--color-primary); position: relative; z-index: 1; }
  .child-card__pct {
    font-size: 10px; font-weight: 600; color: var(--color-secondary);
    opacity: 0; transform: translateY(4px); transition: all 0.2s;
    position: relative; z-index: 1;
  }
  .child-card.active .child-card__pct,
  .child-card:hover .child-card__pct { opacity: 1; transform: translateY(0); }

  @keyframes bounceIn {
    0% { transform: scale(0.3); }
    50% { transform: scale(1.15); }
    70% { transform: scale(0.95); }
    100% { transform: scale(1); }
  }

  /* Custody Cards */
  .custody-cards { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
  .custody-card {
    display: flex; align-items: center; gap: 12px;
    padding: 16px 18px; border: 2px solid #e8e8e8; background: #fff;
    cursor: pointer; transition: all 0.25s cubic-bezier(0.4,0,0.2,1);
    font-family: var(--font-body); position: relative;
  }
  .custody-card:hover { border-color: var(--color-secondary); transform: translateY(-1px); }
  .custody-card:active { transform: scale(0.98); }
  .custody-card.active {
    border-color: var(--color-primary); background: var(--color-primary); color: #fff;
  }
  .custody-card__icon { font-size: 24px; flex-shrink: 0; }
  .custody-card__text { flex: 1; }
