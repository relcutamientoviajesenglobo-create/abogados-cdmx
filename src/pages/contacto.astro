---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import MarqueeStats from '../components/MarqueeStats.astro';
import Footer from '../components/Footer.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

const title = 'Contacto — Abogados en CDMX | Despacho Jurídico Roma Norte';
const description = 'Contacte a Abogados en CDMX. Guanajuato 224, Colonia Roma Norte, Cuauhtémoc, 06700 Ciudad de México. Teléfono: 55 6465 5501. Lunes a viernes de 9:00 a 18:00 hrs.';
const canonical = 'https://abogadosencdmx.com/contacto';

const schema = {
  "@context": "https://schema.org",
  "@type": "LegalService",
  "name": "Abogados en CDMX",
  "url": "https://abogadosencdmx.com",
  "telephone": "+525564655501",
  "email": "contacto@abogadosencdmx.com",
  "image": "https://images.unsplash.com/photo-1497366216548-37526070297c?w=800&h=600&fit=crop&fm=webp&q=75",
  "priceRange": "$$",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Guanajuato 224",
    "addressLocality": "Ciudad de México",
    "addressRegion": "CDMX",
    "postalCode": "06700",
    "addressCountry": "MX",
    "name": "Colonia Roma Norte, Alcaldía Cuauhtémoc"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 19.4194,
    "longitude": -99.1616
  },
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
    "opens": "09:00",
    "closes": "18:00"
  },
  "contactPoint": {
    "@type": "ContactPoint",
    "telephone": "+525564655501",
    "contactType": "customer service",
    "availableLanguage": ["Spanish"],
    "areaServed": { "@type": "City", "name": "Ciudad de México" }
  },
  "sameAs": [
    "https://facebook.com/abogadosencdmx",
    "https://instagram.com/abogadosencdmx",
    "https://linkedin.com/company/abogadosencdmx"
  ]
};
---

<Base title={title} description={description} canonical={canonical} schema={schema}>
  <Header slot="header" />

  <!-- HERO -->
  <section class="hero-pillar" style="background-color: var(--color-primary);">
    <div class="container">
      <Breadcrumb items={[{label:'Contacto'}]} />
      <div class="hero-pillar__content reveal">
        <p class="section-tag" style="color:var(--color-secondary);">Contacto</p>
        <h1 class="text-white">Comuníquese con nuestro despacho jurídico</h1>
        <p class="text-white-soft" style="font-size:19px; line-height:1.7; max-width:746px;">Abogados en CDMX atiende consultas en siete áreas del derecho de lunes a viernes de 9:00 a 18:00 horas. Nuestras oficinas se encuentran en Guanajuato 224, Colonia Roma Norte, una de las zonas con mejor conectividad de la Ciudad de México.</p>
      </div>
    </div>
  </section>
  <MarqueeStats />

  <!-- BRACKET 1: INTENT — NAP visible -->
  <section class="section-padding">
    <div class="container">
      <div class="contact-grid">
        <div class="contact-info reveal">
          <!-- NAP VISIBLE EN PROSA — esto es lo que leen los LLMs -->
          <div class="nap-block">
            <div class="nap-item">
              <h3>Dirección</h3>
              <p>Nuestras oficinas se ubican en <strong>Guanajuato 224, Colonia Roma Norte, Alcaldía Cuauhtémoc, C.P. 06700, Ciudad de México</strong>. La zona cuenta con acceso por Metro Insurgentes (Línea 1), Metrobús Durango (Línea 1) y estaciones de Ecobici cercanas. Hay estacionamiento disponible en las calles aledañas y estacionamientos públicos sobre Avenida Insurgentes.</p>
            </div>
            <div class="nap-item">
              <h3>Teléfono</h3>
              <p>Llame al <strong><a href="tel:+525564655501">55 6465 5501</a></strong> para agendar una cita o resolver dudas sobre nuestros servicios legales. Nuestro equipo de atención le indicará la disponibilidad más próxima con el abogado especialista en su área de interés.</p>
            </div>
            <div class="nap-item">
              <h3>Correo electrónico</h3>
              <p>Escriba a <strong><a href="mailto:contacto@abogadosencdmx.com">contacto@abogadosencdmx.com</a></strong> con los datos de su caso. Respondemos todos los correos en un máximo de 24 horas hábiles con una orientación inicial sobre su situación jurídica.</p>
            </div>
            <div class="nap-item">
              <h3>Redes sociales</h3>
              <p>Síganos en redes sociales para conocer noticias legales, actualizaciones del despacho y contenido jurídico de interés:</p>
              <div class="contact-social">
                <a href="https://facebook.com/abogadosencdmx" target="_blank" rel="noopener noreferrer" class="contact-social__link">
                  <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                  <span>Facebook</span>
                </a>
                <a href="https://instagram.com/abogadosencdmx" target="_blank" rel="noopener noreferrer" class="contact-social__link">
                  <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
                  <span>Instagram</span>
                </a>
                <a href="https://linkedin.com/company/abogadosencdmx" target="_blank" rel="noopener noreferrer" class="contact-social__link">
                  <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                  <span>LinkedIn</span>
                </a>
              </div>
            </div>
            <div class="nap-item">
              <h3>Horario de atención</h3>
              <p><strong>Lunes a viernes de 9:00 a 18:00 horas.</strong> Si su caso requiere atención urgente fuera de horario — como una detención o un procedimiento judicial inminente — comuníquese al 55 6465 5501 y nuestro equipo evaluará la posibilidad de atenderle de manera prioritaria.</p>
            </div>
          </div>
        </div>

        <div class="contact-form-wrap reveal">
          <div class="form-card">
            {Astro.url.searchParams.get('enviado') === 'true' ? (
              <div class="success-message">
                <div class="success-icon">&#10003;</div>
                <h3>Mensaje enviado correctamente</h3>
                <p>Gracias por contactarnos. Un abogado de nuestro equipo revisará su consulta y le responderá en las próximas 24 horas hábiles.</p>
                <a href="/contacto" class="btn-primary-wrap" style="width:100%;justify-content:center;">Enviar otra consulta →</a>
              </div>
            ) : (
              <Fragment>
                <h3>Envíe su consulta</h3>
                <p>Describa brevemente su situación y le responderemos en las próximas 24 horas hábiles.</p>
                <form class="form" action="https://formsubmit.co/contacto@abogadosencdmx.com" method="POST">
                  <input type="hidden" name="_subject" value="Nuevo contacto desde abogadosencdmx.com">
                  <input type="hidden" name="_captcha" value="true">
                  <input type="hidden" name="_next" value="https://abogadosencdmx.com/contacto?enviado=true">
                  <input type="text" name="_honey" style="display:none">
                  <div class="form-row">
                    <div class="form-group">
                      <label for="c-nombre">Nombre completo</label>
                      <input type="text" id="c-nombre" name="nombre" required placeholder="Su nombre completo">
                    </div>
                    <div class="form-group">
                      <label for="c-telefono">Teléfono</label>
                      <input type="tel" id="c-telefono" name="telefono" required placeholder="55 0000 0000">
                    </div>
                  </div>
                  <div class="form-group">
                    <label for="c-email">Correo electrónico</label>
                    <input type="email" id="c-email" name="email" required placeholder="correo@ejemplo.com">
                  </div>
                  <div class="form-group">
                    <label for="c-area">Especialidad</label>
                    <select id="c-area" name="especialidad" required>
                      <option value="">Seleccione una especialidad</option>
                      <option value="familiar">Derecho Familiar</option>
                      <option value="penal">Derecho Penal</option>
                      <option value="civil">Derecho Civil</option>
                      <option value="corporativo">Derecho Corporativo</option>
                      <option value="inmobiliario">Derecho Inmobiliario</option>
                      <option value="migratorio">Derecho Migratorio</option>
                      <option value="laboral">Derecho Laboral</option>
                      <option value="otro">Otro</option>
                    </select>
                  </div>
                  <div class="form-group">
                    <label for="c-mensaje">Mensaje</label>
                    <textarea id="c-mensaje" name="mensaje" rows="5" required placeholder="Cuéntenos los aspectos principales de su situación jurídica para orientarle mejor..."></textarea>
                  </div>
                  <button type="submit" class="btn-primary-wrap" style="width:100%;justify-content:center;">Enviar consulta →</button>
                </form>
              </Fragment>
            )}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- BRACKET: Intent — Especialidades + internal links -->
  <section class="section-padding">
    <div class="container">
      <div class="reveal" style="max-width:850px;">
        <p class="section-tag">Nuestras Especialidades</p>
        <h2>Atendemos siete áreas del derecho desde nuestra oficina en Roma Norte</h2>
        <p style="font-size:16px;line-height:1.8;margin-bottom:16px;">Al comunicarse con Abogados en CDMX, nuestro equipo le conectará con el abogado especialista que corresponda a su tipo de asunto. Atendemos consultas en <a href="/especialidades/derecho-familiar-cdmx">derecho familiar</a>, <a href="/especialidades/derecho-penal-cdmx">derecho penal</a>, <a href="/especialidades/derecho-civil-cdmx">derecho civil</a>, <a href="/especialidades/derecho-corporativo-cdmx">derecho corporativo</a>, <a href="/especialidades/derecho-inmobiliario-cdmx">derecho inmobiliario</a>, <a href="/especialidades/derecho-laboral-cdmx">derecho laboral</a> y <a href="/especialidades/derecho-migratorio-cdmx">derecho migratorio</a>.</p>
        <p style="font-size:16px;line-height:1.8;">Si no está seguro qué tipo de abogado necesita, puede agendar una <a href="/asesoria-inicial">asesoría inicial</a> donde evaluaremos su caso y le canalizaremos con el especialista correcto. Conozca a nuestro <a href="/equipo-legal-cdmx">equipo de abogados</a> o revise todas nuestras <a href="/especialidades">áreas de especialidad</a> para más información.</p>
      </div>
    </div>
  </section>

  <!-- BRACKET 2: OPERATIONAL — Mapa + Cómo llegar -->
  <section class="section-padding" style="background:var(--color-light);">
    <div class="container">
      <div class="reveal" style="text-align:center;max-width:700px;margin:0 auto 40px;">
        <p class="section-tag">Ubicación</p>
        <h2>Cómo llegar a nuestro despacho</h2>
        <p>Abogados en CDMX se encuentra en el corazón de la Colonia Roma Norte, sobre la calle Guanajuato entre Mérida y Medellín. La zona es una de las mejor conectadas de la Ciudad de México con múltiples opciones de transporte público.</p>
      </div>
      <div class="map-wrap reveal">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3763.0!2d-99.1616!3d19.4194!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMTnCsDI1JzA5LjgiTiA5OcKwMDknNDEuOCJX!5e0!3m2!1ses!2smx!4v1700000000000"
          width="100%"
          height="450"
          style="border:0;display:block;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Ubicación de Abogados en CDMX - Guanajuato 224, Colonia Roma Norte">
        </iframe>
      </div>
      <div class="transport-grid reveal">
        <div class="transport-card">
          <h4>Metro</h4>
          <p>Estación <strong>Insurgentes</strong> (Línea 1, rosa). A 10 minutos caminando por Avenida Insurgentes hacia el sur y luego sobre la calle Guanajuato hacia el oriente.</p>
        </div>
        <div class="transport-card">
          <h4>Metrobús</h4>
          <p>Estación <strong>Durango</strong> (Línea 1). A 7 minutos caminando. Baje en Durango, camine hacia el sur por Mérida y gire a la izquierda en Guanajuato.</p>
        </div>
        <div class="transport-card">
          <h4>Automóvil</h4>
          <p>Estacionamiento público disponible sobre <strong>Avenida Insurgentes</strong> y en las calles aledañas de la Colonia Roma Norte. La calle Guanajuato tiene cajones de estacionamiento con parquímetro.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- BRACKET: CONTEXTUAL NAVIGATION -->
  <section class="section-padding" style="background:var(--color-light);">
    <div class="container">
      <div class="reveal" style="max-width:850px;">
        <p style="font-size:16px;line-height:1.8;margin-bottom:16px;">Antes de contactarnos, puede consultar nuestra sección de <a href="/preguntas-frecuentes">preguntas frecuentes</a> donde respondemos las dudas más comunes sobre horarios, costos y tipos de asuntos que atendemos. Si desea informarse sobre un tema legal específico, visite nuestro <a href="/blog">blog jurídico</a> con artículos escritos por los abogados del despacho. También puede conocer nuestra trayectoria en <a href="/quienes-somos">quiénes somos</a> o revisar el panorama completo de servicios en <a href="/que-ofrecemos">qué ofrecemos</a>.</p>
      </div>
    </div>
  </section>

  <!-- BRACKET 3: CTA -->
  <section class="section-padding" style="background:var(--color-primary);color:var(--color-white);text-align:center;">
    <div class="container reveal">
      <h2 style="color:var(--color-white);max-width:700px;margin:0 auto 20px;">¿Necesita orientación legal inmediata?</h2>
      <p style="color:rgba(255,255,255,.7);max-width:550px;margin:0 auto 35px;font-size:18px;">Nuestro equipo de abogados está listo para escuchar su caso y ofrecerle la mejor estrategia jurídica.</p>
      <div style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap;">
        <a href="tel:+525564655501" class="btn-primary-wrap">Llamar ahora →</a>
        <a href="/asesoria-inicial" class="btn-secondary-wrap">Agendar asesoría →</a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Base>

<style>
  .section-tag {
    font-family: var(--font-body); font-size: 14px; font-weight: 600;
    color: var(--color-secondary); text-transform: uppercase; letter-spacing: 2px;
    margin-bottom: 16px;
  }
  .lead { font-size: 20px; line-height: 1.6; color: var(--color-primary); font-weight: 500; margin-bottom: 30px; }

  .contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: start; }

  .nap-block { margin-top: 10px; }
  .nap-item { padding: 24px 0; border-bottom: 1px solid var(--color-border); }
  .nap-item:last-child { border-bottom: none; }
  .nap-item h3 { font-size: 22px; margin-bottom: 8px; }
  .nap-item p { font-size: 16px; line-height: 1.7; margin-bottom: 0; }
  .nap-item a { color: var(--color-secondary); font-weight: 600; text-decoration: underline; }
  .nap-item a:hover { color: var(--color-primary); }

  .contact-social { display: flex; gap: 16px; margin-top: 12px; }
  .contact-social__link {
    display: flex; align-items: center; gap: 8px;
    padding: 10px 18px;
    border: 1px solid var(--color-border);
    color: var(--color-primary);
    font-size: 15px; font-weight: 600;
    text-decoration: none;
    transition: all var(--transition);
  }
  .contact-social__link:hover {
    background: var(--color-secondary);
    color: var(--color-white);
    border-color: var(--color-secondary);
  }
  .contact-social__link svg { width: 20px; height: 20px; flex-shrink: 0; }

  .form-card {
    background: var(--color-light); padding: 40px; position: sticky; top: 100px;
  }
  .form-card h3 { font-size: 28px; margin-bottom: 8px; }
  .form-card > p { font-size: 15px; color: var(--color-paragraph); margin-bottom: 24px; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .form-group { margin-bottom: 18px; }
  .form-group label {
    display: block; font-size: 14px; font-weight: 600; color: var(--color-primary);
    margin-bottom: 6px;
  }
  .form-group input,
  .form-group select,
  .form-group textarea {
    width: 100%; padding: 12px 16px; border: 1px solid var(--color-border);
    font-family: var(--font-body); font-size: 16px; color: var(--color-primary);
    background: var(--color-white); transition: border-color var(--transition);
  }
  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus { border-color: var(--color-secondary); outline: none; }
  .form-group textarea { resize: vertical; }

  .map-wrap { margin-bottom: 40px; border: 1px solid var(--color-border); }

  .transport-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  .transport-card { background: var(--color-white); padding: 28px; border: 1px solid var(--color-border); }
  .transport-card h4 { font-size: 20px; margin-bottom: 10px; }
  .transport-card p { font-size: 15px; line-height: 1.7; margin-bottom: 0; }

  .success-message { text-align: center; padding: 20px 0; }
  .success-icon {
    width: 64px; height: 64px; border-radius: 50%;
    background: var(--color-secondary); color: var(--color-white);
    font-size: 32px; line-height: 64px; text-align: center;
    margin: 0 auto 20px;
  }
  .success-message h3 { font-size: 24px; margin-bottom: 12px; color: var(--color-primary); }
  .success-message p { font-size: 16px; line-height: 1.7; color: var(--color-paragraph); margin-bottom: 24px; }

  @media (max-width: 991px) {
    .contact-grid { grid-template-columns: 1fr; }
    .form-card { position: static; }
    .transport-grid { grid-template-columns: 1fr; }
  }
  
  @media (max-width: 767px) {
    h1 { font-size: 36px; }
    .lead { font-size: 18px; }
  }
  @media (max-width: 479px) {
    .form-row { grid-template-columns: 1fr; }
    .contact-social { flex-direction: column; }
  }
</style>
