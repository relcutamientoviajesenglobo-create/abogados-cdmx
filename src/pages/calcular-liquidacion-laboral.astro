    <!-- REFERENCE TABLES -->
    <div class="container">
      <div class="calc-ref">
        <h2>Tablas de referencia — Liquidación laboral 2026</h2>
        <p>Información basada en la Ley Federal del Trabajo vigente, reforma 2023 de vacaciones (art. 76) y salario mínimo general 2026.</p>

        <h3 style="font-size:16px;margin:20px 0 8px;color:var(--color-secondary);">Días de vacaciones por antigüedad (art. 76 LFT, reforma 2023)</h3>
        <div class="calc-ref__table-wrap">
          <table>
            <thead>
              <tr><th>Antigüedad</th><th>Días de vacaciones</th><th>Prima vacacional (25%)</th></tr>
            </thead>
            <tbody>
              <tr><td><strong>1 año</strong></td><td>12 días</td><td>3 días</td></tr>
              <tr><td><strong>2 años</strong></td><td>14 días</td><td>3.5 días</td></tr>
              <tr><td><strong>3 años</strong></td><td>16 días</td><td>4 días</td></tr>
              <tr><td><strong>4 años</strong></td><td>18 días</td><td>4.5 días</td></tr>
              <tr><td><strong>5 años</strong></td><td>20 días</td><td>5 días</td></tr>
              <tr><td><strong>6-10 años</strong></td><td>22 días</td><td>5.5 días</td></tr>
              <tr><td><strong>11-15 años</strong></td><td>24 días</td><td>6 días</td></tr>
              <tr><td><strong>16-20 años</strong></td><td>26 días</td><td>6.5 días</td></tr>
              <tr><td><strong>21-25 años</strong></td><td>28 días</td><td>7 días</td></tr>
              <tr><td><strong>26-30 años</strong></td><td>30 días</td><td>7.5 días</td></tr>
            </tbody>
          </table>
        </div>

        <h3 style="font-size:16px;margin:20px 0 8px;color:var(--color-secondary);">Liquidación vs Finiquito — Comparativo</h3>
        <div class="calc-ref__table-wrap">
          <table>
            <thead>
              <tr><th>Concepto</th><th>Liquidación</th><th>Finiquito</th></tr>
            </thead>
            <tbody>
              <tr><td><strong>Cuándo aplica</strong></td><td>Despido injustificado</td><td>Renuncia o fin de contrato</td></tr>
              <tr><td><strong>3 meses salario (art. 123)</strong></td><td>Sí</td><td>No</td></tr>
              <tr><td><strong>20 días por año (art. 50)</strong></td><td>Sí</td><td>No</td></tr>
              <tr><td><strong>Prima de antigüedad</strong></td><td>Sí (siempre)</td><td>Solo si +15 años</td></tr>
              <tr><td><strong>Aguinaldo proporcional</strong></td><td>Sí</td><td>Sí</td></tr>
              <tr><td><strong>Vacaciones proporcionales</strong></td><td>Sí</td><td>Sí</td></tr>
              <tr><td><strong>Prima vacacional</strong></td><td>Sí</td><td>Sí</td></tr>
              <tr><td><strong>Salarios caídos</strong></td><td>Sí (hasta 12 meses)</td><td>No</td></tr>
            </tbody>
          </table>
        </div>

        <p class="calc-ref__note">Fuente: Ley Federal del Trabajo (arts. 48, 50, 76, 80, 87, 162), art. 123 apartado A, fracción XXII de la Constitución Política de los Estados Unidos Mexicanos. Salario mínimo general 2026: $278.80/día ($8,364/mes). Doble SMG para tope prima antigüedad: $557.60/día.</p>
      </div>

      <!-- FAQ Section -->
      <div class="calc-ref" style="margin-top:60px;">
        <h2>Preguntas frecuentes sobre liquidación laboral</h2>
        <div class="faq-list">
          <details class="faq-item">
            <summary class="faq-question">¿Qué es una liquidación laboral?</summary>
            <p class="faq-answer">La liquidación laboral es el pago que el patrón debe realizar al trabajador cuando lo despide sin causa justificada. Está establecida en el artículo 123, apartado A, fracción XXII de la Constitución y en los artículos 48 y 50 de la Ley Federal del Trabajo. Incluye la indemnización constitucional de 3 meses de salario, 20 días por cada año de servicio, prima de antigüedad y las prestaciones proporcionales devengadas.</p>
          </details>
          <details class="faq-item">
            <summary class="faq-question">¿Cuánto me toca de liquidación si me despiden injustificadamente?</summary>
            <p class="faq-answer">Por despido injustificado le corresponde: 3 meses de salario diario integrado (indemnización constitucional), 20 días de salario integrado por cada año trabajado, 12 días de salario por año de prima de antigüedad (topada a 2 veces el salario mínimo), más las partes proporcionales de aguinaldo (15 días), vacaciones y prima vacacional (25%). Use nuestra calculadora para obtener un estimado personalizado.</p>
          </details>
          <details class="faq-item">
            <summary class="faq-question">¿Qué son los salarios caídos?</summary>
            <p class="faq-answer">Los salarios caídos o vencidos son los salarios que el trabajador dejó de percibir desde el día del despido hasta que se ejecuta el laudo o sentencia. Conforme al artículo 48 de la LFT (reformado en 2012), se pagan hasta un máximo de 12 meses de salario. Si el juicio excede ese plazo, se genera un interés del 2% mensual sobre 15 meses de salario por el tiempo excedente.</p>
          </details>
          <details class="faq-item">
            <summary class="faq-question">¿Cómo se calcula el salario diario integrado?</summary>
            <p class="faq-answer">El salario diario integrado (SDI) se calcula multiplicando el salario diario ordinario por un factor de integración. Este factor se obtiene sumando: 1 + (aguinaldo/365) + (días de vacaciones x 0.25 / 365). Por ejemplo, para un trabajador con 1 año de antigüedad: factor = 1 + (15/365) + (12 x 0.25/365) = 1.0493. Si su salario diario es $833.33, su SDI sería $874.44.</p>
          </details>
          <details class="faq-item">
            <summary class="faq-question">¿Cuánto tiempo tengo para demandar por despido injustificado?</summary>
            <p class="faq-answer">Tiene 2 meses (60 días naturales) a partir de la fecha del despido para presentar su demanda, conforme al artículo 518 de la LFT. Es fundamental no firmar ningún documento de renuncia voluntaria y acudir lo antes posible con un abogado laboralista para iniciar el proceso ante el Tribunal Laboral competente en la Ciudad de México.</p>
          </details>
          <details class="faq-item">
            <summary class="faq-question">¿Qué diferencia hay entre liquidación y finiquito?</summary>
            <p class="faq-answer">El finiquito es el pago de las prestaciones devengadas (aguinaldo, vacaciones, prima vacacional proporcionales) que corresponden en cualquier terminación laboral, incluyendo la renuncia. La liquidación, en cambio, se genera exclusivamente por despido injustificado y es significativamente mayor: incluye 3 meses de indemnización constitucional, 20 días por año trabajado, prima de antigüedad y posibles salarios caídos, además del finiquito.</p>
          </details>
        </div>
      </div>

      <!-- CTA Block -->
      <div class="calc-final-cta">
        <h2>¿Fue despedido injustificadamente?</h2>
        <p>Nuestros <a href="/especialidades/derecho-laboral-cdmx" style="color:var(--color-secondary);text-decoration:underline;">abogados laboralistas en CDMX</a> pueden ayudarle a obtener su liquidación completa. La <a href="/despacho-juridico/luciana-valle" style="color:var(--color-secondary);text-decoration:underline;">Lic. Luciana Valle</a> y su equipo le representan.</p>
        <div class="calc-final-cta__btns">
          <a href="/asesoria-inicial" class="btn-primary-wrap">Agendar consulta gratuita →</a>
          <a href="tel:+525564655501" class="btn-secondary-wrap">Llamar al 55 6465 5501</a>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Base>

<script>
  // === STATE ===
  let salary = 25000;
  let years = 3;
  let fireMonth = 3;
  let fireType: 'unjust' | 'rescission' | 'forced' = 'unjust';
  let extras: Set<string> = new Set();

  // === VACATION DAYS TABLE (Art. 76 LFT, reforma 2023) ===
  function getVacationDays(y: number): number {
    const fullYears = Math.floor(y);
    if (fullYears <= 0) return 12;
    if (fullYears === 1) return 12;
    if (fullYears === 2) return 14;
    if (fullYears === 3) return 16;
    if (fullYears === 4) return 18;
    if (fullYears === 5) return 20;
    if (fullYears <= 10) return 22;
    if (fullYears <= 15) return 24;
    if (fullYears <= 20) return 26;
    if (fullYears <= 25) return 28;
    return 30;
  }

  // === SMG 2026 (Salario Mínimo General) ===
  const SMG_DIARIO = 278.80;
  const TOPE_PRIMA = SMG_DIARIO * 2; // $557.60/día — tope art. 162 LFT

  // Days elapsed in year by month end
  const DAYS_BY_MONTH = [0, 31, 59, 90, 120, 151, 181, 212, 243, 273, 304, 334, 365];

  // === ELEMENTS ===
  const $ = (s: string) => document.querySelector(s)!;
  const salarySlider = $('#salarySlider') as HTMLInputElement;
  const yearsSlider = $('#yearsSlider') as HTMLInputElement;

  // === FORMAT (MXN) ===
  const fmtShort = (n: number) => {
    return '$' + Math.round(n).toString().replace(/\B(?=(\d{3})+(?!\d))/g, ',');
  };

  // === CALCULATE ===
  let prevTotal = 0;

  function calculate() {
    const salarioDiario = salary / 30;

    // Factor de integración
    const vacDays = getVacationDays(years);
    const factorIntegracion = 1 + (15 / 365) + (vacDays * 0.25 / 365);
    const salarioIntegrado = salarioDiario * factorIntegracion;

    // Days elapsed in the year at dismissal (mid-month approximation)
    const diasAnio = DAYS_BY_MONTH[fireMonth - 1] + Math.round((DAYS_BY_MONTH[fireMonth] - DAYS_BY_MONTH[fireMonth - 1]) / 2);

    // 1. Indemnización constitucional: 3 meses (art. 123-A-XXII)
    const tresMeses = salarioIntegrado * 90;

    // 2. 20 días por año trabajado (art. 50-II LFT)
    const veinteDias = salarioIntegrado * 20 * years;

    // 3. Prima de antigüedad (art. 162 LFT): 12 días por año, tope 2×SMG
    const salarioPrima = Math.min(salarioDiario, TOPE_PRIMA);
    const primaAntiguedad = salarioPrima * 12 * years;

    // 4. Aguinaldo proporcional: (salario_diario × 15) × (días_año / 365)
    const aguinaldo = (salarioDiario * 15) * (diasAnio / 365);

    // 5. Vacaciones proporcionales: salario_diario × días_vac × (días_año / 365)
    const vacacionesProp = salarioDiario * vacDays * (diasAnio / 365);

    // 6. Prima vacacional: vacaciones × 25%
    const primaVacacional = vacacionesProp * 0.25;
    const vacTotal = vacacionesProp + primaVacacional;

    // 7. Salarios caídos (optional): max 12 meses
    let salariosCaidos = 0;
    if (extras.has('salariosCaidos')) {
      salariosCaidos = salarioIntegrado * 30 * 12;
    }

    // 8. Fondo de ahorro (optional): 5% del salario × meses trabajados
    let fondoAhorro = 0;
    if (extras.has('fondoAhorro')) {
      fondoAhorro = salary * 0.05 * (years * 12);
    }

    // 9. Comisiones (optional): 15% extra on base salary components
    let comisiones = 0;
    if (extras.has('comisiones')) {
      comisiones = (tresMeses + veinteDias) * 0.15;
    }

    const total = tresMeses + veinteDias + primaAntiguedad + aguinaldo + vacTotal + salariosCaidos + fondoAhorro + comisiones;

    // Find biggest component for donut
    const components: [string, number][] = [
      ['3 meses indemnización', tresMeses],
      ['20 días × año', veinteDias],
      ['Prima antigüedad', primaAntiguedad],
      ['Aguinaldo prop.', aguinaldo],
      ['Vacaciones + prima', vacTotal],
    ];
    if (salariosCaidos > 0) components.push(['Salarios caídos', salariosCaidos]);
    if (fondoAhorro > 0) components.push(['Fondo de ahorro', fondoAhorro]);
    if (comisiones > 0) components.push(['Comisiones', comisiones]);

    components.sort((a, b) => b[1] - a[1]);
    const biggestName = components[0][0];
    const biggestPct = total > 0 ? Math.round((components[0][1] / total) * 100) : 0;

    // Animate total
    countTo('resTotalAmount', prevTotal, total, fmtShort);
    prevTotal = total;

    // Multiplier
    const multiplier = salary > 0 ? (total / salary).toFixed(1) : '0';
    animateValue('resMultiplier', `${multiplier} veces su salario mensual`);

    // Donut
    const donut = document.getElementById('donutFill') as SVGCircleElement;
    if (donut) {
      const circumference = 2 * Math.PI * 54;
      const offset = circumference - (biggestPct / 100) * circumference;
      donut.style.strokeDashoffset = String(offset);
    }
    const donutPct = document.getElementById('donutPct');
    if (donutPct) donutPct.textContent = biggestPct + '%';
    $('#resBiggest')!.textContent = biggestName;

    // Breakdown
    $('#brk3Meses')!.textContent = fmtShort(tresMeses);
    $('#brk20Dias')!.textContent = fmtShort(veinteDias);
    $('#brkPrima')!.textContent = fmtShort(primaAntiguedad);
    $('#brkAguinaldo')!.textContent = fmtShort(aguinaldo);
    $('#brkVacaciones')!.textContent = fmtShort(vacTotal);

    const salariosRow = document.getElementById('brkSalariosRow')!;
    if (salariosCaidos > 0) {
      salariosRow.style.display = 'flex';
      $('#brkSalarios')!.textContent = fmtShort(salariosCaidos);
    } else {
      salariosRow.style.display = 'none';
    }

    const fondoRow = document.getElementById('brkFondoRow')!;
    if (fondoAhorro > 0) {
      fondoRow.style.display = 'flex';
      $('#brkFondo')!.textContent = fmtShort(fondoAhorro);
    } else {
      fondoRow.style.display = 'none';
    }

    const comisionesRow = document.getElementById('brkComisionesRow')!;
    if (comisiones > 0) {
      comisionesRow.style.display = 'flex';
      $('#brkComisiones')!.textContent = fmtShort(comisiones);
    } else {
      comisionesRow.style.display = 'none';
    }

    // Display updates
    $('#salaryDisplay')!.textContent = fmtShort(salary) + ' MXN';
    const yLabel = years === 1 ? '1 año' : (years % 1 === 0 ? years + ' años' : years + ' años');
    $('#yearsDisplay')!.textContent = yLabel;

    updateSliderTrack(salarySlider);
    updateSliderTrack(yearsSlider);
  }

  function countTo(id: string, from: number, to: number, formatter: (n: number) => string) {
    const el = document.getElementById(id)!;
    if (Math.round(from) === Math.round(to)) { el.textContent = formatter(to); return; }
    const duration = 400;
    const start = performance.now();
    function tick(now: number) {
      const elapsed = now - start;
      const progress = Math.min(elapsed / duration, 1);
      const eased = 1 - Math.pow(1 - progress, 3);
      const current = Math.round(from + (to - from) * eased);
      el.textContent = formatter(current);
      if (progress < 1) requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);
  }

  function animateValue(id: string, newVal: string) {
    const el = document.getElementById(id)!;
    if (el.textContent === newVal) return;
    el.style.transform = 'translateY(-4px)';
    el.style.opacity = '0.4';
    requestAnimationFrame(() => {
      setTimeout(() => {
        el.textContent = newVal;
        el.style.transform = 'translateY(0)';
        el.style.opacity = '1';
      }, 80);
    });
  }

  function updateSliderTrack(slider: HTMLInputElement) {
    const pctVal = ((parseFloat(slider.value) - parseFloat(slider.min)) / (parseFloat(slider.max) - parseFloat(slider.min))) * 100;
    slider.style.setProperty('--pct', `${pctVal}%`);
  }

  // === SALARY SLIDER + TOOLTIP ===
  const salaryTooltip = document.getElementById('salaryTooltip')!;
  function updateSalaryTooltip() {
    const s = salarySlider;
    const pctVal = ((parseInt(s.value) - parseInt(s.min)) / (parseInt(s.max) - parseInt(s.min)));
    salaryTooltip.style.left = `calc(${pctVal * 100}% + ${(0.5 - pctVal) * 28}px)`;
    salaryTooltip.textContent = fmtShort(salary) + ' MXN';
  }
  salarySlider.addEventListener('input', () => {
    salary = parseInt(salarySlider.value);
    updateSalaryTooltip();
    calculate();
  });

  // === YEARS SLIDER + TOOLTIP ===
  const yearsTooltip = document.getElementById('yearsTooltip')!;
  function updateYearsTooltip() {
    const s = yearsSlider;
    const pctVal = ((parseFloat(s.value) - parseFloat(s.min)) / (parseFloat(s.max) - parseFloat(s.min)));
    yearsTooltip.style.left = `calc(${pctVal * 100}% + ${(0.5 - pctVal) * 28}px)`;
    yearsTooltip.textContent = years === 1 ? '1 año' : years + ' años';
  }
  yearsSlider.addEventListener('input', () => {
    years = parseFloat(yearsSlider.value);
    updateYearsTooltip();
    calculate();
  });

  // === MONTH CARDS ===
  document.querySelectorAll('#monthChips .month-card').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('#monthChips .month-card').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      fireMonth = parseInt(btn.getAttribute('data-val') || '3');
      calculate();
    });
  });

  // === FIRE TYPE CARDS ===
  document.querySelectorAll('#fireTypeToggle .custody-card').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('#fireTypeToggle .custody-card').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      fireType = btn.getAttribute('data-val') as 'unjust' | 'rescission' | 'forced';
      calculate();
    });
  });

  // === EXTRAS CARDS ===
  document.querySelectorAll('#extrasChips .extra-card').forEach(btn => {
    btn.addEventListener('click', () => {
      btn.classList.toggle('active');
      const val = btn.getAttribute('data-val')!;
      if (extras.has(val)) extras.delete(val); else extras.add(val);
      calculate();
    });
  });

  // === WHATSAPP SHARE ===
  document.getElementById('shareWhatsApp')?.addEventListener('click', () => {
    const total = document.getElementById('resTotalAmount')?.textContent || '';
    const multiplier = document.getElementById('resMultiplier')?.textContent || '';
    const fireLabels: Record<string, string> = {
      unjust: 'Injustificado',
      rescission: 'Rescisión (art. 51)',
      forced: 'Renuncia forzada'
    };
    const msg = encodeURIComponent(
      `📋 *Cálculo de Liquidación Laboral CDMX 2026*\n\n` +
      `💰 Salario mensual: ${fmtShort(salary)} MXN\n` +
      `📅 Años trabajados: ${years}\n` +
      `⚖️ Tipo: ${fireLabels[fireType]}\n\n` +
      `💵 *Liquidación total estimada:*\n` +
      `${total} MXN\n` +
      `(${multiplier})\n\n` +
      `Calculado en: https://abogadosencdmx.com/calcular-liquidacion-laboral\n` +
      `📞 Consulta gratuita: 55 6465 5501`
    );
    window.open(`https://wa.me/?text=${msg}`, '_blank');
  });

  // === INIT ===
  updateSalaryTooltip();
  updateYearsTooltip();
  calculate();
</script>

