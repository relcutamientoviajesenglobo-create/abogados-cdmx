---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = 'Calculadora de Liquidación Laboral CDMX 2026 | Abogados en CDMX';
const description = 'Calcule su liquidación por despido injustificado en la Ciudad de México. Incluye indemnización constitucional, 20 días por año, prima de antigüedad y salarios caídos. Actualizada 2026 con LFT vigente.';
const canonical = 'https://abogadosencdmx.com/calcular-liquidacion-laboral';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      "name": "Calculadora de Liquidación Laboral CDMX",
      "url": canonical,
      "applicationCategory": "FinanceApplication",
      "operatingSystem": "Web",
      "description": description,
      "provider": { "@type": "LegalService", "name": "Abogados en CDMX", "url": "https://abogadosencdmx.com" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://abogadosencdmx.com/" },
        { "@type": "ListItem", "position": 2, "name": "Calculadora de Liquidación Laboral", "item": canonical }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        { "@type": "Question", "name": "¿Qué es una liquidación laboral?", "acceptedAnswer": { "@type": "Answer", "text": "La liquidación laboral es la compensación económica que un patrón debe pagar al trabajador cuando lo despide injustificadamente. Incluye 3 meses de salario (indemnización constitucional), 20 días por año trabajado, prima de antigüedad, y las partes proporcionales de aguinaldo, vacaciones y prima vacacional." } },
        { "@type": "Question", "name": "¿Cuánto me toca de liquidación si me despiden injustificadamente?", "acceptedAnswer": { "@type": "Answer", "text": "Por despido injustificado le corresponde: 3 meses de salario integrado (art. 123-A-XXII Constitución), 20 días de salario integrado por cada año trabajado (art. 50-II LFT), prima de antigüedad de 12 días por año (art. 162 LFT), más proporcionales de aguinaldo, vacaciones y prima vacacional." } },
        { "@type": "Question", "name": "¿Qué son los salarios caídos?", "acceptedAnswer": { "@type": "Answer", "text": "Los salarios caídos (o vencidos) son los salarios que el trabajador dejó de percibir desde la fecha del despido hasta que se cumple el laudo. Conforme al art. 48 LFT reformado, se pagan hasta un máximo de 12 meses, más un 2% mensual sobre 15 meses de salario por el tiempo que exceda." } },
        { "@type": "Question", "name": "¿Cómo se calcula el salario diario integrado?", "acceptedAnswer": { "@type": "Answer", "text": "El salario diario integrado (SDI) se obtiene multiplicando el salario diario por el factor de integración. Este factor incluye la parte proporcional de aguinaldo (15 días) y prima vacacional (25% de los días de vacaciones correspondientes), divididos entre 365." } },
        { "@type": "Question", "name": "¿Cuánto tiempo tengo para demandar por despido injustificado?", "acceptedAnswer": { "@type": "Answer", "text": "El trabajador tiene 2 meses (60 días) a partir de la fecha del despido para presentar su demanda ante el Tribunal Laboral competente, conforme al artículo 518 de la Ley Federal del Trabajo." } },
        { "@type": "Question", "name": "¿Qué diferencia hay entre liquidación y finiquito?", "acceptedAnswer": { "@type": "Answer", "text": "La liquidación se paga cuando el patrón despide injustificadamente e incluye indemnización constitucional (3 meses) y 20 días por año. El finiquito se paga en cualquier terminación laboral (renuncia, fin de contrato) e incluye solo las partes proporcionales de prestaciones devengadas. La liquidación es significativamente mayor." } }
      ]
    }
  ]
};
---

<Base title={title} description={description} canonical={canonical} schema={schema}>
  <Header slot="header" />

  <section class="calc-page">
    <!-- HERO -->
    <div class="calc-hero">
      <div class="container">
