---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = 'Abogados en Roma Norte, CDMX — Despacho Jurídico en Guanajuato 224 | Abogados en CDMX';
const description = 'Despacho de abogados en la Colonia Roma Norte, Alcaldía Cuauhtémoc, CDMX. Especialistas en derecho familiar, penal, civil, corporativo, inmobiliario, migratorio y laboral. Oficina en Guanajuato 224.';
const canonical = 'https://abogadosencdmx.com/abogados-roma-norte-cdmx';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LegalService",
      "name": "Abogados en Roma Norte, CDMX",
      "description": "Despacho jurídico ubicado en la Colonia Roma Norte, Alcaldía Cuauhtémoc. Especialistas en 7 áreas del derecho con oficina en Guanajuato 224, C.P. 06700.",
      "url": "https://abogadosencdmx.com/abogados-roma-norte-cdmx",
      "telephone": "+525564655501",
      "email": "contacto@abogadosencdmx.com",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Guanajuato 224",
        "addressLocality": "Ciudad de México",
        "addressRegion": "CDMX",
        "postalCode": "06700",
        "addressCountry": "MX",
        "name": "Colonia Roma Norte, Alcaldía Cuauhtémoc"
      },
      "geo": { "@type": "GeoCoordinates", "latitude": 19.4194, "longitude": -99.1616 },
      "openingHoursSpecification": { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"], "opens": "09:00", "closes": "18:00" },
      "areaServed": { "@type": "City", "name": "Ciudad de México" },
      "priceRange": "$$"
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://abogadosencdmx.com/" },
        { "@type": "ListItem", "position": 2, "name": "Abogados en Roma Norte", "item": "https://abogadosencdmx.com/abogados-roma-norte-cdmx" }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "¿Dónde está exactamente el despacho de abogados en Roma Norte?",
          "acceptedAnswer": { "@type": "Answer", "text": "Nuestra oficina se encuentra en Guanajuato 224, Colonia Roma Norte, Alcaldía Cuauhtémoc, C.P. 06700, Ciudad de México. Estamos a 3 cuadras del Metrobús Sonora y a 5 minutos caminando desde la Glorieta de los Insurgentes." }
        },
        {
          "@type": "Question",
          "name": "¿Qué especialidades legales manejan en Roma Norte?",
          "acceptedAnswer": { "@type": "Answer", "text": "En nuestro despacho de Roma Norte atendemos 7 áreas: derecho familiar (divorcios, custodia, pensiones), derecho penal, derecho civil, derecho corporativo, derecho inmobiliario, derecho migratorio y derecho laboral." }
        },
        {
          "@type": "Question",
          "name": "¿Tienen estacionamiento en su oficina de Roma Norte?",
          "acceptedAnswer": { "@type": "Answer", "text": "Contamos con estacionamiento limitado en el edificio. También hay estacionamientos públicos en la calle de Jalapa y sobre Avenida Insurgentes. Recomendamos llegar en Metrobús (estación Sonora) o Metro (Insurgentes, Línea 1)." }
        },
        {
          "@type": "Question",
          "name": "¿Cuánto cuesta la primera consulta en su despacho de Roma Norte?",
          "acceptedAnswer": { "@type": "Answer", "text": "La consulta inicial en nuestro despacho es gratuita y sin compromiso. En una sesión de 30 a 45 minutos evaluamos su situación legal y le presentamos las opciones disponibles con un presupuesto transparente." }
        }
      ]
    }
  ]
};

const especialidades = [
  { nombre: 'Derecho Familiar', href: '/especialidades/derecho-familiar-cdmx', icono: '&#9825;', desc: 'Divorcios, custodia, pensión alimenticia y adopciones.' },
  { nombre: 'Derecho Penal', href: '/especialidades/derecho-penal-cdmx', icono: '&#9878;', desc: 'Defensa penal, amparos y delitos patrimoniales.' },
  { nombre: 'Derecho Civil', href: '/especialidades/derecho-civil-cdmx', icono: '&#9998;', desc: 'Contratos, responsabilidad civil y sucesiones.' },
  { nombre: 'Derecho Corporativo', href: '/especialidades/derecho-corporativo-cdmx', icono: '&#9881;', desc: 'Constitución de empresas, compliance y gobierno corporativo.' },
  { nombre: 'Derecho Inmobiliario', href: '/especialidades/derecho-inmobiliario-cdmx', icono: '&#8962;', desc: 'Compraventa, escrituración y arrendamiento.' },
  { nombre: 'Derecho Migratorio', href: '/especialidades/derecho-migratorio-cdmx', icono: '&#9992;', desc: 'Visas, residencia temporal y permanente, naturalización.' },
  { nombre: 'Derecho Laboral', href: '/especialidades/derecho-laboral-cdmx', icono: '&#9874;', desc: 'Despidos injustificados, liquidaciones y demandas laborales.' },
];
---

<Base title={title} description={description} canonical={canonical} schema={schema}>
  <Header slot="header" />

  <!-- Hero -->
  <section class="loc-hero">
    <div class="loc-container">
      <nav class="loc-breadcrumb" aria-label="Breadcrumb">
        <a href="/">Inicio</a> &rsaquo; <span>Abogados en Roma Norte</span>
      </nav>
      <span class="loc-badge">Oficina principal en Colonia Roma Norte</span>
      <h1>Abogados en Roma Norte, Ciudad de M&eacute;xico</h1>
      <p class="loc-hero-desc">Nuestro despacho jur&iacute;dico se encuentra en el coraz&oacute;n de la Colonia Roma Norte, Alcald&iacute;a Cuauht&eacute;moc. Desde nuestra oficina en Guanajuato 224 brindamos asesor&iacute;a legal especializada en 7 &aacute;reas del derecho a clientes de toda la Ciudad de M&eacute;xico.</p>
    </div>
  </section>

  <!-- Servicios desde Roma Norte -->
  <section class="loc-section">
    <div class="loc-container">
      <h2>Servicios legales en Roma Norte, CDMX</h2>
      <p>La Colonia Roma Norte es una de las zonas con mayor actividad jur&iacute;dica en la Ciudad de M&eacute;xico. Nuestra ubicaci&oacute;n estrat&eacute;gica en Guanajuato 224 nos permite estar cerca de los juzgados civiles y familiares de la Alcald&iacute;a Cuauht&eacute;moc, del Centro de Justicia Penal y del Centro de Conciliaci&oacute;n Laboral (CEFRAMEL). Atendemos casos de residentes de la Roma Norte, Roma Sur, Juárez, Doctores y colonias aleda&ntilde;as en materias como divorcios, custodia de hijos, defensa penal, contratos inmobiliarios, constituci&oacute;n de empresas, tr&aacute;mites migratorios y conflictos laborales.</p>
      <p>La Alcald&iacute;a Cuauht&eacute;moc concentra una alta densidad de oficinas, restaurantes y comercios, lo que genera una demanda constante de servicios jur&iacute;dicos en materia corporativa, arrendamientos comerciales y derecho laboral. Nuestro equipo conoce a profundidad la din&aacute;mica legal de la zona.</p>
    </div>
  </section>

  <!-- Cómo llegar -->
  <section class="loc-section loc-section--alt">
    <div class="loc-container">
      <h2>C&oacute;mo llegar a nuestro despacho en Roma Norte</h2>
      <p>Nuestra oficina se ubica en <strong>Guanajuato 224, Colonia Roma Norte, C.P. 06700</strong>, entre las calles de Orizaba y Córdoba.</p>
      <div class="loc-directions">
        <div class="loc-dir-card">
          <h3>En Metro</h3>
          <p>La estaci&oacute;n m&aacute;s cercana es <strong>Insurgentes (L&iacute;nea 1)</strong>, a 8 minutos caminando hacia el sur por Avenida Insurgentes. Tambi&eacute;n puede usar <strong>Hospital General (L&iacute;nea 3)</strong> a 10 minutos al sureste.</p>
        </div>
        <div class="loc-dir-card">
          <h3>En Metrob&uacute;s</h3>
          <p>La estaci&oacute;n <strong>Sonora (L&iacute;nea 1 Metrob&uacute;s)</strong> est&aacute; a solo 3 cuadras de nuestra oficina. Camine por la calle de Guanajuato hacia el poniente.</p>
        </div>
        <div class="loc-dir-card">
          <h3>En auto</h3>
          <p>Desde Avenida Insurgentes, tome la calle de Guanajuato hacia el oriente. Hay estacionamiento p&uacute;blico en la calle de Jalapa y sobre Insurgentes. El Parqu&iacute;metro Roma opera de lunes a s&aacute;bado.</p>
        </div>
      </div>
      <p class="loc-landmarks"><strong>Referencias:</strong> A 2 cuadras del Jard&iacute;n Pushkin, a 5 minutos de la Plaza R&iacute;o de Janeiro y a 3 cuadras del Mercado Roma.</p>
    </div>
  </section>

  <!-- Especialidades -->
  <section class="loc-section">
    <div class="loc-container">
      <h2>&Aacute;reas del derecho que atendemos desde Roma Norte</h2>
      <div class="loc-specs-grid">
        {especialidades.map(e => (
          <a href={e.href} class="loc-spec-card">
            <span class="loc-spec-icon" set:html={e.icono} />
            <h3>{e.nombre}</h3>
            <p>{e.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonio -->
  <section class="loc-section loc-section--alt">
    <div class="loc-container">
      <div class="loc-testimonial">
        <blockquote>
          <p>&ldquo;Vivo en la Roma Norte y buscaba un despacho cercano para mi divorcio. Encontr&eacute; a Abogados en CDMX a pocas cuadras de mi departamento. El trato fue profesional desde la primera consulta y resolvieron todo en menos de tres meses. Excelente servicio cerca de casa.&rdquo;</p>
          <cite>&mdash; Patricia Zavala, Colonia Roma Norte</cite>
        </blockquote>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="loc-section">
    <div class="loc-container">
      <h2>Preguntas frecuentes sobre nuestro despacho en Roma Norte</h2>
      <div class="loc-faq">
        <details>
          <summary>&iquest;D&oacute;nde est&aacute; exactamente el despacho de abogados en Roma Norte?</summary>
          <p>Nuestra oficina se encuentra en Guanajuato 224, Colonia Roma Norte, Alcald&iacute;a Cuauht&eacute;moc, C.P. 06700. Estamos a 3 cuadras del Metrob&uacute;s Sonora y a 5 minutos caminando desde la Glorieta de los Insurgentes.</p>
        </details>
        <details>
          <summary>&iquest;Qu&eacute; especialidades legales manejan en Roma Norte?</summary>
          <p>Atendemos 7 &aacute;reas del derecho: familiar, penal, civil, corporativo, inmobiliario, migratorio y laboral. Cada &aacute;rea cuenta con abogados especializados con experiencia en tribunales de la Ciudad de M&eacute;xico.</p>
        </details>
        <details>
          <summary>&iquest;Tienen estacionamiento en su oficina de Roma Norte?</summary>
          <p>Contamos con estacionamiento limitado en el edificio. Tambi&eacute;n hay estacionamientos p&uacute;blicos en la calle de Jalapa y sobre Avenida Insurgentes. Recomendamos llegar en Metrob&uacute;s (estaci&oacute;n Sonora) o Metro (Insurgentes, L&iacute;nea 1).</p>
        </details>
        <details>
          <summary>&iquest;Cu&aacute;nto cuesta la primera consulta en Roma Norte?</summary>
          <p>La consulta inicial es gratuita y sin compromiso. En una sesi&oacute;n de 30 a 45 minutos evaluamos su situaci&oacute;n legal y le presentamos opciones con un presupuesto claro.</p>
        </details>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="loc-cta">
    <div class="loc-container">
      <h2>Agende su consulta gratuita en Roma Norte</h2>
      <p>Vis&iacute;tenos en Guanajuato 224, Colonia Roma Norte, o cont&aacute;ctenos por tel&eacute;fono y WhatsApp.</p>
      <div class="loc-cta-buttons">
        <a href="tel:+525564655501" class="loc-btn loc-btn--primary">Llamar: 55 6465 5501</a>
        <a href="https://wa.me/525564655501?text=Hola%2C%20quiero%20agendar%20una%20consulta%20legal%20en%20Roma%20Norte" class="loc-btn loc-btn--whatsapp">WhatsApp</a>
        <a href="/asesoria-inicial" class="loc-btn loc-btn--outline">Asesor&iacute;a inicial gratuita</a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Base>

<style>
  .loc-hero{background:#1a1f3d;color:#fff;padding:80px 0 60px;text-align:center}
  .loc-hero h1{font-size:clamp(1.8rem,4vw,2.8rem);margin:16px 0;line-height:1.2}
  .loc-hero-desc{max-width:700px;margin:0 auto;font-size:1.1rem;opacity:.9;line-height:1.7}
  .loc-container{max-width:1100px;margin:0 auto;padding:0 20px}
  .loc-breadcrumb{font-size:.9rem;margin-bottom:16px;opacity:.7}
  .loc-breadcrumb a{color:#c9a84c;text-decoration:none}
  .loc-badge{display:inline-block;background:#c9a84c;color:#1a1f3d;padding:6px 18px;border-radius:50px;font-size:.85rem;font-weight:600;margin-bottom:10px}
  .loc-section{padding:60px 0}
  .loc-section--alt{background:#f8f7f4}
  .loc-section h2{font-size:clamp(1.4rem,3vw,2rem);color:#1a1f3d;margin-bottom:20px}
  .loc-section p{line-height:1.8;color:#333;max-width:800px;margin-bottom:16px}
  .loc-directions{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:24px;margin-top:30px}
  .loc-dir-card{background:#fff;border:1px solid #e8e6e1;border-radius:12px;padding:28px;box-shadow:0 2px 8px rgba(0,0,0,.04)}
  .loc-dir-card h3{color:#1a1f3d;margin-bottom:10px;font-size:1.1rem}
  .loc-dir-card p{font-size:.95rem;margin:0}
  .loc-landmarks{margin-top:24px;padding:16px 20px;background:#fff;border-left:4px solid #c9a84c;border-radius:0 8px 8px 0;font-size:.95rem}
  .loc-specs-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(250px,1fr));gap:20px;margin-top:30px}
  .loc-spec-card{display:block;background:#fff;border:1px solid #e8e6e1;border-radius:12px;padding:24px;text-decoration:none;transition:box-shadow .2s,border-color .2s}
  .loc-spec-card:hover{box-shadow:0 4px 16px rgba(0,0,0,.08);border-color:#c9a84c}
  .loc-spec-icon{font-size:1.6rem;display:block;margin-bottom:8px}
  .loc-spec-card h3{color:#1a1f3d;font-size:1rem;margin-bottom:6px}
  .loc-spec-card p{color:#555;font-size:.9rem;margin:0;line-height:1.5}
  .loc-testimonial{max-width:700px;margin:0 auto;text-align:center}
  .loc-testimonial blockquote{border:none;margin:0;padding:0}
  .loc-testimonial p{font-size:1.15rem;font-style:italic;color:#1a1f3d;line-height:1.8}
  .loc-testimonial cite{display:block;margin-top:16px;font-size:.95rem;color:#666;font-style:normal}
  .loc-faq{max-width:800px;margin-top:24px}
  .loc-faq details{border:1px solid #e8e6e1;border-radius:10px;margin-bottom:12px;overflow:hidden}
  .loc-faq summary{padding:18px 24px;cursor:pointer;font-weight:600;color:#1a1f3d;background:#fff;font-size:1rem;list-style:none}
  .loc-faq summary::-webkit-details-marker{display:none}
  .loc-faq summary::before{content:'+ ';color:#c9a84c;font-weight:700}
  .loc-faq details[open] summary::before{content:'- '}
  .loc-faq details p{padding:0 24px 18px;margin:0;color:#444;line-height:1.7;font-size:.95rem}
  .loc-cta{background:#1a1f3d;color:#fff;padding:60px 0;text-align:center}
  .loc-cta h2{color:#fff;margin-bottom:12px;font-size:clamp(1.4rem,3vw,2rem)}
  .loc-cta p{color:rgba(255,255,255,.85);max-width:600px;margin:0 auto 28px}
  .loc-cta-buttons{display:flex;flex-wrap:wrap;gap:14px;justify-content:center}
  .loc-btn{display:inline-block;padding:14px 28px;border-radius:8px;font-weight:600;text-decoration:none;font-size:1rem;transition:opacity .2s}
  .loc-btn:hover{opacity:.9}
  .loc-btn--primary{background:#c9a84c;color:#1a1f3d}
  .loc-btn--whatsapp{background:#25d366;color:#fff}
  .loc-btn--outline{border:2px solid #fff;color:#fff;background:transparent}
  @media(max-width:600px){.loc-hero{padding:60px 0 40px}.loc-section{padding:40px 0}.loc-cta{padding:40px 0}.loc-cta-buttons{flex-direction:column;align-items:center}}
</style>
