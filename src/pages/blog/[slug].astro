---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await post.render();

const title = `${post.data.title} | Abogados en CDMX`;
const description = post.data.description;
const canonical = `https://abogadosencdmx.com/blog/${post.slug}`;
const publishedDate = post.data.date.toISOString();

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": post.data.title,
  "description": description,
  "url": canonical,
  "datePublished": publishedDate,
  "dateModified": publishedDate,
  "author": { "@type": "Person", "name": post.data.author },
  "publisher": {
    "@type": "LegalService",
    "name": "Abogados en CDMX",
    "url": "https://abogadosencdmx.com",
    "telephone": "+525564655501",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Guanajuato 224",
      "addressLocality": "Ciudad de México",
      "postalCode": "06700",
      "addressCountry": "MX"
    }
  },
  "mainEntityOfPage": canonical
};

// Build TOC from headings
const toc = headings.filter((h) => [2, 3].includes(h.depth));

// Format date
const dateObj = post.data.date;
const months = ['enero','febrero','marzo','abril','mayo','junio','julio','agosto','septiembre','octubre','noviembre','diciembre'];
const dateDisplay = `${dateObj.getDate()} de ${months[dateObj.getMonth()]} de ${dateObj.getFullYear()}`;
---

<Base title={title} description={description} canonical={canonical} schema={schema} publishedDate={publishedDate} modifiedDate={publishedDate} author={post.data.author}>
  <Header slot="header" />

  <article class="section-padding">
    <div class="container">
      <Breadcrumb items={[{label:'Blog', href:'/blog'},{label: post.data.title}]} />
      <div class="article-layout">
        <div class="article-content">
          <div class="article-meta">
            <span class="article-cat">Derecho</span>
            <time datetime={publishedDate}>{dateDisplay}</time>
            <span class="article-author">Por {post.data.author}</span>
          </div>

          <h1>{post.data.title}</h1>

          {toc.length > 3 && (
            <nav class="article-toc" aria-label="Tabla de contenidos">
              <h2 class="article-toc__title">Contenido del artículo</h2>
              <ol class="article-toc__list">
                {toc.map((h) => (
                  <li class={h.depth === 3 ? 'toc-sub' : ''}>
                    <a href={`#${h.slug}`}>{h.text}</a>
                  </li>
                ))}
              </ol>
            </nav>
          )}

          <div class="prose">
            <Content />
          </div>

          <div class="article-cta">
            <h3>¿Necesita asesoría legal sobre este tema?</h3>
            <p>Nuestro equipo de abogados en CDMX puede orientarle con un diagnóstico profesional de su caso. La consulta inicial es gratuita.</p>
            <div style="display:flex;gap:12px;flex-wrap:wrap;">
              <a href="/asesoria-inicial" class="btn-primary-wrap">Solicitar asesoría gratuita →</a>
              <a href="tel:+525564655501" class="btn-secondary-wrap">Llamar al 55 6465 5501 →</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </article>

  <Footer slot="footer" />
</Base>

<style>
  .article-layout { max-width: 800px; margin: 0 auto; }
  .article-content { width: 100%; }

  .article-meta {
    display: flex; flex-wrap: wrap; align-items: center; gap: 16px;
    padding-bottom: 20px; margin-bottom: 32px;
    border-bottom: 1px solid var(--color-border);
    font-size: 14px; color: var(--color-paragraph);
  }
  .article-cat {
    background: var(--color-secondary); color: var(--color-white);
    padding: 3px 10px; font-weight: 600; font-size: 12px;
    text-transform: uppercase; letter-spacing: 1px;
  }
  .article-author { font-weight: 600; color: var(--color-primary); }

  .article-toc {
    background: var(--color-light); padding: 28px 32px; margin-bottom: 40px;
  }
  .article-toc__title { font-size: 18px; margin-bottom: 16px; }
  .article-toc__list { padding-left: 20px; }
  .article-toc__list li { margin-bottom: 8px; font-size: 15px; }
  .article-toc__list li a { color: var(--color-primary); }
  .article-toc__list li a:hover { color: var(--color-secondary); }
  .toc-sub { padding-left: 20px; font-size: 14px; }

  .prose {
    font-size: 17px; line-height: 1.85; color: #333;
  }
  .prose :global(h2) {
    font-size: 30px; margin-top: 48px; margin-bottom: 20px;
    color: var(--color-primary);
  }
  .prose :global(h3) {
    font-size: 22px; margin-top: 36px; margin-bottom: 16px;
    color: var(--color-primary);
  }
  .prose :global(p) { margin-bottom: 20px; }
  .prose :global(strong) { color: var(--color-primary); }
  .prose :global(a) { color: var(--color-secondary); text-decoration: underline; }
  .prose :global(ul), .prose :global(ol) {
    padding-left: 24px; margin-bottom: 20px;
  }
  .prose :global(li) { margin-bottom: 8px; }
  .prose :global(table) {
    width: 100%; border-collapse: collapse; margin: 24px 0;
    font-size: 15px;
  }
  .prose :global(th) {
    background: var(--color-primary); color: var(--color-white);
    padding: 12px 16px; text-align: left; font-weight: 600;
  }
  .prose :global(td) {
    padding: 12px 16px; border-bottom: 1px solid var(--color-border);
  }
  .prose :global(tr:nth-child(even)) { background: var(--color-light); }
  .prose :global(blockquote) {
    border-left: 4px solid var(--color-secondary);
    padding: 16px 24px; margin: 24px 0;
    background: var(--color-light); font-style: italic;
  }
  .prose :global(hr) {
    border: none; border-top: 1px solid var(--color-border);
    margin: 40px 0;
  }

  .article-cta {
    background: var(--color-primary); color: var(--color-white);
    padding: 40px; margin-top: 48px;
  }
  .article-cta h3 { color: var(--color-white); margin-bottom: 12px; }
  .article-cta p { color: rgba(255,255,255,.7); margin-bottom: 24px; font-size: 16px; }

  @media (max-width: 767px) {
    .prose { font-size: 16px; }
    .prose :global(h2) { font-size: 26px; }
    .prose :global(h3) { font-size: 20px; }
    .article-cta { padding: 28px 20px; }
    .article-toc { padding: 20px; }
  }
</style>
