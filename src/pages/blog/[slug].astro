---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import RelatedPosts from '../../components/RelatedPosts.astro';
import { getImageUrl, getImageAlt } from '../../data/blog-images';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await post.render();

const title = `${post.data.title} | Abogados en CDMX`;
const description = post.data.description;
const canonical = `https://abogadosencdmx.com/blog/${post.slug}`;
const publishedDate = post.data.date.toISOString();
const heroImage = getImageUrl(post.slug).replace('w=700&h=420', 'w=1200&h=600');
const heroAlt = getImageAlt(post.slug);

// Extract FAQ pairs from markdown body (## headings ending in ?)
const faqPairs: { question: string; answer: string }[] = [];
if (post.body) {
  const lines = post.body.split('\n');
  for (let i = 0; i < lines.length; i++) {
    const line = lines[i].trim();
    if (line.startsWith('## ') && line.endsWith('?')) {
      const question = line.replace(/^##\s+/, '').replace(/[¿?]/g, '').trim() + '?';
      // Collect answer lines until next heading or empty section
      let answer = '';
      for (let j = i + 1; j < lines.length; j++) {
        const nextLine = lines[j].trim();
        if (nextLine.startsWith('## ') || nextLine.startsWith('# ')) break;
        if (nextLine && !nextLine.startsWith('---')) {
          // Strip markdown formatting for schema
          const clean = nextLine
            .replace(/\*\*(.*?)\*\*/g, '$1')
            .replace(/\[(.*?)\]\(.*?\)/g, '$1')
            .replace(/[|`#>-]/g, '')
            .trim();
          if (clean) {
            answer += (answer ? ' ' : '') + clean;
          }
        }
      }
      if (answer.length > 20) {
        faqPairs.push({
          question: '¿' + question,
          answer: answer.substring(0, 500)
        });
      }
    }
  }
}

// Build @graph with Article + BreadcrumbList + FAQPage
const schemaGraph: any[] = [
  {
    "@type": "Article",
    "headline": post.data.title,
    "description": description,
    "image": heroImage,
    "url": canonical,
    "datePublished": publishedDate,
    "dateModified": publishedDate,
    "author": { "@type": "Person", "name": post.data.author },
    "publisher": {
      "@type": "LegalService",
      "name": "Abogados en CDMX",
      "url": "https://abogadosencdmx.com",
      "telephone": "+525564655501",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Guanajuato 224",
        "addressLocality": "Ciudad de México",
        "postalCode": "06700",
        "addressCountry": "MX"
      }
    },
    "mainEntityOfPage": canonical
  },
  {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://abogadosencdmx.com/" },
      { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://abogadosencdmx.com/blog" },
      { "@type": "ListItem", "position": 3, "name": post.data.title, "item": canonical }
    ]
  }
];

// Add FAQPage if we found FAQ pairs
if (faqPairs.length >= 2) {
  schemaGraph.push({
    "@type": "FAQPage",
    "mainEntity": faqPairs.map(faq => ({
      "@type": "Question",
      "name": faq.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": faq.answer
      }
    }))
  });
}

const schema = {
  "@context": "https://schema.org",
  "@graph": schemaGraph
};

// Build TOC from headings
const toc = headings.filter((h) => [2, 3].includes(h.depth));

// Format date
const dateObj = post.data.date;
const months = ['enero','febrero','marzo','abril','mayo','junio','julio','agosto','septiembre','octubre','noviembre','diciembre'];
const dateDisplay = `${dateObj.getDate()} de ${months[dateObj.getMonth()]} de ${dateObj.getFullYear()}`;

// Detect category from keywords
const keywords = post.data.keywords?.split(',').map((k: string) => k.trim().toLowerCase()) || [];
const catMap: Record<string, { label: string; color: string }> = {
  'familiar': { label: 'Derecho Familiar', color: '#c17f3e' },
  'penal': { label: 'Derecho Penal', color: '#8b1a1a' },
  'civil': { label: 'Derecho Civil', color: '#2d5f8a' },
  'corporativo': { label: 'Derecho Corporativo', color: '#1a5c3a' },
  'inmobiliario': { label: 'Derecho Inmobiliario', color: '#6b4c9a' },
  'migratorio': { label: 'Derecho Migratorio', color: '#2e7d6f' },
  'laboral': { label: 'Derecho Laboral', color: '#c4731b' },
};
const catDetect: Record<string, string[]> = {
  'familiar': ['divorcio','custodia','pension','matrimonio','adopcion','familiar','conyugal','guarda','patria','violencia domestica'],
  'penal': ['penal','delito','amparo','defensa','detenido','narcomenudeo','robo','fraude','penalista','antecedentes'],
  'civil': ['civil','contrato','sucesion','herencia','usucapion','demanda civil','responsabilidad','profeco','consumidor','embargo','mediacion civil','prescripcion','interdiccion','tutela','cobro','deuda'],
  'corporativo': ['empresa','corporativo','sociedad','mercantil','startup','compliance','franquicia','propiedad intelectual','marca','sa de cv','srl','sas','constituir','disolucion','datos personales'],
  'inmobiliario': ['inmobiliario','inmueble','propiedad','arrendamiento','inquilino','escritura','compraventa','hipoteca','infonavit','fideicomiso','avaluo','condomin'],
  'migratorio': ['migratorio','migracion','visa','residencia','inm','extranjero','naturalizacion','deportacion','asilo','refugio','nacionalidad'],
  'laboral': ['laboral','trabajo','despido','liquidacion','sindicato','outsourcing','subcontratacion','jornada','horas extra','home office','teletrabajo','mobbing','acoso laboral','contrato trabajo','accidente trabajo'],
};
let detectedCat = 'general';
for (const [cat, catKws] of Object.entries(catDetect)) {
  if (keywords.some(kw => catKws.some(ck => kw.includes(ck) || ck.includes(kw)))) {
    detectedCat = cat;
    break;
  }
}
const catInfo = catMap[detectedCat] || { label: 'Derecho', color: '#001d3d' };

// Estimate reading time
const wordCount = post.body?.split(/\s+/).length || 0;
const readingTime = Math.max(1, Math.ceil(wordCount / 200));
---

<Base title={title} description={description} canonical={canonical} schema={schema} publishedDate={publishedDate} modifiedDate={publishedDate} author={post.data.author} ogImage={heroImage}>
  <Header slot="header" />

  <!-- ═══ HERO ═══ -->
  <section class="post-hero">
    <img src={heroImage} alt={heroAlt} class="post-hero__bg" width="1200" height="600" loading="eager" fetchpriority="high" />
    <div class="post-hero__overlay"></div>
    <div class="post-hero__content container">
      <div class="post-hero__breadcrumb">
        <a href="/">Inicio</a>
        <span class="post-hero__sep">/</span>
        <a href="/blog">Blog</a>
        <span class="post-hero__sep">/</span>
        <span>{post.data.title.length > 50 ? post.data.title.substring(0, 50) + '...' : post.data.title}</span>
      </div>
      <div class="post-hero__meta">
        <span class="post-hero__badge" style={`background:${catInfo.color}`}>{catInfo.label}</span>
        <span class="post-hero__dot">·</span>
        <time datetime={publishedDate}>{dateDisplay}</time>
        <span class="post-hero__dot">·</span>
        <span>{readingTime} min de lectura</span>
      </div>
      <h1 class="post-hero__title">{post.data.title}</h1>
      <div class="post-hero__author">
        <div class="post-hero__avatar">{post.data.author.split(' ').slice(-2).map((n: string) => n[0]).join('')}</div>
        <div class="post-hero__author-info">
          <span class="post-hero__author-name">{post.data.author}</span>
          <span class="post-hero__author-role">Abogados en CDMX</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ ARTICLE BODY ═══ -->
  <article class="section-padding">
    <div class="container">
      <div class="article-layout">
        <div class="article-content">

          {toc.length > 3 && (() => {
            // Separate main sections (H2) from sub-items (H3)
            const mainSections = toc.filter(h => h.depth === 2);
            // Group: find FAQ-like headings vs content headings
            const faqPattern = /^\u00bf|^¿|pregunt|frecuent|también.*interesar/i;
            const contentHeadings = mainSections.filter(h => !faqPattern.test(h.text));
            const faqHeadings = mainSections.filter(h => faqPattern.test(h.text));
            let counter = 0;

            return (
              <nav class="article-toc" aria-label="Tabla de contenidos" itemscope itemtype="https://schema.org/SiteNavigationElement">
                <div class="toc-header">
                  <div class="toc-header__icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
                  </div>
                  <div>
                    <h2 class="toc-header__title">Contenido del artículo</h2>
                    <span class="toc-header__count">{mainSections.length} secciones · {readingTime} min de lectura</span>
                  </div>
                </div>

                {contentHeadings.length > 0 && (
                  <div class="toc-group">
                    <ol class="toc-list">
                      {contentHeadings.map((h) => {
                        counter++;
                        const subItems = toc.filter(sub => sub.depth === 3 && (() => {
                          const hIdx = toc.indexOf(h);
                          const subIdx = toc.indexOf(sub);
                          const nextH2Idx = toc.findIndex((t, i) => i > hIdx && t.depth === 2);
                          return subIdx > hIdx && (nextH2Idx === -1 || subIdx < nextH2Idx);
                        })());
                        return (
                          <li class="toc-item" itemprop="name">
                            <a href={`#${h.slug}`} class="toc-link" itemprop="url">
                              <span class="toc-number">{String(counter).padStart(2, '0')}</span>
                              <span class="toc-text">{h.text}</span>
                            </a>
                            {subItems.length > 0 && (
                              <ul class="toc-sublist">
                                {subItems.map((sub) => (
                                  <li class="toc-subitem">
                                    <a href={`#${sub.slug}`} class="toc-sublink">
                                      <span class="toc-subdash">—</span>
                                      {sub.text}
                                    </a>
                                  </li>
                                ))}
                              </ul>
                            )}
                          </li>
                        );
                      })}
                    </ol>
                  </div>
                )}

                {faqHeadings.length > 0 && (
                  <div class="toc-faq-group">
                    <div class="toc-faq-label">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 015.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                      Preguntas frecuentes
                    </div>
                    <ul class="toc-faq-list">
                      {faqHeadings.map((h) => (
                        <li>
                          <a href={`#${h.slug}`} class="toc-faq-link">{h.text}</a>
                        </li>
                      ))}
                    </ul>
                  </div>
                )}
              </nav>
            );
          })()}

          <div class="prose">
            <Content />
          </div>

          <div class="article-cta">
            <div class="cta-badge">Consulta inicial sin costo</div>
            <h3>¿Su caso necesita atención legal?</h3>
            <p>Hable directamente con un abogado especialista. Evaluamos su situación, le explicamos sus opciones y le damos un presupuesto transparente — todo en una sola llamada.</p>
            <div class="cta-buttons">
              <a href="/asesoria-inicial" class="cta-main">
                <span class="cta-main__text">Agendar consulta gratuita</span>
                <span class="cta-main__sub">Respuesta en menos de 2 horas</span>
              </a>
              <a href="tel:+525564655501" class="cta-phone">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M19.95 21q-3.125 0-6.175-1.362t-5.55-3.863q-2.5-2.5-3.862-5.55T3 4.05q0-.45.3-.75T4.05 3H8.1q.35 0 .625.238t.325.562l.65 3.5q.05.4-.025.675T9.4 8.45L6.975 10.9q.5.925 1.187 1.787t1.513 1.663q.775.775 1.625 1.438T13.1 17l2.35-2.35q.225-.225.588-.337t.712-.063l3.45.7q.35.1.575.363T21 15.9v4.05q0 .45-.3.75t-.75.3z"/></svg>
                <div>
                  <span class="cta-phone__number">55 6465 5501</span>
                  <span class="cta-phone__hours">L-V 9:00 – 18:00</span>
                </div>
              </a>
              <a href="https://wa.me/525564655501?text=Hola%2C%20necesito%20asesor%C3%ADa%20legal" class="cta-whatsapp" target="_blank" rel="noopener">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                WhatsApp
              </a>
            </div>
          </div>

          <RelatedPosts currentSlug={post.slug} currentKeywords={post.data.keywords || ''} />
        </div>
      </div>
    </div>
  </article>

  <Footer slot="footer" />
</Base>

<style>
  /* ═══ HERO ═══ */
  .post-hero {
    position: relative;
    min-height: 480px;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    margin-top: calc(var(--topbar-h, 40px) + var(--header-h, 80px));
  }
  .post-hero__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }
  .post-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0, 15, 35, 0.92) 0%,
      rgba(0, 15, 35, 0.7) 40%,
      rgba(0, 15, 35, 0.35) 100%
    );
  }
  .post-hero__content {
    position: relative;
    z-index: 2;
    padding-top: 80px;
    padding-bottom: 48px;
    max-width: 900px;
  }

  /* Breadcrumb */
  .post-hero__breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: rgba(255,255,255,0.5);
    margin-bottom: 20px;
  }
  .post-hero__breadcrumb a {
    color: rgba(255,255,255,0.6);
    transition: color 0.2s;
  }
  .post-hero__breadcrumb a:hover {
    color: var(--color-secondary);
  }
  .post-hero__sep {
    color: rgba(255,255,255,0.3);
  }

  /* Meta */
  .post-hero__meta {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 20px;
    font-size: 13px;
    color: rgba(255,255,255,0.6);
    font-weight: 500;
  }
  .post-hero__badge {
    padding: 5px 14px;
    font-size: 11px;
    font-weight: 700;
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 1px;
  }
  .post-hero__dot {
    color: rgba(255,255,255,0.3);
  }

  /* Title */
  .post-hero__title {
    font-family: var(--font-heading);
    font-size: clamp(28px, 4vw, 44px);
    font-weight: 800;
    line-height: 1.15;
    color: #fff;
    margin-bottom: 28px;
    max-width: 800px;
  }

  /* Author */
  .post-hero__author {
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .post-hero__avatar {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--color-secondary);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 15px;
    letter-spacing: 0.5px;
    flex-shrink: 0;
  }
  .post-hero__author-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .post-hero__author-name {
    color: #fff;
    font-weight: 600;
    font-size: 15px;
  }
  .post-hero__author-role {
    color: rgba(255,255,255,0.45);
    font-size: 12px;
    font-weight: 500;
  }

  /* ═══ ARTICLE LAYOUT ═══ */
  .article-layout { max-width: 800px; margin: 0 auto; overflow: hidden; }
  .article-content { width: 100%; }

  /* ═══ TOC ═══ */
  .article-toc {
    background: #fff;
    border: 1px solid #e4e4e4;
    padding: 0;
    margin-bottom: 48px;
    overflow: hidden;
  }

  /* Header */
  .toc-header {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 20px 28px;
    background: var(--color-primary);
    color: #fff;
  }
  .toc-header__icon {
    width: 40px; height: 40px;
    display: flex; align-items: center; justify-content: center;
    border: 1.5px solid var(--color-secondary);
    flex-shrink: 0;
  }
  .toc-header__icon svg { color: var(--color-secondary); }
  .toc-header__title {
    font-size: 18px; font-weight: 700; color: #fff; margin: 0;
  }
  .toc-header__count {
    font-size: 12px; color: rgba(255,255,255,0.5); font-weight: 500;
  }

  /* Main list */
  .toc-group { padding: 24px 28px; }
  .toc-list {
    list-style: none; padding: 0; margin: 0;
    counter-reset: none;
  }
  .toc-item {
    border-bottom: 1px solid #f0f0f0;
  }
  .toc-item:last-child { border-bottom: none; }

  .toc-link {
    display: flex; align-items: flex-start; gap: 14px;
    padding: 14px 0;
    color: var(--color-primary);
    font-size: 15px; font-weight: 500;
    line-height: 1.4;
    transition: color 0.2s;
    text-decoration: none;
  }
  .toc-link:hover { color: var(--color-secondary); }
  .toc-link:hover .toc-number {
    background: var(--color-secondary); color: #fff;
  }

  .toc-number {
    display: flex; align-items: center; justify-content: center;
    min-width: 30px; height: 30px;
    background: var(--color-light);
    color: var(--color-primary);
    font-size: 12px; font-weight: 700;
    flex-shrink: 0;
    transition: all 0.2s;
    font-family: var(--font-heading);
  }
  .toc-text { padding-top: 4px; }

  /* Sub-items */
  .toc-sublist {
    list-style: none; padding: 0 0 8px 44px; margin: 0;
  }
  .toc-subitem { margin-bottom: 4px; }
  .toc-sublink {
    display: flex; align-items: center; gap: 8px;
    font-size: 13px; color: var(--color-paragraph);
    padding: 4px 0; transition: color 0.2s;
    text-decoration: none;
  }
  .toc-sublink:hover { color: var(--color-secondary); }
  .toc-subdash {
    color: var(--color-secondary); font-weight: 600;
    flex-shrink: 0;
  }

  /* FAQ section */
  .toc-faq-group {
    padding: 20px 28px;
    background: var(--color-light);
    border-top: 1px solid #e4e4e4;
  }
  .toc-faq-label {
    display: flex; align-items: center; gap: 8px;
    font-size: 12px; font-weight: 700;
    text-transform: uppercase; letter-spacing: 1px;
    color: var(--color-secondary);
    margin-bottom: 12px;
  }
  .toc-faq-label svg { flex-shrink: 0; }
  .toc-faq-list {
    list-style: none; padding: 0; margin: 0;
    display: grid; grid-template-columns: 1fr 1fr; gap: 6px 20px;
  }
  .toc-faq-link {
    font-size: 13px; color: var(--color-primary);
    padding: 6px 0; display: block;
    line-height: 1.35; transition: color 0.2s;
    text-decoration: none;
  }
  .toc-faq-link:hover { color: var(--color-secondary); }
  .toc-faq-link::before {
    content: '→ '; color: var(--color-secondary);
    font-weight: 600;
  }

  /* ═══ PROSE ═══ */
  .prose {
    font-size: 17px; line-height: 1.85; color: #333;
  }
  .prose :global(h2) {
    font-size: 30px; margin-top: 48px; margin-bottom: 20px;
    color: var(--color-primary);
  }
  .prose :global(h3) {
    font-size: 22px; margin-top: 36px; margin-bottom: 16px;
    color: var(--color-primary);
  }
  .prose :global(p) { margin-bottom: 20px; }
  .prose :global(strong) { color: var(--color-primary); }
  .prose :global(a) { color: var(--color-secondary); text-decoration: underline; }
  .prose :global(ul), .prose :global(ol) {
    padding-left: 24px; margin-bottom: 20px;
  }
  .prose :global(li) { margin-bottom: 8px; }
  .prose :global(table) {
