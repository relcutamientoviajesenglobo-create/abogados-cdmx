---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = 'Abogados en la Condesa, CDMX — Despacho Jurídico Cerca de Condesa e Hipódromo | Abogados en CDMX';
const description = 'Abogados cerca de la Condesa e Hipódromo, CDMX. Despacho jurídico a 5 minutos de la Condesa especializado en derecho familiar, civil, penal, corporativo, inmobiliario, migratorio y laboral.';
const canonical = 'https://abogadosencdmx.com/abogados-condesa-cdmx';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LegalService",
      "name": "Abogados Cerca de la Condesa, CDMX",
      "description": "Despacho jurídico que atiende a clientes de la Condesa, Hipódromo e Hipódromo Condesa en la Alcaldía Cuauhtémoc, CDMX. Oficina en Roma Norte a 5 minutos.",
      "url": "https://abogadosencdmx.com/abogados-condesa-cdmx",
      "telephone": "+525564655501",
      "email": "contacto@abogadosencdmx.com",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Guanajuato 224",
        "addressLocality": "Ciudad de México",
        "addressRegion": "CDMX",
        "postalCode": "06700",
        "addressCountry": "MX",
        "name": "Colonia Roma Norte, Alcaldía Cuauhtémoc"
      },
      "geo": { "@type": "GeoCoordinates", "latitude": 19.4130, "longitude": -99.1712 },
      "areaServed": {
        "@type": "Place",
        "name": "Condesa e Hipódromo, Alcaldía Cuauhtémoc, Ciudad de México",
        "geo": { "@type": "GeoCoordinates", "latitude": 19.4130, "longitude": -99.1712 }
      },
      "openingHoursSpecification": { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"], "opens": "09:00", "closes": "18:00" },
      "priceRange": "$$"
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://abogadosencdmx.com/" },
        { "@type": "ListItem", "position": 2, "name": "Abogados en Condesa", "item": "https://abogadosencdmx.com/abogados-condesa-cdmx" }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "¿Hay abogados cerca de la Condesa en CDMX?",
          "acceptedAnswer": { "@type": "Answer", "text": "Sí. Nuestro despacho en Roma Norte está a solo 5 minutos caminando de la Condesa. Las colonias Roma Norte y Condesa son colindantes, por lo que llegar a nuestra oficina en Guanajuato 224 es muy accesible." }
        },
        {
          "@type": "Question",
          "name": "¿Qué servicios legales ofrecen para la zona Condesa-Roma?",
          "acceptedAnswer": { "@type": "Answer", "text": "Atendemos derecho familiar, penal, civil, corporativo, inmobiliario, migratorio y laboral. Los clientes de la Condesa nos buscan frecuentemente por contratos de arrendamiento comercial, constitución de negocios gastronómicos, trámites migratorios y asuntos familiares." }
        },
        {
          "@type": "Question",
          "name": "¿Cómo llego desde la Condesa al despacho?",
          "acceptedAnswer": { "@type": "Answer", "text": "Desde el Parque México, camine hacia el oriente por la calle Michoacán o Tamaulipas hasta cruzar Avenida Insurgentes. Continúe por Guanajuato hasta el número 224. Son solo 10 a 15 minutos a pie." }
        },
        {
          "@type": "Question",
          "name": "¿Manejan contratos para restaurantes y negocios en la Condesa?",
          "acceptedAnswer": { "@type": "Answer", "text": "Sí. Asesoramos a negocios de la zona Condesa-Roma en constitución de sociedades, contratos de arrendamiento comercial, licencias de funcionamiento, trámites ante la alcaldía y compliance regulatorio para restaurantes, bares y comercios." }
        }
      ]
    }
  ]
};

const especialidades = [
  { nombre: 'Derecho Familiar', href: '/especialidades/derecho-familiar-cdmx', icono: '&#9825;', desc: 'Divorcios, custodia, pensión alimenticia y adopciones.' },
  { nombre: 'Derecho Penal', href: '/especialidades/derecho-penal-cdmx', icono: '&#9878;', desc: 'Defensa penal, amparos y delitos patrimoniales.' },
  { nombre: 'Derecho Civil', href: '/especialidades/derecho-civil-cdmx', icono: '&#9998;', desc: 'Contratos, responsabilidad civil y sucesiones.' },
  { nombre: 'Derecho Corporativo', href: '/especialidades/derecho-corporativo-cdmx', icono: '&#9881;', desc: 'Constitución de empresas, compliance y gobierno corporativo.' },
  { nombre: 'Derecho Inmobiliario', href: '/especialidades/derecho-inmobiliario-cdmx', icono: '&#8962;', desc: 'Compraventa, escrituración y arrendamiento.' },
  { nombre: 'Derecho Migratorio', href: '/especialidades/derecho-migratorio-cdmx', icono: '&#9992;', desc: 'Visas, residencia temporal y permanente, naturalización.' },
  { nombre: 'Derecho Laboral', href: '/especialidades/derecho-laboral-cdmx', icono: '&#9874;', desc: 'Despidos injustificados, liquidaciones y demandas laborales.' },
];
---

<Base title={title} description={description} canonical={canonical} schema={schema}>
  <Header slot="header" />

  <section class="loc-hero">
    <div class="loc-container">
      <nav class="loc-breadcrumb" aria-label="Breadcrumb">
        <a href="/">Inicio</a> &rsaquo; <span>Abogados en Condesa</span>
      </nav>
      <span class="loc-badge">Despacho jur&iacute;dico a 5 minutos de la Condesa</span>
      <h1>Abogados en la Condesa, Ciudad de M&eacute;xico</h1>
      <p class="loc-hero-desc">Nuestro despacho en la Roma Norte colinda con la Condesa e Hip&oacute;dromo. Camine desde el Parque M&eacute;xico hasta nuestra oficina en minutos. Especialistas en derecho corporativo para negocios de la zona, derecho inmobiliario, familiar y las 7 &aacute;reas de pr&aacute;ctica legal.</p>
    </div>
  </section>

  <section class="loc-section">
    <div class="loc-container">
      <h2>Servicios legales para la Condesa, Hip&oacute;dromo e Hip&oacute;dromo Condesa</h2>
      <p>La Condesa es una de las zonas m&aacute;s din&aacute;micas de la Ciudad de M&eacute;xico: combina residencias, restaurantes, comercios y oficinas creativas en un entorno patrimonial art déco. Esta mezcla genera necesidades jur&iacute;dicas espec&iacute;ficas que conocemos bien por nuestra cercan&iacute;a. Asesoramos a propietarios de negocios gastron&oacute;micos en la constituci&oacute;n de sociedades y contratos de arrendamiento, a residentes en compraventa de departamentos y tr&aacute;mites sucesorios, y a extranjeros de la comunidad internacional que vive en la zona en asuntos migratorios y de derecho familiar.</p>
      <p>Al estar en la misma Alcald&iacute;a Cuauht&eacute;moc, los tr&aacute;mites administrativos, registrales y judiciales de nuestros clientes de la Condesa se gestionan en las mismas instancias que utilizamos cotidianamente. Esto agiliza los tiempos de resoluci&oacute;n y reduce costos de traslado.</p>
    </div>
  </section>

  <section class="loc-section loc-section--alt">
    <div class="loc-container">
      <h2>C&oacute;mo llegar desde la Condesa a nuestro despacho</h2>
      <p>Nuestra oficina est&aacute; en <strong>Guanajuato 224, Colonia Roma Norte</strong>, a solo unas cuadras del l&iacute;mite entre la Condesa y la Roma Norte.</p>
      <div class="loc-directions">
        <div class="loc-dir-card">
          <h3>Caminando</h3>
          <p>Desde el <strong>Parque M&eacute;xico</strong>, camine por <strong>Michoac&aacute;n</strong> o <strong>Tamaulipas</strong> hacia el oriente. Cruce <strong>Avenida Insurgentes</strong> y contin&uacute;e por Guanajuato hasta el n&uacute;mero 224. Son <strong>10 a 15 minutos a pie</strong>.</p>
        </div>
        <div class="loc-dir-card">
          <h3>En Metro</h3>
          <p>La estaci&oacute;n <strong>Chilpancingo (L&iacute;nea 9)</strong> est&aacute; en el coraz&oacute;n de la Condesa. Desde ah&iacute;, camine 12 minutos al oriente hasta Guanajuato 224. Tambi&eacute;n puede usar <strong>Insurgentes (L&iacute;nea 1)</strong> a 8 minutos.</p>
        </div>
        <div class="loc-dir-card">
          <h3>En Metrob&uacute;s</h3>
          <p>La estaci&oacute;n <strong>Sonora (L&iacute;nea 1)</strong> queda a 3 cuadras de nuestra oficina y a menos de 10 minutos de la Condesa. Es la opci&oacute;n m&aacute;s r&aacute;pida en transporte p&uacute;blico.</p>
        </div>
      </div>
      <p class="loc-landmarks"><strong>Referencias:</strong> A 10 minutos del Parque M&eacute;xico, a 12 minutos de la Glorieta de la Cibeles y a 5 minutos del Mercado Roma.</p>
    </div>
  </section>

  <section class="loc-section">
    <div class="loc-container">
      <h2>&Aacute;reas del derecho para clientes de la Condesa</h2>
      <div class="loc-specs-grid">
        {especialidades.map(e => (
          <a href={e.href} class="loc-spec-card">
            <span class="loc-spec-icon" set:html={e.icono} />
            <h3>{e.nombre}</h3>
            <p>{e.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="loc-section loc-section--alt">
    <div class="loc-container">
      <div class="loc-testimonial">
        <blockquote>
          <p>&ldquo;Abr&iacute; un restaurante en la Condesa y necesitaba constituir la sociedad, negociar el contrato de arrendamiento y tramitar las licencias. El despacho est&aacute; a pocas cuadras y me resolvieron todo r&aacute;pido. Ahora tambi&eacute;n llevan mis contratos laborales. Muy recomendable para negocios de la zona.&rdquo;</p>
          <cite>&mdash; Andr&eacute;s Salazar, Colonia Hip&oacute;dromo Condesa</cite>
        </blockquote>
      </div>
    </div>
  </section>

  <section class="loc-section">
    <div class="loc-container">
      <h2>Preguntas frecuentes — Abogados cerca de la Condesa</h2>
      <div class="loc-faq">
        <details>
          <summary>&iquest;Hay abogados cerca de la Condesa en CDMX?</summary>
          <p>S&iacute;. Nuestro despacho en Roma Norte est&aacute; a solo 5 minutos caminando de la Condesa. Las colonias Roma Norte y Condesa son colindantes, por lo que llegar a nuestra oficina en Guanajuato 224 es muy f&aacute;cil.</p>
        </details>
        <details>
          <summary>&iquest;Qu&eacute; servicios legales ofrecen para la zona Condesa-Roma?</summary>
          <p>Atendemos derecho familiar, penal, civil, corporativo, inmobiliario, migratorio y laboral. Los clientes de la Condesa nos buscan frecuentemente por contratos de arrendamiento comercial, constituci&oacute;n de negocios gastron&oacute;micos y tr&aacute;mites migratorios.</p>
        </details>
        <details>
          <summary>&iquest;C&oacute;mo llego caminando desde la Condesa?</summary>
          <p>Desde el Parque M&eacute;xico, camine hacia el oriente por Michoac&aacute;n o Tamaulipas, cruce Insurgentes y siga por Guanajuato. Son 10 a 15 minutos a pie.</p>
        </details>
        <details>
          <summary>&iquest;Manejan contratos para restaurantes y bares de la Condesa?</summary>
          <p>S&iacute;. Asesoramos a negocios de la zona en constituci&oacute;n de sociedades, contratos de arrendamiento comercial, licencias de funcionamiento y compliance regulatorio para restaurantes, bares y comercios.</p>
        </details>
      </div>
    </div>
  </section>

  <section class="loc-cta">
    <div class="loc-container">
      <h2>Agende su consulta gratuita desde la Condesa</h2>
      <p>Estamos a minutos de la Condesa. Ll&aacute;menos, escr&iacute;banos o agende en l&iacute;nea.</p>
      <div class="loc-cta-buttons">
        <a href="tel:+525564655501" class="loc-btn loc-btn--primary">Llamar: 55 6465 5501</a>
        <a href="https://wa.me/525564655501?text=Hola%2C%20soy%20de%20la%20Condesa%20y%20quiero%20agendar%20una%20consulta%20legal" class="loc-btn loc-btn--whatsapp">WhatsApp</a>
        <a href="/asesoria-inicial" class="loc-btn loc-btn--outline">Asesor&iacute;a inicial gratuita</a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Base>

<style>
  .loc-hero{background:#1a1f3d;color:#fff;padding:80px 0 60px;text-align:center}
  .loc-hero h1{font-size:clamp(1.8rem,4vw,2.8rem);margin:16px 0;line-height:1.2}
  .loc-hero-desc{max-width:700px;margin:0 auto;font-size:1.1rem;opacity:.9;line-height:1.7}
  .loc-container{max-width:1100px;margin:0 auto;padding:0 20px}
  .loc-breadcrumb{font-size:.9rem;margin-bottom:16px;opacity:.7}
  .loc-breadcrumb a{color:#c9a84c;text-decoration:none}
  .loc-badge{display:inline-block;background:#c9a84c;color:#1a1f3d;padding:6px 18px;border-radius:50px;font-size:.85rem;font-weight:600;margin-bottom:10px}
  .loc-section{padding:60px 0}
  .loc-section--alt{background:#f8f7f4}
  .loc-section h2{font-size:clamp(1.4rem,3vw,2rem);color:#1a1f3d;margin-bottom:20px}
  .loc-section p{line-height:1.8;color:#333;max-width:800px;margin-bottom:16px}
  .loc-directions{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:24px;margin-top:30px}
  .loc-dir-card{background:#fff;border:1px solid #e8e6e1;border-radius:12px;padding:28px;box-shadow:0 2px 8px rgba(0,0,0,.04)}
  .loc-dir-card h3{color:#1a1f3d;margin-bottom:10px;font-size:1.1rem}
  .loc-dir-card p{font-size:.95rem;margin:0}
  .loc-landmarks{margin-top:24px;padding:16px 20px;background:#fff;border-left:4px solid #c9a84c;border-radius:0 8px 8px 0;font-size:.95rem}
  .loc-specs-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(250px,1fr));gap:20px;margin-top:30px}
  .loc-spec-card{display:block;background:#fff;border:1px solid #e8e6e1;border-radius:12px;padding:24px;text-decoration:none;transition:box-shadow .2s,border-color .2s}
  .loc-spec-card:hover{box-shadow:0 4px 16px rgba(0,0,0,.08);border-color:#c9a84c}
  .loc-spec-icon{font-size:1.6rem;display:block;margin-bottom:8px}
  .loc-spec-card h3{color:#1a1f3d;font-size:1rem;margin-bottom:6px}
  .loc-spec-card p{color:#555;font-size:.9rem;margin:0;line-height:1.5}
  .loc-testimonial{max-width:700px;margin:0 auto;text-align:center}
  .loc-testimonial blockquote{border:none;margin:0;padding:0}
  .loc-testimonial p{font-size:1.15rem;font-style:italic;color:#1a1f3d;line-height:1.8}
  .loc-testimonial cite{display:block;margin-top:16px;font-size:.95rem;color:#666;font-style:normal}
  .loc-faq{max-width:800px;margin-top:24px}
  .loc-faq details{border:1px solid #e8e6e1;border-radius:10px;margin-bottom:12px;overflow:hidden}
  .loc-faq summary{padding:18px 24px;cursor:pointer;font-weight:600;color:#1a1f3d;background:#fff;font-size:1rem;list-style:none}
  .loc-faq summary::-webkit-details-marker{display:none}
  .loc-faq summary::before{content:'+ ';color:#c9a84c;font-weight:700}
  .loc-faq details[open] summary::before{content:'- '}
  .loc-faq details p{padding:0 24px 18px;margin:0;color:#444;line-height:1.7;font-size:.95rem}
  .loc-cta{background:#1a1f3d;color:#fff;padding:60px 0;text-align:center}
  .loc-cta h2{color:#fff;margin-bottom:12px;font-size:clamp(1.4rem,3vw,2rem)}
  .loc-cta p{color:rgba(255,255,255,.85);max-width:600px;margin:0 auto 28px}
  .loc-cta-buttons{display:flex;flex-wrap:wrap;gap:14px;justify-content:center}
  .loc-btn{display:inline-block;padding:14px 28px;border-radius:8px;font-weight:600;text-decoration:none;font-size:1rem;transition:opacity .2s}
  .loc-btn:hover{opacity:.9}
  .loc-btn--primary{background:#c9a84c;color:#1a1f3d}
  .loc-btn--whatsapp{background:#25d366;color:#fff}
  .loc-btn--outline{border:2px solid #fff;color:#fff;background:transparent}
  @media(max-width:600px){.loc-hero{padding:60px 0 40px}.loc-section{padding:40px 0}.loc-cta{padding:40px 0}.loc-cta-buttons{flex-direction:column;align-items:center}}
</style>
