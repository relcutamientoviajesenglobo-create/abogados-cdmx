---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = 'Abogados en Coyoacán, CDMX — Despacho Jurídico Cerca de Coyoacán | Abogados en CDMX';
const description = 'Abogados cerca de Coyoacán, CDMX. Despacho jurídico a 20 minutos de Coyoacán especializado en derecho familiar, civil, penal, corporativo, inmobiliario, migratorio y laboral.';
const canonical = 'https://abogadosencdmx.com/abogados-coyoacan-cdmx';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LegalService",
      "name": "Abogados Cerca de Coyoacán, CDMX",
      "description": "Despacho jurídico que atiende a clientes de Coyoacán, CDMX. Oficina en Roma Norte a 20 minutos de Coyoacán por Avenida Insurgentes.",
      "url": "https://abogadosencdmx.com/abogados-coyoacan-cdmx",
      "telephone": "+525564655501",
      "email": "contacto@abogadosencdmx.com",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Guanajuato 224",
        "addressLocality": "Ciudad de México",
        "addressRegion": "CDMX",
        "postalCode": "06700",
        "addressCountry": "MX",
        "name": "Colonia Roma Norte, Alcaldía Cuauhtémoc"
      },
      "geo": { "@type": "GeoCoordinates", "latitude": 19.3505, "longitude": -99.1617 },
      "areaServed": {
        "@type": "Place",
        "name": "Coyoacán, Ciudad de México",
        "geo": { "@type": "GeoCoordinates", "latitude": 19.3505, "longitude": -99.1617 }
      },
      "openingHoursSpecification": { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"], "opens": "09:00", "closes": "18:00" },
      "priceRange": "$$"
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://abogadosencdmx.com/" },
        { "@type": "ListItem", "position": 2, "name": "Abogados en Coyoacán", "item": "https://abogadosencdmx.com/abogados-coyoacan-cdmx" }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "¿Hay abogados que atiendan casos de Coyoacán?",
          "acceptedAnswer": { "@type": "Answer", "text": "Sí. Nuestro despacho en Roma Norte atiende a clientes de Coyoacán, Del Valle, Ciudad Universitaria y colonias aledañas. Estamos a 20 minutos por Insurgentes Sur y conectados por el Metrobús Línea 1." }
        },
        {
          "@type": "Question",
          "name": "¿Qué tipos de casos manejan para residentes de Coyoacán?",
          "acceptedAnswer": { "@type": "Answer", "text": "Atendemos asuntos de derecho familiar, civil, penal, corporativo, inmobiliario, migratorio y laboral. Los casos más frecuentes de clientes de Coyoacán incluyen sucesiones, compraventa de inmuebles patrimoniales, divorcios y trámites migratorios ligados a la UNAM." }
        },
        {
          "@type": "Question",
          "name": "¿Cómo llego desde Coyoacán al despacho?",
          "acceptedAnswer": { "@type": "Answer", "text": "Tome Avenida Insurgentes Norte desde Coyoacán. En Metrobús, aborde en la estación Doctor Gálvez o Bombilla (Línea 1) hasta la estación Sonora, a 3 cuadras de nuestro despacho. El trayecto es de aproximadamente 25 minutos." }
        },
        {
          "@type": "Question",
          "name": "¿Atienden asuntos legales relacionados con la UNAM?",
          "acceptedAnswer": { "@type": "Answer", "text": "Sí. Asesoramos a profesores, investigadores y personal administrativo de la UNAM en asuntos laborales, migratorios (para académicos extranjeros) y de derecho civil. También atendemos conflictos de arrendamiento en colonias cercanas a Ciudad Universitaria." }
        }
      ]
    }
  ]
};

const especialidades = [
  { nombre: 'Derecho Familiar', href: '/especialidades/derecho-familiar-cdmx', icono: '&#9825;', desc: 'Divorcios, custodia, pensión alimenticia y adopciones.' },
  { nombre: 'Derecho Penal', href: '/especialidades/derecho-penal-cdmx', icono: '&#9878;', desc: 'Defensa penal, amparos y delitos patrimoniales.' },
  { nombre: 'Derecho Civil', href: '/especialidades/derecho-civil-cdmx', icono: '&#9998;', desc: 'Contratos, responsabilidad civil y sucesiones.' },
  { nombre: 'Derecho Corporativo', href: '/especialidades/derecho-corporativo-cdmx', icono: '&#9881;', desc: 'Constitución de empresas, compliance y gobierno corporativo.' },
  { nombre: 'Derecho Inmobiliario', href: '/especialidades/derecho-inmobiliario-cdmx', icono: '&#8962;', desc: 'Compraventa, escrituración y arrendamiento.' },
  { nombre: 'Derecho Migratorio', href: '/especialidades/derecho-migratorio-cdmx', icono: '&#9992;', desc: 'Visas, residencia temporal y permanente, naturalización.' },
  { nombre: 'Derecho Laboral', href: '/especialidades/derecho-laboral-cdmx', icono: '&#9874;', desc: 'Despidos injustificados, liquidaciones y demandas laborales.' },
];
---

<Base title={title} description={description} canonical={canonical} schema={schema}>
  <Header slot="header" />

  <section class="loc-hero">
    <div class="loc-container">
      <nav class="loc-breadcrumb" aria-label="Breadcrumb">
        <a href="/">Inicio</a> &rsaquo; <span>Abogados en Coyoac&aacute;n</span>
      </nav>
      <span class="loc-badge">Despacho jur&iacute;dico a 20 minutos de Coyoac&aacute;n</span>
      <h1>Abogados en Coyoac&aacute;n, Ciudad de M&eacute;xico</h1>
      <p class="loc-hero-desc">Atendemos a clientes de Coyoac&aacute;n, Del Valle, Ciudad Universitaria y la zona sur de la CDMX desde nuestra oficina en la Colonia Roma Norte. Conectados directamente por Insurgentes y el Metrob&uacute;s L&iacute;nea 1.</p>
    </div>
  </section>

  <section class="loc-section">
    <div class="loc-container">
      <h2>Servicios legales para Coyoac&aacute;n y zona sur de CDMX</h2>
      <p>Coyoac&aacute;n es una de las alcald&iacute;as con mayor patrimonio hist&oacute;rico y cultural de la Ciudad de M&eacute;xico. Sus colonias como el Centro de Coyoac&aacute;n, Barrio de la Concepci&oacute;n, Del Carmen, Churubusco y las zonas cercanas a Ciudad Universitaria generan necesidades jur&iacute;dicas particulares: sucesiones de inmuebles patrimoniales, regularizaci&oacute;n de predios, conflictos de arrendamiento, tr&aacute;mites migratorios para acad&eacute;micos extranjeros y asuntos de derecho familiar.</p>
      <p>Nuestro equipo ha atendido m&uacute;ltiples casos de clientes de Coyoac&aacute;n, incluyendo sucesiones complejas de inmuebles catalogados, divorcios, custodia de hijos, defensa penal y asuntos corporativos para negocios de la zona gastron&oacute;mica y cultural de la alcald&iacute;a. La conexi&oacute;n directa por Avenida Insurgentes hace que el traslado a nuestra oficina sea r&aacute;pido y conveniente.</p>
    </div>
  </section>

  <section class="loc-section loc-section--alt">
    <div class="loc-container">
      <h2>C&oacute;mo llegar desde Coyoac&aacute;n a nuestro despacho</h2>
      <p>Nuestra oficina est&aacute; en <strong>Guanajuato 224, Colonia Roma Norte</strong>, a aproximadamente 20 minutos de Coyoac&aacute;n por Avenida Insurgentes Sur.</p>
      <div class="loc-directions">
        <div class="loc-dir-card">
          <h3>En Metrob&uacute;s</h3>
          <p>Aborde en la estaci&oacute;n <strong>Doctor G&aacute;lvez</strong> o <strong>Bombilla</strong> (L&iacute;nea 1 del Metrob&uacute;s) y baje en la estaci&oacute;n <strong>Sonora</strong>. Desde ah&iacute;, camine 3 cuadras por Guanajuato. Tiempo: 25 minutos aproximadamente.</p>
        </div>
        <div class="loc-dir-card">
          <h3>En Metro</h3>
          <p>Desde <strong>Coyoac&aacute;n (L&iacute;nea 3)</strong>, viaje hasta <strong>Centro M&eacute;dico</strong> y transborde a la <strong>L&iacute;nea 9</strong> hasta <strong>Chilpancingo</strong>, o contin&uacute;e a <strong>Balderas</strong> y transborde a la <strong>L&iacute;nea 1</strong> hasta <strong>Insurgentes</strong>.</p>
        </div>
        <div class="loc-dir-card">
          <h3>En auto</h3>
          <p>Tome <strong>Avenida Insurgentes Sur</strong> hacia el norte. Pase Ciudad Universitaria, la Colonia Del Valle y contin&uacute;e hasta la calle Guanajuato en la Roma Norte. Trayecto de 20 a 35 minutos seg&uacute;n el tr&aacute;fico.</p>
        </div>
      </div>
      <p class="loc-landmarks"><strong>Referencias:</strong> Estamos a 20 minutos del Jard&iacute;n Centenario de Coyoac&aacute;n, a 15 minutos de la Casa Azul de Frida Kahlo y a 10 minutos de la Cineteca Nacional.</p>
    </div>
  </section>

  <section class="loc-section">
    <div class="loc-container">
      <h2>&Aacute;reas del derecho para clientes de Coyoac&aacute;n</h2>
      <div class="loc-specs-grid">
        {especialidades.map(e => (
          <a href={e.href} class="loc-spec-card">
            <span class="loc-spec-icon" set:html={e.icono} />
            <h3>{e.nombre}</h3>
            <p>{e.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="loc-section loc-section--alt">
    <div class="loc-container">
      <div class="loc-testimonial">
        <blockquote>
          <p>&ldquo;Hered&eacute; una casa en el centro de Coyoac&aacute;n y el tr&aacute;mite sucesorio se complic&oacute; por ser un inmueble catalogado. Los abogados del despacho conocen bien los procedimientos ante el INAH y lograron regularizar la propiedad. El Metrob&uacute;s me dejaba a unas cuadras de la oficina, muy accesible.&rdquo;</p>
          <cite>&mdash; Fernanda Garc&iacute;a, Barrio del Carmen, Coyoac&aacute;n</cite>
        </blockquote>
      </div>
    </div>
  </section>

  <section class="loc-section">
    <div class="loc-container">
      <h2>Preguntas frecuentes — Abogados cerca de Coyoac&aacute;n</h2>
      <div class="loc-faq">
        <details>
          <summary>&iquest;Hay abogados que atiendan casos de Coyoac&aacute;n?</summary>
          <p>S&iacute;. Nuestro despacho en Roma Norte atiende a clientes de Coyoac&aacute;n, Del Valle, Ciudad Universitaria y colonias aleda&ntilde;as. Estamos a 20 minutos por Insurgentes Sur y conectados por el Metrob&uacute;s L&iacute;nea 1.</p>
        </details>
        <details>
          <summary>&iquest;Qu&eacute; tipos de casos manejan para residentes de Coyoac&aacute;n?</summary>
          <p>Los casos m&aacute;s frecuentes de clientes de Coyoac&aacute;n incluyen sucesiones de inmuebles patrimoniales, compraventa de propiedades, divorcios, tr&aacute;mites migratorios vinculados a la UNAM y conflictos de arrendamiento.</p>
        </details>
        <details>
          <summary>&iquest;C&oacute;mo llego desde Coyoac&aacute;n al despacho?</summary>
          <p>Tome Insurgentes hacia el norte o el Metrob&uacute;s L&iacute;nea 1 desde Doctor G&aacute;lvez o Bombilla hasta la estaci&oacute;n Sonora. Desde ah&iacute;, camine 3 cuadras. El trayecto total es de unos 25 minutos.</p>
        </details>
        <details>
          <summary>&iquest;Atienden asuntos legales de la zona universitaria?</summary>
          <p>S&iacute;. Asesoramos a profesores, investigadores y personal de la UNAM en asuntos laborales, migratorios y civiles. Tambi&eacute;n atendemos conflictos de arrendamiento frecuentes en colonias cercanas a Ciudad Universitaria como Copilco y Pedregal.</p>
        </details>
      </div>
    </div>
  </section>

  <section class="loc-cta">
    <div class="loc-container">
      <h2>Agende su consulta gratuita desde Coyoac&aacute;n</h2>
      <p>Cont&aacute;ctenos por tel&eacute;fono, WhatsApp o solicite su asesor&iacute;a inicial en l&iacute;nea.</p>
      <div class="loc-cta-buttons">
        <a href="tel:+525564655501" class="loc-btn loc-btn--primary">Llamar: 55 6465 5501</a>
        <a href="https://wa.me/525564655501?text=Hola%2C%20soy%20de%20Coyoac%C3%A1n%20y%20quiero%20agendar%20una%20consulta%20legal" class="loc-btn loc-btn--whatsapp">WhatsApp</a>
        <a href="/asesoria-inicial" class="loc-btn loc-btn--outline">Asesor&iacute;a inicial gratuita</a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Base>

<style>
  .loc-hero{background:#1a1f3d;color:#fff;padding:80px 0 60px;text-align:center}
  .loc-hero h1{font-size:clamp(1.8rem,4vw,2.8rem);margin:16px 0;line-height:1.2}
  .loc-hero-desc{max-width:700px;margin:0 auto;font-size:1.1rem;opacity:.9;line-height:1.7}
  .loc-container{max-width:1100px;margin:0 auto;padding:0 20px}
  .loc-breadcrumb{font-size:.9rem;margin-bottom:16px;opacity:.7}
  .loc-breadcrumb a{color:#c9a84c;text-decoration:none}
  .loc-badge{display:inline-block;background:#c9a84c;color:#1a1f3d;padding:6px 18px;border-radius:50px;font-size:.85rem;font-weight:600;margin-bottom:10px}
  .loc-section{padding:60px 0}
  .loc-section--alt{background:#f8f7f4}
  .loc-section h2{font-size:clamp(1.4rem,3vw,2rem);color:#1a1f3d;margin-bottom:20px}
  .loc-section p{line-height:1.8;color:#333;max-width:800px;margin-bottom:16px}
  .loc-directions{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:24px;margin-top:30px}
  .loc-dir-card{background:#fff;border:1px solid #e8e6e1;border-radius:12px;padding:28px;box-shadow:0 2px 8px rgba(0,0,0,.04)}
  .loc-dir-card h3{color:#1a1f3d;margin-bottom:10px;font-size:1.1rem}
  .loc-dir-card p{font-size:.95rem;margin:0}
  .loc-landmarks{margin-top:24px;padding:16px 20px;background:#fff;border-left:4px solid #c9a84c;border-radius:0 8px 8px 0;font-size:.95rem}
  .loc-specs-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(250px,1fr));gap:20px;margin-top:30px}
  .loc-spec-card{display:block;background:#fff;border:1px solid #e8e6e1;border-radius:12px;padding:24px;text-decoration:none;transition:box-shadow .2s,border-color .2s}
  .loc-spec-card:hover{box-shadow:0 4px 16px rgba(0,0,0,.08);border-color:#c9a84c}
  .loc-spec-icon{font-size:1.6rem;display:block;margin-bottom:8px}
  .loc-spec-card h3{color:#1a1f3d;font-size:1rem;margin-bottom:6px}
  .loc-spec-card p{color:#555;font-size:.9rem;margin:0;line-height:1.5}
  .loc-testimonial{max-width:700px;margin:0 auto;text-align:center}
  .loc-testimonial blockquote{border:none;margin:0;padding:0}
  .loc-testimonial p{font-size:1.15rem;font-style:italic;color:#1a1f3d;line-height:1.8}
  .loc-testimonial cite{display:block;margin-top:16px;font-size:.95rem;color:#666;font-style:normal}
  .loc-faq{max-width:800px;margin-top:24px}
  .loc-faq details{border:1px solid #e8e6e1;border-radius:10px;margin-bottom:12px;overflow:hidden}
  .loc-faq summary{padding:18px 24px;cursor:pointer;font-weight:600;color:#1a1f3d;background:#fff;font-size:1rem;list-style:none}
  .loc-faq summary::-webkit-details-marker{display:none}
  .loc-faq summary::before{content:'+ ';color:#c9a84c;font-weight:700}
  .loc-faq details[open] summary::before{content:'- '}
  .loc-faq details p{padding:0 24px 18px;margin:0;color:#444;line-height:1.7;font-size:.95rem}
  .loc-cta{background:#1a1f3d;color:#fff;padding:60px 0;text-align:center}
  .loc-cta h2{color:#fff;margin-bottom:12px;font-size:clamp(1.4rem,3vw,2rem)}
  .loc-cta p{color:rgba(255,255,255,.85);max-width:600px;margin:0 auto 28px}
  .loc-cta-buttons{display:flex;flex-wrap:wrap;gap:14px;justify-content:center}
  .loc-btn{display:inline-block;padding:14px 28px;border-radius:8px;font-weight:600;text-decoration:none;font-size:1rem;transition:opacity .2s}
  .loc-btn:hover{opacity:.9}
  .loc-btn--primary{background:#c9a84c;color:#1a1f3d}
  .loc-btn--whatsapp{background:#25d366;color:#fff}
  .loc-btn--outline{border:2px solid #fff;color:#fff;background:transparent}
  @media(max-width:600px){.loc-hero{padding:60px 0 40px}.loc-section{padding:40px 0}.loc-cta{padding:40px 0}.loc-cta-buttons{flex-direction:column;align-items:center}}
</style>
