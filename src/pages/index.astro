---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const title = 'Abogados en CDMX — Despacho Jurídico Especializado en Derecho Familiar, Civil, Penal y Corporativo';
const description = 'Despacho jurídico en Roma Norte, CDMX. Especialistas en derecho familiar, penal, civil, corporativo, migratorio, inmobiliario y laboral. Consulta gratuita.';
const canonical = 'https://abogadosencdmx.com';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LegalService",
      "name": "Abogados en CDMX",
      "description": "Despacho jurídico especializado en derecho familiar, civil, penal, corporativo, migratorio, inmobiliario y laboral en la Ciudad de México.",
      "url": "https://abogadosencdmx.com",
      "telephone": "+525564655501",
      "email": "contacto@abogadosencdmx.com",
      "foundingDate": "2014",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Guanajuato 224",
        "addressLocality": "Ciudad de México",
        "addressRegion": "CDMX",
        "postalCode": "06700",
        "addressCountry": "MX",
        "name": "Colonia Roma Norte, Alcaldía Cuauhtémoc"
      },
      "geo": { "@type": "GeoCoordinates", "latitude": 19.4194, "longitude": -99.1616 },
      "openingHoursSpecification": { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"], "opens": "09:00", "closes": "18:00" },
      "areaServed": { "@type": "City", "name": "Ciudad de México" },
      "priceRange": "$$",
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.9",
        "reviewCount": "8",
        "bestRating": "5",
        "worstRating": "1"
      },
      "review": [
        {
          "@type": "Review",
          "author": { "@type": "Person", "name": "Jorge Ramírez" },
          "datePublished": "2025-11-10",
          "reviewBody": "Cuando me encontré en una situación legal inesperada, el equipo de Abogados en CDMX actuó con rapidez y profesionalismo. Mi abogado penalista me mantuvo informado en cada etapa del proceso y logró el mejor resultado posible para mi caso.",
          "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" }
        },
        {
          "@type": "Review",
          "author": { "@type": "Person", "name": "Mariana Rivas" },
          "datePublished": "2025-10-22",
          "reviewBody": "Necesitaba regularizar una propiedad que heredé y no tenía escrituras. El despacho me guió en todo el proceso de usucapión de manera clara y sin complicaciones. Hoy el inmueble está a mi nombre gracias a su trabajo.",
          "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" }
        },
        {
          "@type": "Review",
          "author": { "@type": "Person", "name": "Lucia Torres" },
          "datePublished": "2025-09-15",
          "reviewBody": "Mi proceso de divorcio parecía imposible. Los abogados familiaristas del despacho lograron un convenio justo que protegió los intereses de mis hijos. Su sensibilidad y profesionalismo marcaron la diferencia.",
          "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" }
        },
        {
          "@type": "Review",
          "author": { "@type": "Person", "name": "Laura Stein" },
          "datePublished": "2025-12-03",
          "reviewBody": "Como extranjera casada con mexicano, necesitaba regularizar mi situación migratoria. El equipo me acompañó desde la solicitud hasta obtener mi residencia permanente. Todo impecable y dentro de los tiempos que me indicaron.",
          "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" }
        },
        {
          "@type": "Review",
          "author": { "@type": "Person", "name": "Carlos Mendoza" },
          "datePublished": "2026-01-08",
          "reviewBody": "La pelea por la custodia de mi hijo fue lo más difícil que he enfrentado. Mi abogada entendió mi caso, presentó las pruebas correctas y el juez falló a mi favor. Eternamente agradecido con el equipo.",
          "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" }
        }
      ]
    },
    {
      "@type": "WebSite",
      "name": "Abogados en CDMX",
      "url": "https://abogadosencdmx.com",
      "potentialAction": { "@type": "SearchAction", "target": "https://abogadosencdmx.com/blog?q={search_term_string}", "query-input": "required name=search_term_string" }
    },
    {
      "@type": "Organization",
      "name": "Abogados en CDMX",
      "url": "https://abogadosencdmx.com",
      "logo": "https://abogadosencdmx.com/images/og-default.svg",
      "description": "Despacho jurídico en la Colonia Roma Norte, CDMX. Especialistas en 7 áreas del derecho: familiar, penal, civil, corporativo, inmobiliario, migratorio y laboral. Fundado en 2014.",
      "foundingDate": "2014",
      "telephone": "+525564655501",
      "email": "contacto@abogadosencdmx.com",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Guanajuato 224",
        "addressLocality": "Ciudad de México",
        "addressRegion": "CDMX",
        "postalCode": "06700",
        "addressCountry": "MX",
        "name": "Colonia Roma Norte, Alcaldía Cuauhtémoc"
      },
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": "+525564655501",
        "contactType": "customer service",
        "availableLanguage": "es",
        "areaServed": { "@type": "City", "name": "Ciudad de México" }
      },
      "numberOfEmployees": { "@type": "QuantitativeValue", "minValue": 5, "maxValue": 20 },
      "sameAs": []
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://abogadosencdmx.com/" }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "¿Cuánto cuesta una consulta con un abogado en CDMX?",
          "acceptedAnswer": { "@type": "Answer", "text": "En nuestro despacho, la consulta inicial es gratuita y sin compromiso. Durante esta sesión de 30 a 45 minutos evaluamos su caso, explicamos las opciones legales disponibles y proporcionamos un presupuesto transparente. Los honorarios posteriores varían según la complejidad del caso y el área del derecho." }
        },
        {
          "@type": "Question",
          "name": "¿Qué áreas del derecho manejan en su despacho?",
          "acceptedAnswer": { "@type": "Answer", "text": "Nuestro despacho en la Colonia Roma Norte maneja 7 especialidades: derecho familiar (divorcios, custodia, pensión alimenticia), derecho penal (defensa criminal), derecho civil (contratos, responsabilidad), derecho corporativo (constitución de empresas, compliance), derecho inmobiliario (compraventa, arrendamiento), derecho migratorio (visas, residencia) y derecho laboral (despido injustificado, contratos)." }
        },
        {
          "@type": "Question",
          "name": "¿Cuánto tiempo tarda un divorcio en CDMX?",
          "acceptedAnswer": { "@type": "Answer", "text": "Un divorcio express de mutuo acuerdo en CDMX puede resolverse en 2 a 4 meses. Un divorcio contencioso sin acuerdo entre las partes puede tardar de 6 meses a 2 años dependiendo de la complejidad, bienes en disputa y custodia de hijos. Nuestro equipo de derecho familiar ha resuelto más de 300 casos en la Ciudad de México." }
        },
        {
          "@type": "Question",
          "name": "¿Dónde están ubicadas sus oficinas?",
          "acceptedAnswer": { "@type": "Answer", "text": "Nuestro despacho está ubicado en Guanajuato 224, Colonia Roma Norte, Cuauhtémoc, Ciudad de México, CP 06700. Estamos a 5 minutos caminando de la estación de Metro Insurgentes. Nuestro horario de atención es de lunes a viernes de 9:00 a 18:00 horas. También ofrecemos consultas por videollamada." }
        },
        {
          "@type": "Question",
          "name": "¿Qué debo hacer si me despidieron injustificadamente en CDMX?",
          "acceptedAnswer": { "@type": "Answer", "text": "Si fue despedido sin causa justificada, tiene derecho a una indemnización que incluye 3 meses de salario, 20 días por año trabajado, prima de antigüedad, salarios caídos y prestaciones proporcionales. Tiene 2 meses a partir del despido para presentar su demanda ante el Tribunal Laboral. Contacte a un abogado laboralista inmediatamente para proteger sus derechos." }
        }
      ]
    }
  ]
};

const especialidades = [
  { nombre: 'Derecho Familiar', slug: 'derecho-familiar-cdmx', desc: 'Divorcios, custodia, pensión alimenticia y violencia familiar.', icono: '⚖️' },
  { nombre: 'Derecho Penal', slug: 'derecho-penal-cdmx', desc: 'Defensa penal, amparos, recursos y asesoría a víctimas.', icono: '🛡️' },
  { nombre: 'Derecho Civil', slug: 'derecho-civil-cdmx', desc: 'Contratos, daños, responsabilidad civil y sucesiones.', icono: '📋' },
  { nombre: 'Derecho Corporativo', slug: 'derecho-corporativo-cdmx', desc: 'Constitución de sociedades, fusiones y compliance.', icono: '🏢' },
  { nombre: 'Derecho Inmobiliario', slug: 'derecho-inmobiliario-cdmx', desc: 'Compraventa, arrendamiento y regularización de propiedad.', icono: '🏠' },
  { nombre: 'Derecho Migratorio', slug: 'derecho-migratorio-cdmx', desc: 'Visas, residencia temporal y permanente, naturalización.', icono: '🌎' },
  { nombre: 'Derecho Laboral', slug: 'derecho-laboral-cdmx', desc: 'Despidos, liquidaciones, demandas y acoso laboral.', icono: '👷' },
];

const testimonios = [
  { nombre: 'Jorge Ramírez', area: 'Derecho Penal', texto: 'Cuando me encontré en una situación legal inesperada, el equipo de Abogados en CDMX actuó con rapidez y profesionalismo. Mi abogado penalista me mantuvo informado en cada etapa del proceso y logró el mejor resultado posible para mi caso.' },
  { nombre: 'Mariana Rivas', area: 'Derecho Inmobiliario', texto: 'Necesitaba regularizar una propiedad que heredé y no tenía escrituras. El despacho me guió en todo el proceso de usucapión de manera clara y sin complicaciones. Hoy el inmueble está a mi nombre gracias a su trabajo.' },
  { nombre: 'Roberto Ayala', area: 'Derecho Corporativo', texto: 'Contraté a Abogados en CDMX para estructurar la fusión de dos empresas. Su equipo corporativo manejó el due diligence, los contratos y las autorizaciones regulatorias con un nivel de detalle impecable.' },
  { nombre: 'Lucia Torres', area: 'Derecho Familiar', texto: 'Mi proceso de divorcio parecía imposible. Los abogados familiaristas del despacho lograron un convenio justo que protegió los intereses de mis hijos. Su sensibilidad y profesionalismo marcaron la diferencia.' },
  { nombre: 'Laura Stein', area: 'Derecho Migratorio', texto: 'Como extranjera casada con mexicano, necesitaba regularizar mi situación migratoria. El equipo me acompañó desde la solicitud hasta obtener mi residencia permanente. Todo impecable y dentro de los tiempos que me indicaron.' },
  { nombre: 'Ernesto Salas', area: 'Derecho Inmobiliario', texto: 'Tuve un problema con un inquilino que dejó de pagar la renta. El despacho inició el juicio de desocupación y en pocos meses recuperé mi propiedad. Su conocimiento del procedimiento fue evidente desde el primer día.' },
  { nombre: 'Carlos Mendoza', area: 'Derecho Familiar', texto: 'La pelea por la custodia de mi hijo fue lo más difícil que he enfrentado. Mi abogada entendió mi caso, presentó las pruebas correctas y el juez falló a mi favor. Eternamente agradecido con el equipo.' },
  { nombre: 'Rodrigo Cervantes', area: 'Derecho Corporativo', texto: 'Constituimos nuestra empresa con la asesoría del despacho y desde entonces manejan nuestros contratos comerciales. Su programa de compliance nos ha evitado varios problemas con proveedores y reguladores.' },
];

const equipo = [
  { nombre: 'Lic. Tania Mendoza', especialidad: 'Derecho Inmobiliario', slug: 'tania-mendoza', img: 'https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?w=600&h=750&fit=crop&crop=face&fm=webp&q=75' },
  { nombre: 'Lic. Luciana Valle', especialidad: 'Derecho Laboral', slug: 'luciana-valle', img: 'https://images.unsplash.com/photo-1580489944761-15a19d654956?w=600&h=750&fit=crop&crop=face&fm=webp&q=75' },
  { nombre: 'Lic. Ian Montiel', especialidad: 'Derecho Corporativo', slug: 'ian-montiel', img: 'https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=600&h=750&fit=crop&crop=face&fm=webp&q=75' },
];
---

<Base title={title} description={description} canonical={canonical} schema={schema} publishedDate="2025-09-15T00:00:00-06:00" modifiedDate="2026-03-22T00:00:00-06:00" author="Abogados en CDMX">
  <Header slot="header" />

  <!-- ══════════════════════════════════════════════
       SECTION 1: HERO
       ══════════════════════════════════════════════ -->
  <section class="hero">
    <div class="hero__bg">
      <img src="https://images.unsplash.com/photo-1589829545856-d10d557cf95f?w=1200&h=675&fit=crop&fm=webp&q=75" alt="Despacho jurídico profesional en la Ciudad de México" width="1200" height="675" loading="eager" fetchpriority="high" srcset="https://images.unsplash.com/photo-1589829545856-d10d557cf95f?w=640&h=360&fit=crop&fm=webp&q=75 640w, https://images.unsplash.com/photo-1589829545856-d10d557cf95f?w=960&h=540&fit=crop&fm=webp&q=75 960w, https://images.unsplash.com/photo-1589829545856-d10d557cf95f?w=1200&h=675&fit=crop&fm=webp&q=75 1200w, https://images.unsplash.com/photo-1589829545856-d10d557cf95f?w=1920&h=1080&fit=crop&fm=webp&q=75 1920w" sizes="100vw">
      <div class="hero__overlay"></div>
    </div>
    <div class="container hero__content">
      <div class="hero__text">
        <p class="hero__tag">Despacho Jurídico en Ciudad de México</p>
        <h1>Protegemos sus derechos con <span class="hero__accent">estrategia legal</span> y resultados comprobables</h1>
        <p class="hero__desc">Abogados en CDMX es un despacho jurídico ubicado en la Colonia Roma Norte, especializado en derecho familiar, penal, civil, corporativo, inmobiliario, migratorio y laboral. Brindamos representación legal integral a personas y empresas en la Ciudad de México.</p>
        <div class="hero__cta">
          <a href="/asesoria-inicial" class="btn-primary-wrap">Solicitar asesoría gratuita →</a>
          <a href="/especialidades" class="btn-secondary-wrap">Ver especialidades →</a>
        </div>
      </div>
      <div class="hero__badge">
        <div class="hero__badge-inner">
          <span class="hero__badge-num">300+</span>
          <span class="hero__badge-label">Casos resueltos en CDMX</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       SECTION 2: MARQUEE TRUST
       ══════════════════════════════════════════════ -->
  <section class="marquee-section">
    <div class="marquee-track">
      <div class="marquee-content">
        <span class="marquee-item">Tribunal Superior de Justicia CDMX</span>
        <span class="marquee-dot" aria-hidden="true">✦</span>
        <span class="marquee-item">Juzgados Familiares</span>
        <span class="marquee-dot" aria-hidden="true">✦</span>
        <span class="marquee-item">Juzgados Penales</span>
        <span class="marquee-dot" aria-hidden="true">✦</span>
        <span class="marquee-item">CEFRAMEL</span>
        <span class="marquee-dot" aria-hidden="true">✦</span>
        <span class="marquee-item">Instituto Nacional de Migración</span>
        <span class="marquee-dot" aria-hidden="true">✦</span>
        <span class="marquee-item">Registro Público de la Propiedad</span>
        <span class="marquee-dot" aria-hidden="true">✦</span>
        <span class="marquee-item">Tribunal Superior de Justicia CDMX</span>
        <span class="marquee-dot" aria-hidden="true">✦</span>
        <span class="marquee-item">Juzgados Familiares</span>
        <span class="marquee-dot" aria-hidden="true">✦</span>
        <span class="marquee-item">Juzgados Penales</span>
        <span class="marquee-dot" aria-hidden="true">✦</span>
        <span class="marquee-item">CEFRAMEL</span>
        <span class="marquee-dot" aria-hidden="true">✦</span>
        <span class="marquee-item">Instituto Nacional de Migración</span>
        <span class="marquee-dot" aria-hidden="true">✦</span>
        <span class="marquee-item">Registro Público de la Propiedad</span>
        <span class="marquee-dot" aria-hidden="true">✦</span>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       SECTION 3: ¿POR QUÉ ELEGIRNOS?
       ══════════════════════════════════════════════ -->
  <section class="section-padding">
    <div class="container">
      <div class="porque-grid">
        <div class="porque-left reveal">
          <p class="section-tag">¿Por qué elegirnos?</p>
          <h2>Un despacho que entiende su caso y defiende sus intereses</h2>
          <p>Abogados en CDMX combina conocimiento jurídico especializado con atención personalizada. No somos un despacho de volumen: cada caso recibe la estrategia y el tiempo que merece. Nuestros clientes saben quién es su abogado, conocen el estado de su expediente y participan en las decisiones clave de su proceso.</p>
          <a href="/quienes-somos" class="text-link">Conozca nuestra historia →</a>
        </div>
        <div class="porque-right">
          <div class="porque-card reveal">
            <span class="porque-num">01</span>
            <h4>Especialistas por área</h4>
            <p>Cada caso es atendido por un abogado especialista en la materia correspondiente, no por un generalista que improvisa.</p>
          </div>
          <div class="porque-card reveal">
            <span class="porque-num">02</span>
            <h4>Comunicación directa</h4>
            <p>Usted habla directamente con su abogado titular, no con asistentes. Respondemos llamadas y correos en menos de 24 horas.</p>
          </div>
          <div class="porque-card reveal">
            <span class="porque-num">03</span>
            <h4>Estrategia antes de acción</h4>
            <p>Evaluamos cada caso antes de actuar. Le explicamos las opciones, los riesgos y los costos reales para que usted decida con información completa.</p>
          </div>
          <div class="porque-card reveal">
            <span class="porque-num">04</span>
            <h4>Resultados comprobables</h4>
            <p>Más de 300 casos resueltos en 7 áreas del derecho con clientes que refieren a sus conocidos por la calidad de nuestra representación.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       SECTION 4: ÁREAS DE PRÁCTICA
       ══════════════════════════════════════════════ -->
  <section class="section-padding areas-section">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-tag">Especialidades</p>
        <h2>7 áreas del derecho para resolver su caso</h2>
        <p class="section-sub">Cada área cuenta con abogados dedicados exclusivamente a esa materia, con conocimiento actualizado de la legislación vigente en la Ciudad de México.</p>
      </div>
      <div class="areas-grid">
        {especialidades.map((esp, i) => (
          <a href={`/especialidades/${esp.slug}`} class="area-card reveal" style={`animation-delay:${i * 80}ms`}>
            <span class="area-icon" aria-hidden="true">{esp.icono}</span>
            <h3 class="area-name">{esp.nombre}</h3>
            <p class="area-desc">{esp.desc}</p>
            <span class="area-arrow" aria-hidden="true">→</span>
          </a>
        ))}
      </div>
      <div class="section-cta reveal">
        <a href="/especialidades" class="text-link">Ver todas las especialidades →</a>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       SECTION 5: SOBRE NOSOTROS PREVIEW
       ══════════════════════════════════════════════ -->
  <section class="section-padding about-section">
    <div class="container">
      <div class="about-grid">
        <div class="about-img reveal">
          <img src="https://images.unsplash.com/photo-1497366216548-37526070297c?w=800&h=600&fit=crop&fm=webp&q=75" alt="Oficinas de Abogados en CDMX en Colonia Roma Norte" width="800" height="600" loading="lazy">
          <div class="about-img__overlay">
            <span class="about-img__years">Desde 2014</span>
          </div>
        </div>
        <div class="about-text reveal">
          <p class="section-tag">Sobre nosotros</p>
          <h2>Un despacho con raíces en la Roma Norte y visión de excelencia</h2>
          <p>Abogados en CDMX opera desde Guanajuato 224, Colonia Roma Norte, Alcaldía Cuauhtémoc, C.P. 06700, Ciudad de México. Nuestro despacho nació con la convicción de que la asesoría legal profesional debe ser accesible, clara y orientada a resultados concretos.</p>
          <p>A lo largo de los años hemos consolidado un equipo de abogados especializados en 7 áreas del derecho, cada uno con experiencia comprobable ante los tribunales de la Ciudad de México. Nuestro compromiso es brindar a cada cliente una representación legal que combine rigor técnico con sensibilidad humana.</p>
          <div class="about-highlights">
            <div class="about-hl"><span class="about-hl__num">7</span><span class="about-hl__text">Áreas de especialización</span></div>
            <div class="about-hl"><span class="about-hl__num">20+</span><span class="about-hl__text">Profesionales del derecho</span></div>
          </div>
          <a href="/quienes-somos" class="btn-primary-wrap" style="margin-top:24px;">Conozca nuestro despacho →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       SECTION 6: SERVICIOS PREVIEW
       ══════════════════════════════════════════════ -->
  <section class="section-padding" style="background:var(--color-primary);color:var(--color-white);">
    <div class="container">
      <div class="servicios-header reveal">
        <p class="section-tag" style="color:var(--color-secondary);">Nuestros servicios</p>
        <h2 style="color:var(--color-white);">Lo acompañamos en cada etapa de su proceso legal</h2>
      </div>
      <div class="servicios-grid">
        <div class="servicio-card reveal">
          <span class="servicio-num">01</span>
          <h4>Asesoría legal inicial</h4>
          <p>Evaluamos su caso, identificamos las opciones legales y le presentamos una estrategia clara antes de tomar cualquier decisión.</p>
        </div>
        <div class="servicio-card reveal">
          <span class="servicio-num">02</span>
          <h4>Representación en tribunales</h4>
          <p>Litigamos ante juzgados civiles, familiares, penales, laborales y tribunales federales de la Ciudad de México con una estrategia procesal sólida.</p>
        </div>
        <div class="servicio-card reveal">
          <span class="servicio-num">03</span>
          <h4>Negociación y mediación</h4>
          <p>Buscamos resoluciones eficientes fuera de juicio cuando es posible. No todo requiere un litigio y muchos casos se resuelven mejor por la vía conciliatoria.</p>
        </div>
        <div class="servicio-card reveal">
          <span class="servicio-num">04</span>
          <h4>Gestión documental</h4>
          <p>Tramitamos documentos, escrituras, contratos, actas y registros ante notarios, registros públicos e instituciones gubernamentales.</p>
        </div>
        <div class="servicio-card reveal">
